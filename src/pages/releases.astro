---
import { getCollection, render } from 'astro:content';
import Layout from '~/layouts/PageLayout.astro';
import HeroText from '~/components/widgets/HeroText.astro';
import products from '~/data/products.json';

const metadata = {
  title: 'Releases — Meridian',
  description: 'Download Meridian and read release notes for every version. Always get the latest build here.',
};

const allEntries = await getCollection('changelog');
const entries = allEntries.sort((a, b) => b.data.publishDate.getTime() - a.data.publishDate.getTime());
const latest = entries.find((e) => e.data.isLatest) ?? entries[0];
const older = entries.filter((e) => e.id !== latest?.id);

const req = products.systemRequirements;

const typeBadge: Record<string, string> = {
  major: 'bg-purple-100 text-purple-800',
  minor: 'bg-blue-100 text-blue-800',
  patch: 'bg-green-100 text-green-800',
  hotfix: 'bg-red-100 text-red-800',
};

const { Content: LatestContent } = await render(latest);
---

<Layout metadata={metadata}>
  <HeroText
    title="Releases"
    subtitle={`Version history and downloads for Meridian — NinjaTrader 8. Current build: v${latest?.data.version}.`}
  />

  <!-- System requirements + Installation -->
  <section id="requirements" class="max-w-4xl mx-auto px-6 mb-14">
    <div class="grid md:grid-cols-2 gap-6">
      <div class="rounded-2xl border border-zinc-200 bg-white p-6 shadow-sm">
        <h2 class="text-base font-semibold mb-4 text-zinc-900">System requirements</h2>
        <ul class="space-y-2.5 text-sm text-zinc-600">
          <li class="flex gap-2">
            <span class="text-zinc-400 w-24 shrink-0">OS</span>
            <span class="font-medium text-zinc-900 text-right ml-auto">{req.os}</span>
          </li>
          <li class="flex gap-2">
            <span class="text-zinc-400 w-24 shrink-0">NinjaTrader</span>
            <span class="font-medium text-zinc-900 text-right ml-auto">{req.ninjaTrader}</span>
          </li>
          <li class="flex gap-2">
            <span class="text-zinc-400 w-24 shrink-0">RAM</span>
            <span class="font-medium text-zinc-900 text-right ml-auto">{req.ram}</span>
          </li>
          <li class="flex gap-2">
            <span class="text-zinc-400 w-24 shrink-0">Disk</span>
            <span class="font-medium text-zinc-900 text-right ml-auto">{req.disk}</span>
          </li>
        </ul>
        {req.note && <p class="mt-4 text-xs text-zinc-500 leading-relaxed">{req.note}</p>}
      </div>

      <div class="rounded-2xl border border-zinc-200 bg-white p-6 shadow-sm">
        <h2 class="text-base font-semibold mb-4 text-zinc-900">Installation</h2>
        <ol class="space-y-2 text-sm text-zinc-600 list-decimal list-inside leading-relaxed">
          <li>Download the latest build from the card below.</li>
          <li>NinjaTrader 8 → <strong>Tools → Import NinjaScript Add-On</strong>.</li>
          <li>Select the downloaded <code class="bg-zinc-100 px-1 rounded text-xs">.zip</code> and restart NinjaTrader.</li>
          <li>Open <strong>PSI Monitor</strong> from the Control Center → New.</li>
        </ol>
        <p class="mt-4 text-xs text-zinc-500">
          Need help? Visit <a href="/support" class="underline text-zinc-600 hover:text-zinc-900">support</a> or read the <a href="/faq" class="underline text-zinc-600 hover:text-zinc-900">FAQ</a>.
        </p>
      </div>
    </div>
  </section>

  <!-- Latest release — full card with download -->
  {latest && (
    <section id={`v${latest.data.version}`} class="max-w-4xl mx-auto px-6 mb-10">
      <div class="rounded-2xl border-2 border-emerald-600/25 bg-gradient-to-b from-white to-emerald-50/20 p-8 shadow-md">
        <!-- Header -->
        <div class="flex flex-wrap items-center gap-3 mb-2">
          <span class="px-2.5 py-0.5 rounded-full text-xs font-semibold bg-emerald-100 text-emerald-800">Latest</span>
          <span class={`px-2.5 py-0.5 rounded-full text-xs font-semibold capitalize ${typeBadge[latest.data.type]}`}>
            {latest.data.type}
          </span>
        </div>
        <h2 class="text-2xl font-bold text-zinc-900 mb-1">{latest.data.title}</h2>
        <p class="text-sm text-zinc-500 mb-6">
          Released {latest.data.publishDate.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
          · NinjaTrader 8 add-on
        </p>

        <!-- Changelog content -->
        <div class="prose prose-sm max-w-none prose-headings:font-semibold prose-headings:text-zinc-900 prose-headings:text-base prose-li:text-zinc-600 prose-p:text-zinc-600 mb-8 pb-8 border-b border-zinc-200">
          <LatestContent />
        </div>

        <!-- Disclaimer checkbox + download -->
        <div class="max-w-lg mb-5">
          <label class="flex items-start gap-3 cursor-pointer">
            <input
              type="checkbox"
              id="disclaimer-confirm"
              class="mt-0.5 w-4 h-4 rounded border-zinc-300 text-emerald-600 cursor-pointer shrink-0"
            />
            <span class="text-sm text-zinc-600">
              I have read the <a href="/disclaimer" class="text-emerald-800 underline font-medium">risk disclaimer</a>.
              I understand Meridian is a behavioral monitor only, does not provide trading advice, and that futures and
              forex trading involve substantial risk of loss.
            </span>
          </label>
        </div>

        <div class="flex flex-wrap items-center gap-4">
          <a
            id="download-btn"
            href={latest.data.downloadUrl ?? '#'}
            class="inline-flex items-center gap-2 px-7 py-3 rounded-full bg-emerald-600 text-white font-semibold opacity-40 pointer-events-none transition-all hover:bg-emerald-700 text-sm"
            aria-disabled="true"
          >
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4" />
            </svg>
            Download v{latest.data.version} (.zip)
          </a>
          <span class="text-xs text-zinc-400">
            Need a license? <a href="https://meridianpsi.lemonsqueezy.com/checkout/buy/b7b8b514-fefa-4a34-8cad-d2e68f564d25" class="text-emerald-700 font-medium hover:underline">Start free trial</a>
          </span>
        </div>
      </div>
    </section>
  )}

  <!-- Older versions -->
  {older.length > 0 && (
    <section class="max-w-4xl mx-auto px-6 pb-24">
      <h2 class="text-sm font-semibold text-zinc-500 uppercase tracking-widest mb-4">Previous versions</h2>
      <div class="rounded-xl border border-zinc-200 bg-white overflow-hidden divide-y divide-zinc-100">
        {older.map(async (entry) => {
          const { Content: OldContent } = await render(entry);
          return (
            <details id={`v${entry.data.version}`} class="group">
              <summary class="flex items-center justify-between px-5 py-3.5 cursor-pointer hover:bg-zinc-50 transition-colors list-none">
                <div class="flex items-center gap-3">
                  <span class="font-semibold text-sm text-zinc-900">v{entry.data.version}</span>
                  <span class={`px-2 py-0.5 rounded-full text-xs font-medium capitalize ${typeBadge[entry.data.type]}`}>
                    {entry.data.type}
                  </span>
                  <span class="text-xs text-zinc-400">
                    {entry.data.publishDate.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' })}
                  </span>
                </div>
                <svg class="w-4 h-4 text-zinc-400 transition-transform group-open:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
                </svg>
              </summary>
              <div class="px-5 pb-5 pt-2">
                <div class="prose prose-sm max-w-none prose-headings:font-semibold prose-headings:text-zinc-800 prose-headings:text-sm prose-li:text-zinc-600 mb-4">
                  <OldContent />
                </div>
                {entry.data.downloadUrl && entry.data.downloadUrl !== '/download' && entry.data.downloadUrl !== '/releases' && (
                  <a
                    href={entry.data.downloadUrl}
                    class="inline-flex items-center gap-1.5 text-xs font-medium text-zinc-600 hover:text-zinc-900 border border-zinc-200 hover:border-zinc-400 rounded-lg px-3 py-1.5 transition-all"
                  >
                    <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4" />
                    </svg>
                    Download v{entry.data.version}
                  </a>
                )}
              </div>
            </details>
          );
        })}
      </div>
    </section>
  )}
</Layout>

<script>
  const checkbox = document.getElementById('disclaimer-confirm') as HTMLInputElement | null;
  const btn = document.getElementById('download-btn');

  checkbox?.addEventListener('change', () => {
    if (checkbox.checked) {
      btn?.classList.remove('opacity-40', 'pointer-events-none');
      btn?.removeAttribute('aria-disabled');
    } else {
      btn?.classList.add('opacity-40', 'pointer-events-none');
      btn?.setAttribute('aria-disabled', 'true');
    }
  });
</script>
