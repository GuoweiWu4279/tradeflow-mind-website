---
import { getCollection, render } from 'astro:content';
import Layout from '~/layouts/PageLayout.astro';
import HeroText from '~/components/widgets/HeroText.astro';

const metadata = {
  title: 'Changelog — PSI Monitor',
  description: 'Release notes and version history for PSI Monitor. Stay up to date with the latest improvements and fixes.',
};

const allEntries = await getCollection('changelog');
const entries = allEntries.sort((a, b) => b.data.publishDate.getTime() - a.data.publishDate.getTime());

const typeBadge: Record<string, string> = {
  major: 'bg-purple-100 text-purple-800 dark:bg-purple-900/40 dark:text-purple-300',
  minor: 'bg-blue-100 text-blue-800 dark:bg-blue-900/40 dark:text-blue-300',
  patch: 'bg-green-100 text-green-800 dark:bg-green-900/40 dark:text-green-300',
  hotfix: 'bg-red-100 text-red-800 dark:bg-red-900/40 dark:text-red-300',
};
---

<Layout metadata={metadata}>
  <HeroText
    title="Changelog"
    subtitle="Release notes and version history for PSI Monitor."
  />

  <section class="max-w-3xl mx-auto px-6 pb-20">
    {entries.map(async (entry) => {
      const { Content } = await render(entry);
      return (
        <div class="mb-12 pb-12 border-b border-zinc-200 dark:border-zinc-800 last:border-0">
          <div class="flex flex-wrap items-center gap-3 mb-4">
            <h2 class="text-xl font-bold text-zinc-900 dark:text-white m-0">
              {entry.data.title}
            </h2>
            {entry.data.isLatest && (
              <span class="px-2 py-0.5 rounded-full text-xs font-medium bg-emerald-100 text-emerald-800 dark:bg-emerald-900/40 dark:text-emerald-300">
                Latest
              </span>
            )}
            <span class={`px-2 py-0.5 rounded-full text-xs font-medium capitalize ${typeBadge[entry.data.type]}`}>
              {entry.data.type}
            </span>
          </div>
          <p class="text-sm text-zinc-500 dark:text-zinc-400 mb-6">
            Released {entry.data.publishDate.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
          </p>
          <div class="prose dark:prose-invert prose-sm max-w-none prose-headings:font-semibold">
            <Content />
          </div>
          {entry.data.downloadUrl && (
            <div class="mt-6">
              <a
                href={entry.data.downloadUrl}
                class="inline-flex items-center gap-2 px-4 py-2 rounded-lg bg-zinc-900 dark:bg-white text-white dark:text-zinc-900 text-sm font-medium hover:opacity-90 transition-opacity"
              >
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4" />
                </svg>
                Download v{entry.data.version}
              </a>
            </div>
          )}
        </div>
      );
    })}
  </section>
</Layout>
