---
import Layout from '~/layouts/PageLayout.astro';
import heroBgImage from '~/assets/images/hero-bg.jpg';

import Hero from '~/components/widgets/Hero.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';

const metadata = {
  title: 'Meridian — The First Real-Time Psychological Stability Index for Active Traders',
  ignoreTitleTemplate: true,
};

const marqueeRow1 = [
  {
    quote: "Passed my third Apex evaluation. The first two I blew up on days where, in hindsight, I should have just closed the platform. The pattern was obvious once I could see it.",
    name: 'Mike R.',
    role: 'Prop firm trader',
  },
  {
    quote: "Three months in. I thought I had clean execution — the overtrading metric disagreed from day one.",
    name: 'Jason K.',
    role: 'Futures day trader',
  },
  {
    quote: "Turned out I wasn't losing because of my entries. I was adding to losing positions and ignoring my own rules. Took data to admit it.",
    name: 'Anonymous',
    role: '',
  },
  {
    quote: "After a losing session I used to review charts to explain what happened. Now I check the session report first. It's faster and more honest.",
    name: 'Sam W.',
    role: 'ES / NQ',
  },
  {
    quote: "It doesn't close your positions for you — that part is still on you. But I stopped pretending I didn't notice the score dropping while I was moving my stop around.",
    name: 'T. Rodriguez',
    role: 'NQ futures',
  },
  {
    quote: "The seven bars make it immediately clear which habit is pulling the score down. I kept telling myself I was trading fine. The data disagreed consistently.",
    name: 'Elena V.',
    role: 'MNQ scalper',
  },
  {
    quote: "I don't use tools that send my fill data to the cloud. Local-only was non-negotiable for me.",
    name: 'David Chen',
    role: 'Independent trader',
  },
  {
    quote: "Being able to use Market Replay without it touching my live baseline was more useful than I expected.",
    name: 'Chris P.',
    role: 'Futures swing',
  },
  {
    quote: "I run two accounts with copy fills. I was expecting double-counting issues in the score. It handled it cleanly without any configuration.",
    name: 'Jordan L.',
    role: 'Multi-account',
  },
];

const marqueeRow2 = [
  {
    quote: "Post-session journals have their place. This is different — the feedback arrives while the session is still running, not the next morning.",
    name: 'Anonymous',
    role: '',
  },
  {
    quote: "The stop-widening flag caught me doing something I always denied — moving my stop out when a trade went against me. Useful confirmation, even if it wasn't comfortable.",
    name: 'Marcus T.',
    role: 'CL / GC',
  },
  {
    quote: "I've restarted funded accounts more times than I want to count. If someone had told me a revenge-entry detector would matter more than another indicator, I wouldn't have believed them.",
    name: 'Alex Nowak',
    role: 'Prop trader',
  },
  {
    quote: "Four years trading NQ. Thought I had a solid read on my own behavior. First week of data showed me I had several habits I wasn't aware of.",
    name: 'James O.',
    role: 'Day trader',
  },
  {
    quote: "The caution signal fired and I decided I could manage through it. Twenty minutes later I had hit my daily limit. I can't blame the tool — I ignored it.",
    name: 'Sara',
    role: 'ES trader',
  },
  {
    quote: "A rough Tuesday doesn't disappear from the score just because Wednesday started. That's accurate. That's how it actually feels.",
    name: 'Leo B.',
    role: 'Overnight + day',
  },
  {
    quote: "Thought my exits were disciplined. Turns out there's a consistent pattern on certain days. I don't love it, but I can work with the information.",
    name: 'Kim H.',
    role: 'Index futures',
  },
  {
    quote: "The alerts are infrequent enough that I don't tune them out. When one fires, I actually pause before doing anything.",
    name: 'Andre C.',
    role: 'Prop + personal',
  },
];

const steps = [
  {
    label: 'Configure',
    bg: '#f4f4f5',
    desc: 'Adapt the system to your strategy',
    fullDesc: 'Adapt the system to any strategy or trading style. Meridian allows you to define a comprehensive set of operational boundaries, establishing a baseline customized to your specific execution methods.',
    bullets: ['Universal compatibility: Configurable for any trading style and strategy.', 'Comprehensive parameters: Set exact session rules, position limits, and stop conventions.', 'Adaptive baseline: Machine learning updates your personal rhythm after every session.'],
    image: '/configue-pic.jpg?v=2',
    imgAlt: 'Meridian personal baseline configuration panel',
    icon: '<svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z" /><path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" /></svg>',
  },
  {
    label: 'Live Monitor',
    bg: '#1C1C1E',
    desc: 'PSI updates in <100ms',
    fullDesc: 'Track your execution state instantly. Grounded in quantitative models and cognitive research, Meridian calculates your Psychological Stability Index (PSI) in real time.',
    bullets: ['Actionable PSI score updates in &lt;100ms', '7 behavioral signal bars to isolate execution errors', 'Live session stats: trades, win rate, and duration'],
    image: '/screenshots/psi-critical.png',
    imgAlt: 'Meridian PSI Monitor showing a Critical score with seven behavioral signal bars',
    icon: '<svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z" /></svg>',
  },
  {
    label: 'Guard',
    bg: '#1C1C1E',
    desc: 'Automated enforcement',
    fullDesc: 'Automated discipline. You set the rules when you are objective. Guard enforces them automatically when critical thresholds are breached.',
    bullets: ['6 configurable behavioral trigger conditions', '5 automated response levels (from simple alerts to platform lockout)', 'Set once, active for every session'],
    image: '/guard-hero.png',
    imgAlt: 'Meridian Guard — broker disconnected after a rule breach, with reconnect instructions',
    link: { href: '/guard', text: 'Explore Meridian Guard' },
    icon: '<svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" /></svg>',
  },
  {
    label: 'Review & Intel',
    bg: '#f4f4f5',
    desc: 'Patterns across sessions',
    fullDesc: 'Analyze the direct correlation between your psychological state and your P&L. Meridian tracks your behavioral data across multiple timeframes to provide objective, actionable execution analysis.',
    bullets: ['Daily: Daily journaling and detailed session reports.', 'Weekly: Execution analysis identifying repetitive composure patterns.', 'Monthly: Long-term performance tracking, behavioral correlation and very comprehensive analysis.', 'Local History: Up to 5 years of session data stored entirely on your PC.'],
    image: '/screenshots/review-intel-illustration.jpg',
    imgAlt: 'Meridian Review & Intel — session history and analysis overview',
    /* Wider than 16:9 — cover fills the panel so letterboxing bars don’t show (other steps stay contain) */
    imgObjectFit: 'cover' as const,
    icon: '<svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 17v-2m3 2v-4m3 4v-6m2 10H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" /></svg>',
  },
];

const signals = [
  { name: 'Revenge Entry',     desc: 'Re-entry after loss with elevated size' },
  { name: 'Stop Manipulation', desc: 'Widening stops in the adverse direction' },
  { name: 'Size Spike',        desc: 'Position exceeds your declared rule' },
  { name: 'Hold Bias',         desc: 'Abnormal hold duration vs your baseline' },
  { name: 'Position Overstay', desc: 'Holding a loser past your 90th-percentile time' },
  { name: 'Rule Violations',   desc: 'Trading outside your declared session rules' },
  { name: 'Overtrading Pace',  desc: 'Entry frequency accelerating vs history' },
];

const intelShowcaseTabs = [
  {
    title: 'Session Report',
    sub: 'Detailed breakdown of every trade session. Track your PSI fluctuations, time spent in critical zones, and exact behavioral signals triggered.',
    icon: '<svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 17v-2m3 2v-4m3 4v-6m2 10H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" /></svg>',
    slides: [
      { src: '/screenshots/intel-session-calendar.png', alt: 'Meridian session calendar with PSI, composure, and P&L per session' },
    ],
  },
  {
    title: 'History & Progress',
    sub: 'Visualize your discipline over time. Track your monthly composure grades, daily streak stability, and long-term behavioral progress.',
    icon: '<svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" /></svg>',
    slides: [
      { src: '/screenshots/homepage-intel/history/monthly-calendar-list.png', alt: 'Meridian monthly calendar in list view' },
      { src: '/screenshots/homepage-intel/history/monthly-calendar.png',      alt: 'Meridian monthly calendar overview' },
      { src: '/screenshots/homepage-intel/history/psi-trend-in-month.png',    alt: 'Meridian PSI trend for the month' },
    ],
  },
  {
    title: 'Intel & Correlation',
    sub: 'Cross-reference your psychology with your P&L. Discover your weakest trading days and receive a personalized Pre-Session Risk Brief.',
    icon: '<svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z" /></svg>',
    slides: [
      { src: '/screenshots/homepage-intel/intel/regression.png',              alt: 'Meridian regression analysis: psychology vs outcomes' },
      { src: '/screenshots/homepage-intel/intel/today-risk-and-analysis.png', alt: 'Meridian today risk and analysis' },
      { src: '/screenshots/homepage-intel/intel/weekly-trending.png',         alt: 'Meridian weekly behavioral trending' },
    ],
  },
];
---

<Layout metadata={metadata}>
  <!-- ——— HERO — light, clean ——— -->
  <!-- Hero background: replace src/assets/images/hero-bg.jpg (imported so dev/build always resolve URL). -->
  <section
    class="relative overflow-hidden md:-mt-[84px] not-prose hero-bg-home"
    style={`--hero-bg: url('${heroBgImage.src}')`}
  >
    <!-- Bottom fade: blends hero into the section below -->
    <div class="absolute bottom-0 left-0 right-0 h-32 pointer-events-none" style="background: linear-gradient(to bottom, transparent, #fafafa);" aria-hidden="true"></div>
    <!-- Header spacer -->
    <div class="md:pt-[84px]"></div>
    <div class="relative z-[1] max-w-6xl mx-auto px-6">
      <div class="pt-14 pb-12 md:pt-20 md:pb-16 lg:pt-24 lg:pb-20">
        <div class="text-center max-w-4xl mx-auto">
          <!-- Eyebrow badge -->
          <div class="inline-flex items-center gap-2.5 border px-4 py-1.5 mb-8 fade-up rounded-full" style="border-color: rgba(5,150,105,0.35); background: rgba(5,150,105,0.07);">
            <span class="w-1.5 h-1.5 rounded-full" style="background:#059669;" aria-hidden="true"></span>
            <span class="text-[11px] font-semibold tracking-[0.15em] uppercase" style="color:#059669;">Trading psychology monitor</span>
          </div>
          <!-- Title with word-blur animation -->
          <h1 class="text-5xl md:text-6xl lg:text-[4.25rem] font-bold leading-[1.08] tracking-tight mb-5 word-blur-target" style="color:#18181b;">
            Every trader has a plan.<br />
            <span style="color:#059669;">The market's job is to make you forget it.</span>
          </h1>
          <p class="text-sm md:text-base font-medium leading-snug max-w-xl mx-auto mb-6 fade-up" style="color:#3f3f46;">
            The only system that enforces your trading rules when you can't — in the moment, not in tomorrow's journal entry.
          </p>
          <!-- Subtitle -->
          <p class="text-base md:text-lg leading-relaxed max-w-2xl mx-auto mb-10 fade-up" style="color:#71717a;">
            <strong style="color:#18181b; font-weight:600;">Meridian</strong> is a real-time psychological stability monitor for active traders.<br />
            Powered by cognitive research and adaptive learning, it tracks seven behavioral signals to enforce your risk limits and journal your performance—all locally on your PC.
          </p>
          <!-- CTAs -->
          <div class="flex flex-col sm:flex-row sm:justify-center gap-3 fade-up">
            <a href="/pricing" class="btn btn-lg font-semibold" style="background:#059669; color:white; border:1px solid #059669;">Start free trial</a>
            <a href="#how-it-works" class="btn btn-lg font-semibold" style="border:1.5px solid rgba(0,0,0,0.2); color:#18181b; background:transparent;">How it works</a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Supported Platforms section -->
  <div class="fade-up border-b border-zinc-200/60" style="background: #FEFEFE;">
    <div class="max-w-6xl mx-auto px-6 py-8 md:py-10">
      <div class="flex items-center justify-between mb-6">
        <p class="text-base font-semibold" style="color:#18181b;">Supported Platform</p>
        <p class="text-xs" style="color:#a1a1aa;">More platforms launching very shortly.</p>
      </div>
      <div class="flex justify-center">
        <img
          src="/logos/ninja-trader.jpg"
          alt="NinjaTrader"
          style="height: 104px; width: auto; object-fit: contain; opacity: 0.9;"
        />
      </div>
    </div>
  </div>

  <!-- ——— PROBLEM — light off-white ——— -->
  <section class="relative py-16 md:py-24 px-6" style="background:#f7f5f1; border-top:1px solid rgba(0,0,0,0.05); border-bottom:1px solid rgba(0,0,0,0.05);">
    <div class="relative max-w-2xl mx-auto text-center">
      <!-- Eyebrow badge -->
      <div class="inline-flex items-center gap-2.5 border px-4 py-1.5 mb-6 rounded-full fade-up" style="border-color: rgba(5,150,105,0.35); background: rgba(5,150,105,0.07);">
        <span class="w-1.5 h-1.5 rounded-full" style="background:#059669;" aria-hidden="true"></span>
        <span class="text-[11px] font-semibold tracking-[0.15em] uppercase" style="color:#059669;">The Problem</span>
      </div>
      <!-- Heading with word-blur animation + two-tone split -->
      <h2 class="text-3xl md:text-4xl lg:text-5xl font-bold leading-[1.12] tracking-tight mb-5 word-blur-target" style="color:#18181b;">
        Institutions have risk management teams.<br />
        <span style="color:#059669;">You have Meridian.</span>
      </h2>
      <!-- Body -->
      <p class="text-base leading-relaxed max-w-xl mx-auto fade-up" style="color:#71717a;">
        Institutional traders rely on dedicated teams, data systems, and hard limits to prevent emotional decisions. Retail traders trade alone, relying only on willpower.
      </p>
      <p class="text-base leading-relaxed max-w-xl mx-auto mt-4 fade-up" style="color:#71717a;">
        Meridian bridges this gap. It acts as your personal risk manager, tracking your behavior and enforcing your rules the moment emotions take over.
      </p>
    </div>
  </section>

  <!-- ——— ROADMAP / HOW IT WORKS ——— -->
  <section id="how-it-works" class="section border-y border-zinc-200/80 bg-white">
    <div class="container-wide">
      <div class="text-center mb-16 max-w-2xl mx-auto">
        <p class="eyebrow mb-4 fade-up">How it works</p>
        <h2 class="text-3xl md:text-5xl font-bold tracking-tight mb-5 fade-up" style="color:#18181b;">
          Before. During. After. Every session.
        </h2>
        <p class="lead fade-up max-w-3xl mx-auto text-balance" style="color:#71717a;">
          Meridian fits into every stage of how you trade — setup, real-time monitoring and automatic enforcement, and post-session review.
        </p>
      </div>

      <!-- 4-step roadmap -->
      <div class="relative">
        <!-- dotted connector line (desktop) -->
        <div
          class="hidden md:block absolute top-6 left-[12.5%] right-[12.5%] border-t border-dashed border-zinc-300/80"
          aria-hidden="true"
        ></div>

        <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-4 gap-6">
          {[
            { num: '01', title: 'Configure',     sub: 'Any strategy. Any style.',      bullets: ['Session rules & time windows', 'Size limits and stop conventions', 'Adaptive baseline learns your rhythm'] },
            { num: '02', title: 'Live Monitor',  sub: '7 signals. <100ms updates.',    bullets: ['Quantitative math models & cognitive research', '7 signals tracking the most common psychological failure patterns', 'Live score — see instantly which habit is driving performance'] },
            { num: '03', title: 'Guard',         sub: 'Rules that enforce themselves.', bullets: ['6 trigger conditions', '5 response levels', 'Quiet alert to full platform lockout'] },
            { num: '04', title: 'Review & Intel', sub: 'Every session. Every pattern.', bullets: ['PSI, Composure, and trade stats', 'Monthly digest & P&L correlation', "Today's Risk Brief"] },
          ].map((step, i) => (
            <div class="fade-up" style={`transition-delay:${i * 80}ms`}>
              <!-- Number disc -->
              <div class="relative z-10 mx-auto w-12 h-12 rounded-full bg-white border border-zinc-200 flex items-center justify-center mb-5 text-sm font-semibold tracking-tight text-[#4b734e] shadow-sm">
                {step.num}
              </div>
              <div class="text-center mb-5">
                <h3 class="text-base font-semibold mb-1" style="color:#18181b;">{step.title}</h3>
                <p class="text-sm" style="color:#71717a;">{step.sub}</p>
              </div>
              <ul class="card card-hover p-5 space-y-2.5 shadow-sm shadow-zinc-900/5 ring-1 ring-zinc-900/[0.04]">
                {step.bullets.map((b) => (
                  <li class="flex items-start gap-2.5 text-sm" style="color:#71717a;">
                    <svg class="mt-0.5 w-4 h-4 shrink-0 text-[#4b734e]" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7" />
                    </svg>
                    <span>{b}</span>
                  </li>
                ))}
              </ul>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- ——— STEP DETAIL — light accordion + cross-fade image ——— -->
  <section id="step-detail" class="py-16 lg:py-24 px-6 border-y border-zinc-200/70 bg-gradient-to-b from-zinc-100/70 via-zinc-50/90 to-white">
    <div class="max-w-6xl mx-auto">

      <!-- Eyebrow spans above both columns; grid aligns accordion top with H2 -->
      <div class="max-w-xl mb-6 lg:mb-8">
        <div class="inline-flex items-center gap-2.5 border px-4 py-1.5 rounded-full" style="border-color:rgba(5,150,105,0.35); background:rgba(5,150,105,0.07);">
          <span class="w-1.5 h-1.5 rounded-full" style="background:#059669;" aria-hidden="true"></span>
          <span class="text-[11px] font-semibold tracking-[0.15em] uppercase" style="color:#059669;">See it in action</span>
        </div>
      </div>

      <div class="lg:grid lg:grid-cols-[52%_48%] lg:gap-12 lg:items-start">
        <div class="flex flex-col">
          <h2 class="text-4xl md:text-5xl font-bold leading-[1.1] tracking-tight word-blur-target mb-2" style="color:#18181b;">
            The 4 Stages of<br />Behavioral Risk Management.
          </h2>
          <p class="text-sm leading-relaxed max-w-xl mb-4" style="color:#71717a;">
            How Meridian integrates into your session to ensure consistent execution.
          </p>
          <!-- Image — 16:9, light matte (dark screenshots still read fine); sticky on desktop -->
          <div
            id="step-img-panel"
            class="relative overflow-hidden rounded-xl mb-8 lg:mb-0 shadow-sm ring-1 ring-zinc-900/[0.06]"
            style="position: relative; isolation: isolate; z-index: 0; width: 100%; background: #f4f4f5; aspect-ratio: 16/9;"
          >
            {steps.map((step, i) => (
              <img
                data-step-img={i}
                data-step-bg={step.bg}
                src={step.image}
                alt={step.imgAlt}
                class:list={['acc-img', { 'acc-img--cover': 'imgObjectFit' in step && step.imgObjectFit === 'cover' }]}
                loading="lazy"
              />
            ))}
          </div>
        </div>

        <div class="lg:self-start max-lg:mt-8">
          <div class="space-y-1" role="list" aria-label="Product stages">
            {steps.map((step, i) => (
              <div
                data-acc-item={i}
                role="listitem"
                class:list={['acc-item', { 'acc-item-active': i === 0 }]}
                tabindex="0"
              >
                <div class="flex items-start gap-4 p-5">
                  <div class="acc-item-icon flex-shrink-0 p-2 rounded-lg mt-0.5" aria-hidden="true" set:html={step.icon} />
                  <div class="flex-1 min-w-0">
                    <h3 class="acc-item-title text-base font-semibold">
                      <span class="acc-item-num text-xs font-semibold tracking-widest mr-1">0{i + 1} —</span>
                      {step.label}
                    </h3>
                    <div class="acc-item-body overflow-hidden" style="max-height:0;">
                      <p class="text-sm leading-relaxed mt-2 mb-3" style="color:#71717a;">{step.fullDesc}</p>
                      <ul class="space-y-1.5 text-sm mb-2" style="color:#3f3f46;">
                        {step.bullets.map((b) => (
                          <li class="flex items-start gap-2.5">
                            <span class="mt-[7px] w-1 h-1 rounded-full shrink-0 bg-[#4b734e]"></span>
                            <span set:html={b} />
                          </li>
                        ))}
                      </ul>
                      {step.link && (
                        <a href={step.link.href} class="inline-flex items-center gap-1.5 text-sm font-medium mt-3 transition-colors text-[#4b734e] hover:text-[#3d5c40]">
                          {step.link.text}
