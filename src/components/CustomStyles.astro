---
import '@fontsource-variable/inter';

// 'DM Sans'
// Nunito
// Dosis
// Outfit
// Roboto
// Literata
// 'IBM Plex Sans'
// Karla
// Poppins
// 'Fira Sans'
// 'Libre Franklin'
// Inconsolata
// Raleway
// Oswald
// 'Space Grotesk'
// Urbanist
---

<style is:inline>
  :root {
    --aw-font-sans: 'Inter Variable';
    --aw-font-serif: 'Inter Variable';
    --aw-font-heading: 'Inter Variable';

    --aw-color-primary: rgb(5 150 105);      /* emerald-600 */
    --aw-color-secondary: rgb(4 120 87);     /* emerald-700 */
    --aw-color-accent: rgb(5 150 105);       /* same as primary — single accent */

    --aw-color-text-heading: rgb(17 24 39);  /* zinc-900 */
    --aw-color-text-default: rgb(63 63 70);  /* zinc-700 */
    --aw-color-text-muted: rgb(107 114 128); /* zinc-500 — WCAG AA */
    --aw-color-bg-page: rgb(255 255 255);

    --aw-color-bg-page-dark: rgb(9 9 11);    /* zinc-950 */

    ::selection {
      background-color: rgb(209 250 229);    /* emerald-100 */
      color: rgb(6 78 59);                   /* emerald-900 */
    }
  }

  .dark {
    --aw-font-sans: 'Inter Variable';
    --aw-font-serif: 'Inter Variable';
    --aw-font-heading: 'Inter Variable';

    --aw-color-primary: rgb(16 185 129);     /* emerald-500 — lifts on dark */
    --aw-color-secondary: rgb(5 150 105);    /* emerald-600 */
    --aw-color-accent: rgb(16 185 129);

    --aw-color-text-heading: rgb(244 244 245); /* zinc-100 */
    --aw-color-text-default: rgb(228 228 231); /* zinc-200 */
    --aw-color-text-muted: rgb(161 161 170);   /* zinc-400 */
    --aw-color-bg-page: rgb(9 9 11);

    ::selection {
      background-color: rgb(6 78 59);
      color: snow;
    }
  }
</style>
