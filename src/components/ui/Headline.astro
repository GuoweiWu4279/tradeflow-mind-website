---
import type { Headline as Props } from '~/types';
import { twMerge } from 'tailwind-merge';

const {
  title = await Astro.slots.render('title'),
  subtitle = await Astro.slots.render('subtitle'),
  tagline,
  classes = {},
} = Astro.props;

const {
  container: containerClass = 'max-w-3xl',
  title: titleClass = 'text-3xl md:text-4xl font-bold tracking-tight text-zinc-900 dark:text-zinc-100',
  subtitle: subtitleClass = 'text-lg text-zinc-500 dark:text-zinc-400 leading-relaxed',
  tagline: taglineClass = 'text-xs font-semibold tracking-widest uppercase text-emerald-700 dark:text-emerald-400',
} = classes;
---

{
  (title || subtitle || tagline) && (
    <div class={twMerge('mb-8 md:mx-auto md:mb-12 text-center', containerClass)}>
      {tagline && (
        <p class={twMerge(taglineClass, 'mb-4')} set:html={tagline} />
      )}
      {title && (
        <h2 class={twMerge(titleClass)} set:html={title} />
      )}

      {subtitle && <p class={twMerge('mt-4', subtitleClass)} set:html={subtitle} />}
    </div>
  )
}
