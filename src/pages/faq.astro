---
import { getCollection, render } from 'astro:content';
import Layout from '~/layouts/PageLayout.astro';
import HeroText from '~/components/widgets/HeroText.astro';
import FAQs from '~/components/widgets/FAQs.astro';

const metadata = {
  title: 'FAQ — TradeFlow Mind',
  description: 'Frequently asked questions about TradeFlow Mind — installation, pricing, trading, privacy, and support.',
};

const allFaqs = await getCollection('faq');
const sorted = allFaqs.sort((a, b) => a.data.order - b.data.order);

const categories = [
  { id: 'installation', label: 'Installation' },
  { id: 'trading', label: 'Trading & Usage' },
  { id: 'technical', label: 'Technical' },
  { id: 'billing', label: 'Billing & Refunds' },
  { id: 'general', label: 'General' },
];

const faqsByCategory = categories.map(cat => ({
  ...cat,
  items: sorted.filter(f => f.data.category === cat.id),
})).filter(cat => cat.items.length > 0);
---

<Layout metadata={metadata}>
  <HeroText
    title="Frequently Asked Questions"
    subtitle="Can't find what you're looking for? Contact us at support@tradeflowmind.com"
  />

  <section class="max-w-3xl mx-auto px-6 pb-20">
    {faqsByCategory.map(async (cat) => (
      <div class="mb-12">
        <h2 class="text-sm font-semibold uppercase tracking-widest text-zinc-500 dark:text-zinc-400 mb-6 border-b border-zinc-200 dark:border-zinc-800 pb-2">
          {cat.label}
        </h2>
        <div class="space-y-4">
          {cat.items.map(async (entry) => {
            const { Content } = await render(entry);
            return (
              <details class="group border border-zinc-200 dark:border-zinc-800 rounded-xl overflow-hidden">
                <summary class="flex items-center justify-between px-5 py-4 cursor-pointer font-medium text-zinc-900 dark:text-white hover:bg-zinc-50 dark:hover:bg-zinc-800/50 transition-colors list-none">
                  {entry.data.question}
                  <svg class="w-4 h-4 text-zinc-400 shrink-0 ml-4 transition-transform group-open:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
                  </svg>
                </summary>
                <div class="px-5 pb-5 pt-1 prose dark:prose-invert prose-sm max-w-none prose-a:text-blue-600 dark:prose-a:text-blue-400">
                  <Content />
                </div>
              </details>
            );
          })}
        </div>
      </div>
    ))}

    <!-- Support CTA -->
    <div class="rounded-2xl border border-zinc-200 dark:border-zinc-700 p-6 text-center bg-zinc-50 dark:bg-zinc-900/40 mt-8">
      <h3 class="font-semibold mb-2">Still have questions?</h3>
      <p class="text-sm text-zinc-500 dark:text-zinc-400 mb-4">Our support team typically responds within 1–2 business days.</p>
      <a href="mailto:support@tradeflowmind.com" class="inline-flex items-center gap-2 px-5 py-2.5 rounded-full border border-zinc-300 dark:border-zinc-600 text-sm font-medium hover:border-zinc-500 transition-colors">
        Contact Support →
      </a>
    </div>
  </section>
</Layout>
