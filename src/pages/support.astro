---
import Layout from '~/layouts/PageLayout.astro';

const metadata = {
  title: 'Support — Meridian',
  description: 'Get help with Meridian. Send a message, browse FAQs, or check the changelog.',
};
---

<Layout metadata={metadata}>
  <section class="py-16 px-6">
    <div class="max-w-2xl mx-auto text-center mb-12">
      <h1 class="text-3xl md:text-4xl font-bold text-zinc-900 dark:text-white mb-3">Support</h1>
      <p class="text-zinc-500 dark:text-zinc-400 text-base">
        Questions, bug reports, or installation issues — send us a message and we'll get back to you within 24 hours.
      </p>
    </div>

    <!-- Contact form -->
    <div class="max-w-xl mx-auto">
      <form
        action="https://formspree.io/f/xaqalank"
        method="POST"
        class="space-y-5"
        id="support-form"
      >
        <div>
          <label for="name" class="block text-sm font-medium text-zinc-700 dark:text-zinc-300 mb-1">Name</label>
          <input
            type="text"
            name="name"
            id="name"
            required
            placeholder="Your name"
            class="w-full rounded-lg border border-zinc-300 dark:border-zinc-600 bg-white dark:bg-zinc-800 text-zinc-900 dark:text-white px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-emerald-500 focus:border-transparent"
          />
        </div>

        <div>
          <label for="email" class="block text-sm font-medium text-zinc-700 dark:text-zinc-300 mb-1">Email</label>
          <input
            type="email"
            name="email"
            id="email"
            required
            placeholder="your@email.com"
            class="w-full rounded-lg border border-zinc-300 dark:border-zinc-600 bg-white dark:bg-zinc-800 text-zinc-900 dark:text-white px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-emerald-500 focus:border-transparent"
          />
        </div>

        <div>
          <label for="subject" class="block text-sm font-medium text-zinc-700 dark:text-zinc-300 mb-1">Subject</label>
          <select
            name="subject"
            id="subject"
            required
            class="w-full rounded-lg border border-zinc-300 dark:border-zinc-600 bg-white dark:bg-zinc-800 text-zinc-900 dark:text-white px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-emerald-500 focus:border-transparent"
          >
            <option value="" disabled selected>Select a topic</option>
            <option value="Installation issue">Installation issue</option>
            <option value="Bug report">Bug report</option>
            <option value="Subscription / billing">Subscription / billing</option>
            <option value="Feature question">Feature question</option>
            <option value="Other">Other</option>
          </select>
        </div>

        <div>
          <label for="ninjatrader" class="block text-sm font-medium text-zinc-700 dark:text-zinc-300 mb-1">
            NinjaTrader version <span class="text-zinc-400 font-normal">(optional — helps with bug reports)</span>
          </label>
          <input
            type="text"
            name="ninjatrader_version"
            id="ninjatrader"
            placeholder="e.g. 8.1.3.1"
            class="w-full rounded-lg border border-zinc-300 dark:border-zinc-600 bg-white dark:bg-zinc-800 text-zinc-900 dark:text-white px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-emerald-500 focus:border-transparent"
          />
        </div>

        <div>
          <label for="message" class="block text-sm font-medium text-zinc-700 dark:text-zinc-300 mb-1">Message</label>
          <textarea
            name="message"
            id="message"
            required
            rows="5"
            placeholder="Describe your issue or question in as much detail as possible."
            class="w-full rounded-lg border border-zinc-300 dark:border-zinc-600 bg-white dark:bg-zinc-800 text-zinc-900 dark:text-white px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-emerald-500 focus:border-transparent resize-none"
          ></textarea>
        </div>

        <button
          type="submit"
          class="w-full bg-emerald-600 hover:bg-emerald-700 text-white font-semibold px-6 py-3 rounded-lg transition-colors text-sm"
        >
          Send message
        </button>

        <p class="text-xs text-center text-zinc-400">
          Or email us directly at
          <a href="mailto:contactmeridianpsi@gmail.com" class="underline hover:text-zinc-600">contactmeridianpsi@gmail.com</a>
        </p>
      </form>

      <!-- Success state shown after Formspree redirect if using JS -->
      <div id="form-success" class="hidden text-center py-10">
        <div class="text-emerald-600 text-4xl mb-4">✓</div>
        <h2 class="text-xl font-semibold text-zinc-900 dark:text-white mb-2">Message sent</h2>
        <p class="text-zinc-500 text-sm">We'll get back to you within 24 hours.</p>
      </div>
    </div>

    <!-- Quick links -->
    <div class="max-w-xl mx-auto mt-14 pt-10 border-t border-zinc-100 dark:border-zinc-700">
      <p class="text-xs font-semibold tracking-widest text-zinc-400 uppercase mb-4 text-center">Other resources</p>
      <div class="grid grid-cols-2 gap-3">
        <a href="/faq" class="flex items-center gap-3 rounded-lg border border-zinc-200 dark:border-zinc-700 px-4 py-3 hover:border-emerald-400 transition-colors group">
          <span class="text-emerald-600 text-lg">?</span>
          <div>
            <p class="text-sm font-medium text-zinc-900 dark:text-white group-hover:text-emerald-700 transition-colors">FAQ</p>
            <p class="text-xs text-zinc-400">Common questions</p>
          </div>
        </a>
        <a href="/releases" class="flex items-center gap-3 rounded-lg border border-zinc-200 dark:border-zinc-700 px-4 py-3 hover:border-emerald-400 transition-colors group">
          <span class="text-emerald-600 text-lg">↓</span>
          <div>
            <p class="text-sm font-medium text-zinc-900 dark:text-white group-hover:text-emerald-700 transition-colors">Releases</p>
            <p class="text-xs text-zinc-400">Download latest build</p>
          </div>
        </a>
      </div>
    </div>
  </section>
</Layout>

<script>
  const form = document.getElementById('support-form') as HTMLFormElement | null;
  const successDiv = document.getElementById('form-success');

  if (form && successDiv) {
    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      const data = new FormData(form);
      const response = await fetch(form.action, {
        method: 'POST',
        body: data,
        headers: { Accept: 'application/json' },
      });
      if (response.ok) {
        form.classList.add('hidden');
        successDiv.classList.remove('hidden');
      } else {
        alert('Something went wrong. Please email us directly at contactmeridianpsi@gmail.com.');
      }
    });
  }
</script>
