---
import Layout from '~/layouts/PageLayout.astro';
import HeroText from '~/components/widgets/HeroText.astro';
import Button from '~/components/ui/Button.astro';

import products from '~/data/products.json';

const metadata = {
  title: 'Start Free Trial — Meridian',
  description: 'Start your 7-day free trial of Meridian. Full access. Then $24.99/month. Cancel any time.',
};

const { price, currency, trialDays } = products.pricing;
const checkoutUrl = products.purchase.checkoutUrl;
---

<Layout metadata={metadata}>
  <HeroText
    tagline="Free trial"
    title="Start your 7-day free trial"
    subtitle={`Full access to Meridian. Then ${currency} $${price}/month — cancel any time.`}
  />

  <section class="max-w-xl mx-auto px-6 pb-20 text-center">
    <div class="rounded-2xl border border-zinc-200 bg-white px-6 py-10 shadow-sm">
      <p class="text-zinc-700 text-sm leading-relaxed mb-6">
        You'll be taken to our secure checkout. No charge during the {trialDays}-day trial — cancel any time before it ends.
      </p>
      <Button variant="primary" href={checkoutUrl} class="w-full sm:w-auto px-8 py-3 rounded-full font-semibold">
        Start free trial — {trialDays} days
      </Button>
      <p class="mt-4 text-xs text-zinc-500">
        {trialDays}-day free trial · ${price}/month after · cancel any time
      </p>
      <p class="mt-3 text-xs text-zinc-400">
        Questions? <a href={`mailto:${products.purchase.supportEmail}`} class="underline">{products.purchase.supportEmail}</a>
      </p>
    </div>
  </section>
</Layout>
