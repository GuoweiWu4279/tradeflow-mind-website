<script>
  function initCarousel(id: string) {
    const slides = Array.from(document.querySelectorAll<HTMLElement>(`[data-carousel="${id}"]`));
    const cards  = Array.from(document.querySelectorAll<HTMLElement>(`[data-card-nav="${id}"]`));
    if (!slides.length) return;
    let current = 0;
    let animating = false;

    const activeCard   = ['border-emerald-400', 'bg-white', 'shadow-sm', 'shadow-emerald-100'];
    const inactiveCard = ['border-zinc-200', 'bg-white/60'];

    slides.forEach((s, i) => {
      s.style.transition = 'opacity 0.25s ease';
      s.style.opacity = i === 0 ? '1' : '0';
    });

    function goTo(index: number) {
      if (animating) return;
      const prev = current;
      const next = ((index % slides.length) + slides.length) % slides.length;
      if (prev === next) return;
      animating = true;

      cards[prev]?.classList.remove(...activeCard);
      cards[prev]?.classList.add(...inactiveCard);
      cards[next]?.classList.remove(...inactiveCard);
      cards[next]?.classList.add(...activeCard);

      slides[prev].style.opacity = '0';
      setTimeout(() => {
        slides[prev].classList.add('hidden');
        current = next;
        slides[current].classList.remove('hidden');
        slides[current].style.opacity = '0';
        requestAnimationFrame(() => requestAnimationFrame(() => {
          slides[current].style.opacity = '1';
          animating = false;
        }));
      }, 250);
    }

    document.querySelector(`[data-prev="${id}"]`)?.addEventListener('click', () => goTo(current - 1));
    document.querySelector(`[data-next="${id}"]`)?.addEventListener('click', () => goTo(current + 1));
    cards.forEach((card, i) => card.addEventListener('click', () => goTo(i)));
  }

  document.addEventListener('DOMContentLoaded', () => initCarousel('intel'));
</script>
