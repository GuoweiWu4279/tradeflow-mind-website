---
import Layout from '~/layouts/PageLayout.astro';
import HeroText from '~/components/widgets/HeroText.astro';
import Prices from '~/components/widgets/Pricing.astro';
import FAQs from '~/components/widgets/FAQs.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';

const metadata = {
  title: 'Pricing — TradeFlow Mind',
  description: 'Simple, transparent pricing for TradeFlow Mind. Start with a free 14-day trial. No credit card required.',
};
---

<Layout metadata={metadata}>

  <HeroText
    tagline="Pricing"
    title="Simple, Transparent Pricing"
    subtitle="Start free for 14 days. No credit card required. Cancel anytime."
  />

  <Prices
    title="Choose your plan"
    subtitle="All plans include a 30-day money-back guarantee if the software fails to run on your system."
    prices={[
      {
        title: 'Free Trial',
        subtitle: 'Full access for 14 days. No credit card needed.',
        price: 0,
        period: '14-day trial',
        items: [
          { description: 'Real-time stability index' },
          { description: 'Up to 5 tracked sessions' },
          { description: 'Basic alert thresholds' },
          { description: 'NinjaTrader 8 integration' },
          { description: 'Community support' },
        ],
        callToAction: {
          target: '_self',
          text: 'Start Free Trial',
          href: '/download',
        },
      },
      {
        title: 'Pro',
        subtitle: 'For active traders who take psychology seriously.',
        price: 49,
        period: 'per month',
        items: [
          { description: 'Unlimited session tracking' },
          { description: 'Full historical data & CSV export' },
          { description: 'Custom alert rules & thresholds' },
          { description: 'Session replay analysis' },
          { description: 'Email support' },
          { description: 'All future updates included' },
        ],
        callToAction: {
          target: '_self',
          text: 'Get Pro',
          href: '/download',
        },
        hasRibbon: true,
        ribbonTitle: 'Popular',
      },
      {
        title: 'Lifetime',
        subtitle: 'Pay once, use forever. Includes all v1.x updates.',
        price: 299,
        period: 'one-time',
        items: [
          { description: 'Everything in Pro' },
          { description: 'One-time payment' },
          { description: 'Lifetime updates (v1.x)' },
          { description: 'Priority email support' },
          { description: 'Early access to beta features' },
        ],
        callToAction: {
          target: '_self',
          text: 'Buy Lifetime',
          href: '/download',
        },
      },
    ]}
  />

  <!-- Billing FAQ -->
  <FAQs
    title="Pricing Questions"
    tagline=""
    classes={{ container: 'max-w-6xl' }}
    items={[
      {
        title: 'Can I switch plans?',
        description: 'Yes. You can upgrade or downgrade your plan at any time from your account dashboard.',
      },
      {
        title: 'What payment methods are accepted?',
        description: 'We accept major credit and debit cards (Visa, Mastercard, Amex) via our secure payment processor.',
      },
      {
        title: 'Is there a free trial for Pro?',
        description: 'Yes — the 14-day free trial gives you full access to all Pro features with no credit card required.',
      },
      {
        title: 'What does the 30-day money-back guarantee cover?',
        description: 'If the software fails to install or run correctly on a supported system and our support team cannot resolve the issue, you receive a full refund. See the full Refund Policy for details.',
      },
    ]}
  />

  <div class="max-w-3xl mx-auto px-6 pb-8">
    <p class="text-xs text-center text-zinc-500 dark:text-zinc-400">
      Prices in USD. Annual billing available — saves ~20%. Trading involves substantial risk of loss.
      TradeFlow Mind does not guarantee trading results. <a href="/disclaimer" class="underline">Risk Disclaimer</a>.
    </p>
  </div>

  <CallToAction
    actions={[
      {
        variant: 'primary',
        text: 'Start 14-Day Free Trial',
        href: '/download',
        icon: 'tabler:download',
      },
    ]}
  >
    <Fragment slot="title">No risk. Start free today.</Fragment>
    <Fragment slot="subtitle">
      Full Pro access for 14 days. No credit card required.
    </Fragment>
  </CallToAction>

</Layout>
