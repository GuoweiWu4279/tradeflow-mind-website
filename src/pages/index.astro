---
import Layout from '~/layouts/PageLayout.astro';

import Hero from '~/components/widgets/Hero.astro';
import Stats from '~/components/widgets/Stats.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';

const metadata = {
  title: 'Meridian — The First Real-Time Psychological Stability Index for Active Traders',
  ignoreTitleTemplate: true,
};

const marqueeRow1 = [
  {
    quote: "Three months in. I thought I had clean execution — the overtrading metric disagreed from day one.",
    name: 'Jason K.',
    role: 'Futures day trader',
  },
  {
    quote: "Passed my third Apex evaluation. The first two I blew up on days where, in hindsight, I should have just closed the platform. The pattern was obvious once I could see it.",
    name: 'Mike R.',
    role: 'Prop firm trader',
  },
  {
    quote: "Turned out I wasn't losing because of my entries. I was adding to losing positions and ignoring my own rules. Took data to admit it.",
    name: 'Anonymous',
    role: '',
  },
  {
    quote: "I don't use tools that send my fill data to the cloud. Local-only was non-negotiable for me.",
    name: 'David Chen',
    role: 'Independent trader',
  },
  {
    quote: "It doesn't close your positions for you — that part is still on you. But I stopped pretending I didn't notice the score dropping while I was moving my stop around.",
    name: 'T. Rodriguez',
    role: 'NQ futures',
  },
  {
    quote: "The seven bars make it immediately clear which habit is pulling the score down. I kept telling myself I was trading fine. The data disagreed consistently.",
    name: 'Elena V.',
    role: 'MNQ scalper',
  },
  {
    quote: "Being able to use Market Replay without it touching my live baseline was more useful than I expected.",
    name: 'Chris P.',
    role: 'Futures swing',
  },
  {
    quote: "I run two accounts with copy fills. I was expecting double-counting issues in the score. It handled it cleanly without any configuration.",
    name: 'Jordan L.',
    role: 'Multi-account',
  },
  {
    quote: "After a losing session I used to review charts to explain what happened. Now I check the session report first. It's faster and more honest.",
    name: 'Sam W.',
    role: 'ES / NQ',
  },
  {
    quote: "Didn't want another subscription. Tried the trial anyway. Kept it — the overlay is actually readable mid-session without being in the way.",
    name: 'Rina M.',
    role: 'Day trader',
  },
];

const marqueeRow2 = [
  {
    quote: "The caution signal fired and I decided I could manage through it. Twenty minutes later I had hit my daily limit. I can't blame the tool — I ignored it.",
    name: 'Sara',
    role: 'ES trader',
  },
  {
    quote: "I've restarted funded accounts more times than I want to count. If someone had told me a revenge-entry detector would matter more than another indicator, I wouldn't have believed them.",
    name: 'Alex Nowak',
    role: 'Prop trader',
  },
  {
    quote: "Four years trading NQ. Thought I had a solid read on my own behavior. First week of data showed me I had several habits I wasn't aware of.",
    name: 'James O.',
    role: 'Day trader',
  },
  {
    quote: "Post-session journals have their place. This is different — the feedback arrives while the session is still running, not the next morning.",
    name: 'Anonymous',
    role: '',
  },
  {
    quote: "Took a few sessions to calibrate. Once it did, the alerts started making sense — I could trace each one back to a specific pattern.",
    name: 'Priya S.',
    role: 'Futures trader',
  },
  {
    quote: "The stop-widening flag caught me doing something I always denied — moving my stop out when a trade went against me. Useful confirmation, even if it wasn't comfortable.",
    name: 'Marcus T.',
    role: 'CL / GC',
  },
  {
    quote: "Thought my exits were disciplined. Turns out there's a consistent pattern on certain days. I don't love it, but I can work with the information.",
    name: 'Kim H.',
    role: 'Index futures',
  },
  {
    quote: "A rough Tuesday doesn't disappear from the score just because Wednesday started. That's accurate. That's how it actually feels.",
    name: 'Leo B.',
    role: 'Overnight + day',
  },
  {
    quote: "The alerts are infrequent enough that I don't tune them out. When one fires, I actually pause before doing anything.",
    name: 'Andre C.',
    role: 'Prop + personal',
  },
  {
    quote: "The history view is simple. I like that. Seeing consistent streaks makes discipline feel measurable instead of just a goal.",
    name: 'Nina F.',
    role: 'Futures',
  },
];
---

<Layout metadata={metadata}>
  <Hero
    actions={[
      {
        variant: 'primary',
        text: 'Start free trial — 7 days',
        href: '/pricing',
        icon: 'tabler:player-play',
      },
      { text: 'How it works', href: '#step-detail' },
    ]}
  >
    <Fragment slot="title">
      Every trader has a plan.
      <br />
      <span class="text-accent dark:text-emerald-700">The market's job is to make you forget it.</span>
    </Fragment>

    <Fragment slot="subtitle">
      <strong>Meridian</strong> is the first real-time behavioral and psychological stability monitor for active traders. Tracks 7 behavioral patterns in combination with advanced cognitive science and psychology — and updates your PSI score in &lt;100ms.
    </Fragment>
  </Hero>

  <Stats
    stats={[
      { title: 'Live behavioral signals', amount: '7' },
      { title: 'Updated after and during session', amount: '<100ms' },
      { title: 'Session history', amount: '5 years' },
      { title: 'Free trial, no charge', amount: '7-day' },
    ]}
  />

  <!-- Problem recognition section — institutional vs retail framing -->
  <section class="py-16 px-6 bg-zinc-50/60">
    <div class="max-w-4xl mx-auto text-center">
      <h2 class="text-3xl md:text-4xl font-bold text-zinc-900 mb-4">
        Institutional traders have risk managers.<br />You have yourself.
      </h2>
      <p class="text-lg text-zinc-600 mb-12 max-w-2xl mx-auto">
        They have compliance officers, position limits, and systems that enforce rules outside their control. Retail traders have experience, hard-won rules — and then the moment everything goes wrong, nothing stops them from breaking all of them.
      </p>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-3 max-w-2xl mx-auto mb-12 text-left">
        {[
          'Added size right after a loss',
          'Moved the stop to "give it a little more room"',
          'Took the next trade too fast — still feeling the last one',
          'Held a loser longer than your plan ever allowed',
          'Broke your session rule — just this once',
          'Hit your daily limit and took one more anyway',
        ].map((item) => (
          <div class="flex items-center gap-3 bg-red-50 border border-red-100 rounded-xl px-4 py-3">
            <svg class="w-4 h-4 text-red-400 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M6 18L18 6M6 6l12 12" />
            </svg>
            <span class="text-sm text-zinc-700">{item}</span>
          </div>
        ))}
      </div>
      <p class="text-lg font-semibold text-zinc-900 max-w-xl mx-auto">
        Meridian doesn't tell you what to trade.<br />
        It tells you <em>where you are</em> — so you can decide whether to continue.
      </p>
    </div>
  </section>

  <!-- Product Flow — Roadmap -->
  <section id="how-it-works" class="py-20 lg:py-28 px-6 bg-white border-t border-zinc-100 overflow-hidden">
    <div class="max-w-5xl mx-auto">

      <!-- Heading -->
      <div class="roadmap-heading text-center mb-16">
        <p class="text-xs font-semibold tracking-widest text-emerald-700 uppercase mb-3">How it works</p>
        <h2 class="text-3xl md:text-4xl font-bold text-zinc-900 mb-3">Before. During. After. Every session.</h2>
        <p class="text-zinc-500 max-w-xl mx-auto text-base leading-relaxed">Meridian fits into every stage of how you trade — from a fully customized setup, to real-time monitoring and automatic guardrails, to deep post-session review.</p>
      </div>

      <!-- 4-step flow -->
      <div class="relative">

        <!-- Connector line (desktop only) -->
        <div class="roadmap-connector hidden md:block absolute h-px bg-gradient-to-r from-zinc-100 via-emerald-300 to-zinc-100"
             style="top: 27px; left: calc(12.5% + 4px); right: calc(12.5% + 4px);"></div>

        <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-4 gap-6">

          <!-- Step 1: Configure -->
          <div class="roadmap-step text-center" style="transition-delay: 0ms">
            <div class="w-14 h-14 rounded-full bg-zinc-800 text-white flex items-center justify-center mx-auto mb-4 ring-4 ring-white shadow-md relative z-10">
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-6 h-6">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9.594 3.94c.09-.542.56-.94 1.11-.94h2.593c.55 0 1.02.398 1.11.94l.213 1.281c.063.374.313.686.645.87.074.04.147.083.22.127.325.196.72.257 1.075.124l1.217-.456a1.125 1.125 0 0 1 1.37.49l1.296 2.247a1.125 1.125 0 0 1-.26 1.431l-1.003.827c-.293.241-.438.613-.43.992a7.723 7.723 0 0 1 0 .255c-.008.378.137.75.43.991l1.004.827c.424.35.534.955.26 1.43l-1.298 2.247a1.125 1.125 0 0 1-1.369.491l-1.217-.456c-.355-.133-.75-.072-1.076.124a6.47 6.47 0 0 1-.22.128c-.331.183-.581.495-.644.869l-.213 1.281c-.09.543-.56.94-1.11.94h-2.594c-.55 0-1.019-.398-1.11-.94l-.213-1.281c-.062-.374-.312-.686-.644-.87a6.52 6.52 0 0 1-.22-.127c-.325-.196-.72-.257-1.076-.124l-1.217.456a1.125 1.125 0 0 1-1.369-.49l-1.297-2.247a1.125 1.125 0 0 1 .26-1.431l1.004-.827c.292-.24.437-.613.43-.991a6.932 6.932 0 0 1 0-.255c.007-.38-.138-.751-.43-.992l-1.004-.827a1.125 1.125 0 0 1-.26-1.43l1.297-2.247a1.125 1.125 0 0 1 1.37-.491l1.216.456c.356.133.751.072 1.076-.124.072-.044.146-.086.22-.128.332-.183.582-.495.644-.869l.214-1.28Z" />
                <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z" />
              </svg>
            </div>
            <p class="text-xs font-bold tracking-widest text-zinc-500 mb-1">01</p>
            <h3 class="font-bold text-zinc-900 text-sm mb-1">Configure</h3>
            <p class="text-xs text-zinc-500 mb-4 leading-relaxed">Any strategy. Any style.</p>
            <div class="roadmap-card bg-zinc-50 border border-zinc-200 rounded-xl p-4 text-left">
              <ul class="space-y-2">
                {['Session rules & time windows', 'Size limits and stop conventions', 'Profile settings per account'].map(pt => (
                  <li class="flex items-start gap-2 text-xs text-zinc-600">
                    <span class="mt-1 h-1.5 w-1.5 rounded-full bg-zinc-400 shrink-0"></span>
                    {pt}
                  </li>
                ))}
              </ul>
            </div>
          </div>

          <!-- Step 2: Live Monitor -->
          <div class="roadmap-step text-center" style="transition-delay: 150ms">
            <div class="w-14 h-14 rounded-full bg-emerald-700 text-white flex items-center justify-center mx-auto mb-4 ring-4 ring-white shadow-md relative z-10">
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-6 h-6">
                <path stroke-linecap="round" stroke-linejoin="round" d="M3 13.125C3 12.504 3.504 12 4.125 12h2.25c.621 0 1.125.504 1.125 1.125v6.75C7.5 20.496 6.996 21 6.375 21h-2.25A1.125 1.125 0 0 1 3 19.875v-6.75ZM9.75 8.625c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125v11.25c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 0 1-1.125-1.125V8.625ZM16.5 4.125c0-.621.504-1.125 1.125-1.125h2.25C20.496 3 21 3.504 21 4.125v15.75c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 0 1-1.125-1.125V4.125Z" />
              </svg>
            </div>
            <p class="text-xs font-bold tracking-widest text-zinc-500 mb-1">02</p>
            <h3 class="font-bold text-zinc-900 text-sm mb-1">Live Monitor</h3>
            <p class="text-xs text-zinc-500 mb-4 leading-relaxed">7 signals. &lt;100ms updates.</p>
            <div class="roadmap-card bg-emerald-50 border border-emerald-100 rounded-xl p-4 text-left">
              <ul class="space-y-2">
                {['PSI score updates in real time', 'Seven behavioral signal bars', 'Floating HUD overlay'].map(pt => (
                  <li class="flex items-start gap-2 text-xs text-zinc-600">
                    <span class="mt-1 h-1.5 w-1.5 rounded-full bg-emerald-500 shrink-0"></span>
                    {pt}
                  </li>
                ))}
              </ul>
            </div>
          </div>

          <!-- Step 3: Guard -->
          <div class="roadmap-step text-center" style="transition-delay: 300ms">
            <div class="w-14 h-14 rounded-full bg-emerald-600 text-white flex items-center justify-center mx-auto mb-4 ring-4 ring-white shadow-md relative z-10">
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-6 h-6">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75 11.25 15 15 9.75m-3-7.036A11.959 11.959 0 0 1 3.598 6 11.99 11.99 0 0 0 3 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285Z" />
              </svg>
            </div>
            <p class="text-xs font-bold tracking-widest text-zinc-500 mb-1">03</p>
            <h3 class="font-bold text-zinc-900 text-sm mb-1">Guard</h3>
            <p class="text-xs text-zinc-500 mb-4 leading-relaxed">Rules that enforce themselves.</p>
            <div class="roadmap-card bg-emerald-50 border border-emerald-100 rounded-xl p-4 text-left">
              <ul class="space-y-2">
                {['6 trigger conditions', '5 response levels', 'Toast to broker disconnect'].map(pt => (
                  <li class="flex items-start gap-2 text-xs text-zinc-600">
                    <span class="mt-1 h-1.5 w-1.5 rounded-full bg-emerald-500 shrink-0"></span>
                    {pt}
                  </li>
                ))}
              </ul>
            </div>
          </div>

          <!-- Step 4: Review & Intel -->
          <div class="roadmap-step text-center" style="transition-delay: 450ms">
            <div class="w-14 h-14 rounded-full bg-zinc-700 text-white flex items-center justify-center mx-auto mb-4 ring-4 ring-white shadow-md relative z-10">
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-6 h-6">
                <path stroke-linecap="round" stroke-linejoin="round" d="M7.5 14.25v2.25m3-4.5v4.5m3-6.75v6.75m3-9v9M6 20.25h12A2.25 2.25 0 0 0 20.25 18V6A2.25 2.25 0 0 0 18 3.75H6A2.25 2.25 0 0 0 3.75 6v12A2.25 2.25 0 0 0 6 20.25Z" />
              </svg>
            </div>
            <p class="text-xs font-bold tracking-widest text-zinc-500 mb-1">04</p>
            <h3 class="font-bold text-zinc-900 text-sm mb-1">Review &amp; Intel</h3>
            <p class="text-xs text-zinc-500 mb-4 leading-relaxed">Every session. Every pattern.</p>
            <div class="roadmap-card bg-zinc-50 border border-zinc-200 rounded-xl p-4 text-left">
              <ul class="space-y-2">
                {['PSI, Composure, and trade stats', 'Monthly digest and P&L correlation', "Today's Risk Brief"].map(pt => (
                  <li class="flex items-start gap-2 text-xs text-zinc-600">
                    <span class="mt-1 h-1.5 w-1.5 rounded-full bg-zinc-400 shrink-0"></span>
                    {pt}
                  </li>
                ))}
              </ul>
            </div>
          </div>

        </div>
      </div>
    </div>
  </section>

  <!-- Step detail — tabbed deep-dive for each of the four stages -->
  <section id="step-detail" class="py-20 lg:py-28 px-6 bg-white border-t border-zinc-100 overflow-x-hidden">
    <div class="max-w-5xl mx-auto">

      <!-- Tab navigation -->
      <div class="flex border-b border-zinc-200 mb-12 overflow-x-auto">
        <button data-step-tab="0" class="step-tab-btn is-active">
          <span class="step-tab-num">01</span>
          Configure
        </button>
        <button data-step-tab="1" class="step-tab-btn">
          <span class="step-tab-num">02</span>
          Live Monitor
        </button>
        <button data-step-tab="2" class="step-tab-btn">
          <span class="step-tab-num">03</span>
          Guard
        </button>
        <button data-step-tab="3" class="step-tab-btn">
          <span class="step-tab-num">04</span>
          Review &amp; Intel
        </button>
      </div>

      <!-- Sliding panels (track is 400% wide; each panel is w-1/4 = one full viewport slot) -->
      <div class="overflow-hidden">
        <div id="step-panels-track" class="flex" style="width: 400%; transition: transform 0.45s cubic-bezier(0.4,0,0.2,1);">

          <!-- Panel 0: Configure -->
          <div class="w-1/4 grid md:grid-cols-[3fr_2fr] gap-10 md:gap-16 items-center py-2">
            <div>
              <img
                src="/screenshots/baseline-learning.png"
                alt="Meridian profile configuration and personal baseline settings panel"
                class="rounded-2xl shadow-xl border border-zinc-200 w-full h-auto block"
                loading="lazy"
              />
            </div>
            <div>
              <p class="text-xs font-semibold tracking-widest text-emerald-700 uppercase mb-3">Configure</p>
              <h3 class="text-2xl md:text-3xl font-bold text-zinc-900 leading-snug mb-4">Set your rules once. Meridian applies them every session.</h3>
              <p class="text-zinc-500 text-sm leading-relaxed mb-5">Your profile defines how Meridian reads your behavior — position limits, session windows, stop conventions. Every alert is personalized to your declared rules, not a generic threshold.</p>
              <ul class="space-y-2.5 text-sm text-zinc-700">
                <li class="flex items-start gap-2.5"><span class="mt-1 h-1.5 w-1.5 rounded-full bg-emerald-500 shrink-0"></span>Session rules &amp; time windows</li>
                <li class="flex items-start gap-2.5"><span class="mt-1 h-1.5 w-1.5 rounded-full bg-emerald-500 shrink-0"></span>Position size limits and stop conventions</li>
                <li class="flex items-start gap-2.5"><span class="mt-1 h-1.5 w-1.5 rounded-full bg-emerald-500 shrink-0"></span>Profile settings per account</li>
                <li class="flex items-start gap-2.5"><span class="mt-1 h-1.5 w-1.5 rounded-full bg-emerald-500 shrink-0"></span>Personal baseline adapts with each recorded session</li>
              </ul>
            </div>
          </div>

          <!-- Panel 1: Live Monitor -->
          <div class="w-1/4 grid md:grid-cols-[3fr_2fr] gap-10 md:gap-16 items-center py-2">
            <div>
              <img
                src="/screenshots/psi-critical.png"
                alt="Meridian PSI Monitor showing a Critical score with seven behavioral signal bars live"
                class="rounded-2xl shadow-xl border border-zinc-200 w-full h-auto block"
                loading="lazy"
              />
            </div>
            <div>
              <p class="text-xs font-semibold tracking-widest text-emerald-700 uppercase mb-3">Live Monitor</p>
              <h3 class="text-2xl md:text-3xl font-bold text-zinc-900 leading-snug mb-4">Your stability score, updating in real time.</h3>
              <p class="text-zinc-500 text-sm leading-relaxed mb-5">PSI updates within 100ms of every fill, every stop move, every size decision. Seven behavioral signal bars show exactly what is affecting the score right now.</p>
              <ul class="space-y-2.5 text-sm text-zinc-700">
                <li class="flex items-start gap-2.5"><span class="mt-1 h-1.5 w-1.5 rounded-full bg-emerald-500 shrink-0"></span>PSI score updates after every action in &lt;100ms</li>
                <li class="flex items-start gap-2.5"><span class="mt-1 h-1.5 w-1.5 rounded-full bg-emerald-500 shrink-0"></span>Seven behavioral signal bars — visible while trading</li>
                <li class="flex items-start gap-2.5"><span class="mt-1 h-1.5 w-1.5 rounded-full bg-emerald-500 shrink-0"></span>Floating HUD overlay — stays readable mid-session</li>
                <li class="flex items-start gap-2.5"><span class="mt-1 h-1.5 w-1.5 rounded-full bg-emerald-500 shrink-0"></span>Session stats: trades, win rate, alerts, duration</li>
              </ul>
            </div>
          </div>

          <!-- Panel 2: Guard -->
          <div class="w-1/4 grid md:grid-cols-[3fr_2fr] gap-10 md:gap-16 items-center py-2">
            <div>
              <img
                src="/screenshots/psi-performance.png"
                alt="Meridian PSI vs P&L correlation — the measurable cost of trading out of a stable state"
                class="rounded-2xl shadow-xl border border-zinc-200 w-full h-auto block"
                loading="lazy"
              />
            </div>
            <div>
              <p class="text-xs font-semibold tracking-widest text-emerald-700 uppercase mb-3">Guard</p>
              <h3 class="text-2xl md:text-3xl font-bold text-zinc-900 leading-snug mb-4">Rules that enforce themselves — even when you won't.</h3>
              <p class="text-zinc-500 text-sm leading-relaxed mb-5">Guard is a commitment device. When you are calm, you write the rules. When the moment comes, Guard enforces them automatically — no decision required from you.</p>
              <ul class="space-y-2.5 text-sm text-zinc-700">
                <li class="flex items-start gap-2.5"><span class="mt-1 h-1.5 w-1.5 rounded-full bg-emerald-500 shrink-0"></span>6 configurable trigger conditions</li>
                <li class="flex items-start gap-2.5"><span class="mt-1 h-1.5 w-1.5 rounded-full bg-emerald-500 shrink-0"></span>5 response levels — quiet toast to full broker disconnect</li>
                <li class="flex items-start gap-2.5"><span class="mt-1 h-1.5 w-1.5 rounded-full bg-emerald-500 shrink-0"></span>Set once, active every session automatically</li>
                <li class="flex items-start gap-2.5"><span class="mt-1 h-1.5 w-1.5 rounded-full bg-emerald-500 shrink-0"></span>No manual override required in the heat of the moment</li>
              </ul>
              <div class="mt-6">
                <a href="/guard" class="inline-flex items-center gap-1.5 text-sm font-semibold text-emerald-700 hover:text-emerald-900 transition-colors">
                  Explore Meridian Guard &rarr;
                </a>
              </div>
            </div>
          </div>

          <!-- Panel 3: Review & Intel -->
          <div class="w-1/4 grid md:grid-cols-[3fr_2fr] gap-10 md:gap-16 items-center py-2">
            <div>
              <img
                src="/screenshots/intel-session-calendar.png"
                alt="Meridian session calendar showing PSI score, Composure and P&L per session"
                class="rounded-2xl shadow-xl border border-zinc-200 w-full h-auto block"
                loading="lazy"
              />
            </div>
            <div>
              <p class="text-xs font-semibold tracking-widest text-emerald-700 uppercase mb-3">Review &amp; Intel</p>
              <h3 class="text-2xl md:text-3xl font-bold text-zinc-900 leading-snug mb-4">Not just P&amp;L. Whether you traded right.</h3>
              <p class="text-zinc-500 text-sm leading-relaxed mb-5">Every session is saved with PSI score, Composure, and trade stats. Over months, behavioral patterns become visible — and so does the improvement.</p>
              <ul class="space-y-2.5 text-sm text-zinc-700">
