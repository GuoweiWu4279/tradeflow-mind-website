---
import '@fontsource-variable/inter';
---

<style is:inline>
  :root {
    --aw-font-sans: 'Inter Variable';
    --aw-font-serif: 'Inter Variable';
    --aw-font-heading: 'Inter Variable';

    --aw-color-primary: #DDB918;        /* golden accent */
    --aw-color-secondary: #073460;      /* navy for buttons */
    --aw-color-accent: #DDB918;

    --aw-color-text-heading: #0f172a;   /* near-black */
    --aw-color-text-default: #374151;
    --aw-color-text-muted: #6b7280;
    --aw-color-bg-page: white;

    --aw-color-bg-page-dark: #052244;   /* deepest navy */

    ::selection {
      background-color: #DDB918;
      color: #073460;
    }
  }

  .dark {
    --aw-font-sans: 'Inter Variable';
    --aw-font-serif: 'Inter Variable';
    --aw-font-heading: 'Inter Variable';

    --aw-color-primary: #DDB918;
    --aw-color-secondary: #356197;
    --aw-color-accent: #DDB918;

    --aw-color-text-heading: #EBE9E4;
    --aw-color-text-default: #E1DFDB;
    --aw-color-text-muted: rgba(235,233,228,0.6);
    --aw-color-bg-page: #073460;

    ::selection {
      background-color: #DDB918;
      color: #073460;
    }
  }
</style>
