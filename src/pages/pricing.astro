---
import Layout from '~/layouts/PageLayout.astro';
import HeroText from '~/components/widgets/HeroText.astro';
import FAQs from '~/components/widgets/FAQs.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';
import Button from '~/components/ui/Button.astro';
import { Icon } from 'astro-icon/components';

import pricing from '~/data/pricing.json';
import products from '~/data/products.json';

const { singleTier, annualPreview, footnote, headline, subhead } = pricing;
const supportEmail = products.purchase.supportEmail;

const metadata = {
  title: 'Pricing — Meridian',
  description:
    'Meridian pricing: $24.99/month after a 7-day trial. Annual pricing planned at $239.88/year. Trading involves substantial risk.',
};
---

<Layout metadata={metadata}>
  <HeroText tagline="Pricing" title={headline} subtitle={subhead} />

  <section class="max-w-5xl mx-auto px-6 pb-6">
    <div class="grid gap-6 md:grid-cols-2">
      <div
        class="relative rounded-3xl border border-emerald-200/80 bg-gradient-to-b from-white to-emerald-50/40 shadow-lg shadow-emerald-900/5 px-8 py-10 text-center"
      >
        {singleTier.badge && (
          <span class="inline-block rounded-full bg-emerald-600 px-3 py-1 text-xs font-semibold uppercase tracking-wide text-white mb-4">
            {singleTier.badge}
          </span>
        )}
        <h2 class="text-2xl font-bold text-zinc-900 tracking-tight">{singleTier.name} Monthly</h2>

        <div class="mt-8 flex flex-col items-center gap-1">
          <div class="flex items-baseline justify-center">
            <span class="text-3xl font-semibold text-zinc-900">$</span>
            <span class="text-6xl font-extrabold tracking-tight text-zinc-900">{singleTier.price}</span>
            <span class="ml-1 text-lg font-medium text-zinc-500">{singleTier.billingPeriod}</span>
          </div>
          <p class="text-sm text-zinc-500 mt-2">
            After {singleTier.trialDays}-day free trial · cancel any time
          </p>
        </div>

        <ul class="mt-10 space-y-3 text-left max-w-md mx-auto">
          {
            singleTier.features.map((line: string) => (
              <li class="flex gap-3 text-sm text-zinc-700">
                <span class="mt-0.5 flex h-5 w-5 shrink-0 items-center justify-center rounded-full bg-emerald-500">
                  <Icon name="tabler:check" class="h-3.5 w-3.5 text-white" />
                </span>
                <span>{line}</span>
              </li>
            ))
          }
        </ul>

        <div class="mt-10 flex flex-col items-center gap-3">
          <Button variant="primary" href={singleTier.ctaHref} class="px-8 py-3 text-base font-semibold rounded-full">
            {singleTier.cta}
          </Button>
          <p class="text-xs text-zinc-500">No payment required during trial</p>
          <a href="/download" class="text-sm text-emerald-700 font-medium hover:underline"> Already subscribed? Go to downloads → </a>
        </div>
      </div>

      <div class="relative rounded-3xl border border-zinc-200 bg-zinc-950 shadow-sm px-8 py-10 text-center">
        {annualPreview.badge && (
          <span class="inline-block rounded-full bg-white/10 px-3 py-1 text-xs font-semibold uppercase tracking-wide text-white mb-4">
            {annualPreview.badge}
          </span>
        )}
        <h2 class="text-2xl font-bold text-white tracking-tight">{annualPreview.name}</h2>

        <div class="mt-8 flex flex-col items-center gap-1">
          <div class="flex items-baseline justify-center">
            <span class="text-3xl font-semibold text-white">$</span>
            <span class="text-6xl font-extrabold tracking-tight text-white">{annualPreview.price}</span>
            <span class="ml-1 text-lg font-medium text-zinc-400">{annualPreview.billingPeriod}</span>
          </div>
          <p class="text-sm text-zinc-400 mt-2">
            About ${annualPreview.effectiveMonthly}/month · save ${annualPreview.savings}/year
          </p>
        </div>

        <ul class="mt-10 space-y-3 text-left max-w-md mx-auto">
          {
            annualPreview.features.map((line: string) => (
              <li class="flex gap-3 text-sm text-zinc-300">
                <span class="mt-0.5 flex h-5 w-5 shrink-0 items-center justify-center rounded-full bg-white/10">
                  <Icon name="tabler:check" class="h-3.5 w-3.5 text-white" />
                </span>
                <span>{line}</span>
              </li>
            ))
          }
        </ul>

        <div class="mt-10 flex flex-col items-center gap-3">
          <Button variant="primary" href={annualPreview.ctaHref} class="px-8 py-3 text-base font-semibold rounded-full">
            {annualPreview.cta}
          </Button>
          <p class="text-xs text-zinc-500">No payment required during trial</p>
        </div>
      </div>
    </div>

    <p class="mt-8 text-center text-xs text-zinc-500 leading-relaxed max-w-xl mx-auto">
      {footnote}
      <a href="/disclaimer" class="underline text-emerald-800 hover:text-emerald-900"> Risk disclaimer</a>.
    </p>
  </section>

  <FAQs
    title="Billing and product questions"
    tagline=""
    classes={{ container: 'max-w-6xl' }}
    items={[
      {
        title: 'How does the free trial work?',
        description:
          'Your first seven days include full access to Meridian at no cost. If you choose to continue afterward, the plan is $24.99 per month. You may cancel during the trial at any time; in that case, no subscription charge applies.',
      },
      {
        title: 'Is there an annual plan?',
        description:
          'Yes. Annual pricing is $239.88 per year — about $19.99 per month — and saves around $60 per year versus monthly billing. A 7-day free trial is included on the annual plan as well.',
      },
      {
        title: 'Can I cancel at any time?',
        description:
          'Yes. Meridian is billed month to month with no long-term commitment. Cancel during the trial if you decide it is not a fit, or cancel an active subscription whenever you like. If you cancel a paid subscription, you retain access through the end of the period you have already paid for.',
      },
      {
        title: 'What payment methods are accepted?',
        description:
          'Checkout is processed securely by Lemon Squeezy. Major credit and debit cards (Visa, Mastercard, American Express) and PayPal are supported. We do not store your full card details on our own systems.',
      },
      {
        title: 'What does the refund policy cover?',
        description:
          'Please see our Refund Policy for the full terms. In general, it explains how we handle installation or technical issues on supported setups, and how courtesy refunds work within the stated time frames.',
      },
      {
        title: 'What does PSI measure — and can it predict profits?',
        description:
          'PSI summarizes behavioral-stability signals from your live session using the patterns Meridian is designed to monitor. It is a risk-awareness and discipline tool, not a forecast of trading results, and it is not investment advice. Trading involves substantial risk of loss; many factors beyond psychology determine outcomes.',
      },
    ]}
  />

  <CallToAction
    actions={[
      {
        variant: 'primary',
        text: singleTier.cta,
        href: singleTier.ctaHref,
        icon: 'tabler:player-play',
      },
      { text: 'System requirements', href: '/download' },
    ]}
  >
    <Fragment slot="title">Try Meridian free for seven days</Fragment>
    <Fragment slot="subtitle">
      Full product access during the trial. Monthly at $24.99 or annual at $239.88/year. NinjaTrader 8 is required.
    </Fragment>
  </CallToAction>
</Layout>
