<script>
  function initSlider(id: string) {
    const track = document.querySelector<HTMLElement>(`[data-track="${id}"]`);
    if (!track) return;
    const total = track.children.length;
    const dots = Array.from(document.querySelectorAll<HTMLElement>(`[data-dot="${id}"]`));
    let current = 0;

    function getW() {
      return (track.parentElement as HTMLElement).offsetWidth;
    }

    function goTo(n: number) {
      const prev = current;
      current = ((n % total) + total) % total;
      track.style.transform = `translateX(-${current * getW()}px)`;
      dots[prev]?.classList.remove('w-4', 'bg-white/90');
      dots[prev]?.classList.add('w-1.5', 'bg-white/40');
      dots[current]?.classList.add('w-4', 'bg-white/90');
      dots[current]?.classList.remove('w-1.5', 'bg-white/40');
      // Swap caption labels if present
      document.querySelector<HTMLElement>(`[data-caption="${id}-${prev}"]`)?.classList.add('hidden');
      document.querySelector<HTMLElement>(`[data-caption="${id}-${current}"]`)?.classList.remove('hidden');
    }

    document.querySelector(`[data-prev="${id}"]`)?.addEventListener('click', () => goTo(current - 1));
    document.querySelector(`[data-next="${id}"]`)?.addEventListener('click', () => goTo(current + 1));
    dots.forEach((dot, i) => dot.addEventListener('click', () => goTo(i)));

    let resizeTimer: ReturnType<typeof setTimeout>;
    window.addEventListener('resize', () => {
      clearTimeout(resizeTimer);
      track.style.transitionDuration = '0ms';
      track.style.transform = `translateX(-${current * getW()}px)`;
      resizeTimer = setTimeout(() => { track.style.transitionDuration = ''; }, 150);
    });
  }

  function boot() {
    initSlider('history');
    initSlider('intel-home');
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', boot);
  } else {
    boot();
  }
</script>
