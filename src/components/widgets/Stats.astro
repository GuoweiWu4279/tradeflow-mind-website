---
import type { Stats as Props } from '~/types';
import WidgetWrapper from '~/components/ui/WidgetWrapper.astro';
import Headline from '~/components/ui/Headline.astro';
import { Icon } from 'astro-icon/components';

const {
  title = await Astro.slots.render('title'),
  subtitle = await Astro.slots.render('subtitle'),
  tagline,
  stats = [],

  id,
  isDark = false,
  classes = {},
  bg = await Astro.slots.render('bg'),
} = Astro.props;
---

<WidgetWrapper id={id} isDark={isDark} containerClass={`max-w-6xl mx-auto ${classes?.container ?? ''}`} bg={bg}>
  <Headline title={title} subtitle={subtitle} tagline={tagline} />
  <div class="grid grid-cols-2 md:grid-cols-4 border-y border-zinc-200 dark:border-zinc-800">
    {
      stats &&
        stats.map(({ amount, title, icon }, idx) => (
          <div
            class={`py-3.5 md:py-4 px-4 md:px-6 text-center md:border-r md:last:border-r-0 border-zinc-200 dark:border-zinc-800 ${idx < 2 ? 'border-b md:border-b-0' : ''} intersect-once motion-safe:md:opacity-0 motion-safe:md:intersect:animate-fade intersect-quarter`}
          >
            {icon && (
              <div class="flex items-center justify-center mx-auto mb-3 text-emerald-600 dark:text-emerald-400">
                <Icon name={icon} class="w-6 h-6" />
              </div>
            )}
            {amount && (
              <div class="font-heading text-zinc-900 dark:text-zinc-100 text-3xl md:text-4xl font-bold tracking-tight">
                {amount}
              </div>
            )}
            {title && (
              <div class="mt-1 text-sm text-zinc-500 dark:text-zinc-400">
                {title}
              </div>
            )}
          </div>
        ))
    }
  </div>
</WidgetWrapper>
