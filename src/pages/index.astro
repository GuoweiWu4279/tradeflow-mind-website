---
import Layout from '~/layouts/PageLayout.astro';

import Hero from '~/components/widgets/Hero.astro';
import Note from '~/components/widgets/Note.astro';
import Features from '~/components/widgets/Features.astro';
import Steps from '~/components/widgets/Steps.astro';
import FAQs from '~/components/widgets/FAQs.astro';
import Stats from '~/components/widgets/Stats.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';

const metadata = {
  title: 'PSI Monitor — Trading psychology stability for NinjaTrader 8',
  ignoreTitleTemplate: true,
};
---

<Layout metadata={metadata}>
  <Hero
    actions={[
      {
        variant: 'primary',
        text: 'Buy — $24.99',
        href: '/checkout',
        icon: 'tabler:shopping-cart',
      },
      { text: 'See pricing', href: '/pricing' },
    ]}
  >
    <Fragment slot="title">
      See your stability
      <br />
      <span class="text-accent dark:text-emerald-700">before the next click.</span>
    </Fragment>

    <Fragment slot="subtitle">
      <strong>PSI Monitor</strong> is a NinjaTrader 8 add-on that computes your <strong>Psychological Stability Index (PSI)</strong>
      from seven behavioral dimensions — in real time, entirely on your PC.
      <br /><br />
      <span class="text-sm text-muted italic">
        Monitoring only. No signals, no investment advice, no order blocking.
        <a href="/disclaimer" class="underline">Risk disclaimer</a>.
      </span>
    </Fragment>
  </Hero>

  <Note
    title="Built for traders who want clarity, not noise:"
    description="Futures and forex traders on NinjaTrader 8 who care about discipline, session rhythm, and privacy."
  />

  <Stats
    stats={[
      { title: 'Behavioral dimensions', amount: '7' },
      { title: 'PSI zones', amount: '3' },
      { title: 'Cloud uploads', amount: '0' },
      { title: 'Intro license', amount: '$24.99' },
    ]}
  />

  <Features
    id="features"
    tagline="Inside the product"
    title="What PSI Monitor does"
    subtitle="Every feature exists to make your emotional load visible — without sending your trades to the internet."
    items={[
      {
        title: 'Psychological Stability Index',
        description:
          'A 0–100 PSI with Stable, Caution, and Critical bands so you can spot rising behavioral pressure during the session.',
        icon: 'tabler:gauge',
      },
      {
        title: 'Seven weighted dimensions',
        description:
          'Revenge-style re-entry, stop manipulation, size outliers, hold-time collapse, prolonged loss holds, rule compliance, and overtrading — each explained in-session.',
        icon: 'tabler:binary-tree',
      },
      {
        title: 'HUD + full hub',
        description:
          'A floating overlay while you trade, plus Session, History, Profile, and Settings views for deeper review.',
        icon: 'tabler:layout-dashboard',
      },
      {
        title: 'Adaptive local baselines',
        description:
          'Learns your timing and size habits on-device. Market Replay sessions do not write to your live baseline.',
        icon: 'tabler:chart-dots',
      },
      {
        title: 'Local-only data',
        description:
          'Configuration and history are stored in local files on your machine — built for traders who want control of their data.',
        icon: 'tabler:cloud-off',
      },
      {
        title: 'Live & playback',
        description:
          'Use the same tooling in live markets or Market Replay to rehearse routines without polluting production stats.',
        icon: 'tabler:player-play',
      },
    ]}
  />

  <Steps
    title="How it fits into your day"
    items={[
      {
        title: 'Step 1: <span class="font-normal">Install in NinjaTrader 8</span>',
        description:
          'Deploy the add-on through your NinjaTrader 8 custom assembly workflow, then launch PSI Monitor from the Control Center.',
        icon: 'tabler:download',
      },
      {
        title: 'Step 2: <span class="font-normal">Tune profile & weights</span>',
        description:
          'Set session windows, risk limits, and how much each behavioral dimension influences PSI — match your playbook.',
        icon: 'tabler:adjustments',
      },
      {
        title: 'Step 3: <span class="font-normal">Trade with the HUD</span>',
        description:
          'Watch PSI and dimension bars update after each fill. Use alerts as a prompt to pause — not as a signal.',
        icon: 'tabler:eye',
      },
      {
        title: 'Step 4: <span class="font-normal">Review the session</span>',
        description:
          'Open the hub to study timelines, session stats, and how each dimension contributed — then iterate deliberately.',
        icon: 'tabler:report-analytics',
      },
    ]}
    image={{
      src: 'https://images.unsplash.com/photo-1611974789855-9c2a0a7236a3?ixlib=rb-4.0.3&auto=format&fit=crop&w=1740&q=80',
      alt: 'Trader at workstation',
    }}
  />

  <FAQs
    title="Quick answers"
    subtitle="Full FAQ lives on the FAQ page."
    tagline="FAQ"
    classes={{ container: 'max-w-6xl' }}
    items={[
      {
        title: 'Does PSI Monitor place or block trades?',
        description:
          'No. It observes executions and positions to compute PSI. It does not send orders or prevent you from trading.',
      },
      {
        title: 'Will a higher PSI make me profitable?',
        description:
          'Not necessarily. PSI describes behavioral pressure, not market outcomes. Results vary; trading involves substantial risk of loss.',
      },
      {
        title: 'Is my data private?',
        description:
          'Yes. The add-on stores data locally in XML on your computer and does not upload your trades to our servers.',
      },
      {
        title: 'Which NinjaTrader versions work?',
        description:
          'NinjaTrader 8 (64-bit) is required — we recommend the latest stable build. NT7 is not supported; very old NT8 builds may work but are not guaranteed.',
      },
    ]}
  />

  <CallToAction
    actions={[
      {
        variant: 'primary',
        text: 'Buy — $24.99',
        href: '/checkout',
        icon: 'tabler:shopping-cart',
      },
      {
        text: 'Download area',
        href: '/download',
      },
    ]}
  >
    <Fragment slot="title">Bring calm data to a loud market</Fragment>

    <Fragment slot="subtitle">
      Introductory pricing · one-time license · built for NinjaTrader 8.
      <br />
      <span class="text-sm text-muted italic mt-2 block">
        Trading involves substantial risk of loss. PSI Monitor does not guarantee trading results.
      </span>
    </Fragment>
  </CallToAction>
</Layout>
