---
import Layout from '~/layouts/PageLayout.astro';
import { getCollection } from 'astro:content';
import { getPermalink } from '~/utils/permalinks';
import { findImage } from '~/utils/images';

const metadata = {
  title: 'Trading Insights — Meridian',
  description: 'In-depth articles on trading psychology, risk management, and execution discipline for active futures traders.',
  robots: { index: true, follow: true },
};

const allPosts = await getCollection('post');

const templateIds = [
  'astrowind-template-in-depth',
  'get-started-website-with-astro-tailwind-css',
  'how-to-customize-astrowind-to-your-brand',
  'useful-resources-to-create-websites',
  'markdown-elements-demo-post',
  'landing',
];

const posts = await Promise.all(
  allPosts
    .filter((p) => !p.data.draft && !templateIds.includes(p.id))
    .sort((a, b) => {
      const da = a.data.publishDate ? new Date(a.data.publishDate).valueOf() : 0;
      const db = b.data.publishDate ? new Date(b.data.publishDate).valueOf() : 0;
      return db - da;
    })
    .map(async (post) => ({
      ...post,
      resolvedImage: post.data.image ? await findImage(post.data.image) : null,
    }))
);

const categoryMap: Record<string, string> = {
  'trading-psychology': 'Trading Psychology',
  'risk-management':    'Risk Management',
  'prop-trading':       'Prop Trading',
  'execution':          'Execution',
};

const categories = [...new Set(posts.map((p) => p.data.category).filter(Boolean))];

function readingTime(body: string) {
  return Math.max(1, Math.ceil(body.split(/\s+/).length / 220));
}
function formatDate(d?: Date) {
  if (!d) return '';
  return new Date(d).toLocaleDateString('en-US', { month: 'short', d: 'numeric', year: 'numeric' });
}
---

<Layout metadata={metadata}>
  <section class="max-w-6xl mx-auto px-6 pt-10 pb-20">

    <!-- Page header -->
    <div class="mb-8">
      <h1 class="text-2xl font-bold text-zinc-900 tracking-tight mb-1">Trading Insights</h1>
      <p class="text-sm text-zinc-400">Financial insight, in-depth trading philosophy, and execution research for serious traders.</p>
    </div>

    <!-- Divider + Category tabs -->
    <div class="border-t border-zinc-200 mb-8">
      {categories.length > 0 && (
        <div class="flex flex-wrap gap-6 pt-4" id="cat-tabs">
          <button data-cat="all" class="cat-btn active text-sm font-medium pb-1 border-b-2 border-zinc-900 text-zinc-900 transition-colors">
            All Posts
          </button>
          {categories.map((cat) => (
            <button data-cat={cat} class="cat-btn text-sm font-medium pb-1 border-b-2 border-transparent text-zinc-400 hover:text-zinc-700 transition-colors">
              {categoryMap[cat!] ?? cat}
            </button>
          ))}
        </div>
      )}
    </div>

    <!-- Grid -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5" id="articles-grid">
      {posts.map((post) => {
        const cat = post.data.category ?? '';
        const label = categoryMap[cat] ?? cat;
        const href = getPermalink(post.id, 'post');
        const mins = readingTime(post.body ?? '');
        const date = formatDate(post.data.publishDate);
        const img = post.resolvedImage;

        return (
          <article
            data-cat={cat}
            class="article-card group flex flex-col border border-zinc-300 bg-white hover:shadow-sm transition-shadow duration-200"
          >
            <!-- Cover image — flush to card edges, no radius -->
            <a href={href} class="block overflow-hidden shrink-0" style="aspect-ratio: 16/9;">
              {img ? (
                <img
                  src={typeof img === 'string' ? img : (img as any).src ?? img}
                  alt={post.data.title}
                  class="w-full h-full object-cover group-hover:scale-[1.02] transition-transform duration-500"
                  loading="lazy"
                />
              ) : (
                <div class="w-full h-full bg-gradient-to-br from-zinc-800 via-zinc-700 to-emerald-900 flex items-end p-5">
                  <span class="text-[10px] font-semibold tracking-widest uppercase text-emerald-400 opacity-80">
                    {label || 'Article'}
                  </span>
                </div>
              )}
            </a>

            <!-- Card body with generous padding -->
            <div class="flex flex-col flex-1 px-5 pt-5 pb-6">
              <!-- Author / meta row -->
              <div class="flex items-center justify-between mb-3">
                <div class="flex items-center gap-2.5">
                  <div class="w-7 h-7 rounded-full bg-zinc-200 flex items-center justify-center shrink-0">
                    <svg class="w-3.5 h-3.5 text-zinc-500" fill="currentColor" viewBox="0 0 24 24">
                      <path d="M12 12c2.7 0 4.8-2.1 4.8-4.8S14.7 2.4 12 2.4 7.2 4.5 7.2 7.2 9.3 12 12 12zm0 2.4c-3.2 0-9.6 1.6-9.6 4.8v2.4h19.2v-2.4c0-3.2-6.4-4.8-9.6-4.8z"/>
                    </svg>
                  </div>
                  <span class="text-xs text-zinc-500">{date} &nbsp;·&nbsp; {mins} min read</span>
                </div>
                <div class="w-5 h-5 flex items-center justify-center opacity-30 hover:opacity-60 cursor-pointer">
                  <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
                    <circle cx="12" cy="5" r="1.5"/><circle cx="12" cy="12" r="1.5"/><circle cx="12" cy="19" r="1.5"/>
                  </svg>
                </div>
              </div>

              <!-- Title -->
              <a href={href} class="block mb-2.5">
                <h2 class="text-[15px] font-bold text-zinc-900 leading-snug group-hover:text-emerald-700 transition-colors duration-150">
                  {post.data.title}
                </h2>
              </a>

              <!-- Excerpt -->
              {post.data.excerpt && (
                <p class="text-sm text-zinc-500 leading-relaxed line-clamp-3 flex-1">
                  {post.data.excerpt}
                </p>
              )}
            </div>
          </article>
        );
      })}
    </div>

    <!-- Empty state -->
    {posts.length === 0 && (
      <p class="text-center text-zinc-400 py-24 text-sm">No articles yet. Check back soon.</p>
    )}
  </section>
</Layout>

<style>
  .cat-btn.active {
    color: #18181b;
    border-bottom-color: #18181b;
  }
</style>

<script>
  const tabs = document.querySelectorAll<HTMLButtonElement>('.cat-btn');
  const cards = document.querySelectorAll<HTMLElement>('.article-card');

  tabs.forEach((tab) => {
    tab.addEventListener('click', () => {
      const cat = tab.dataset.cat ?? 'all';

      tabs.forEach((t) => {
        t.classList.remove('active', 'text-zinc-900', 'border-zinc-900');
        t.classList.add('text-zinc-400', 'border-transparent');
      });
      tab.classList.add('active', 'text-zinc-900', 'border-zinc-900');
      tab.classList.remove('text-zinc-400', 'border-transparent');

      cards.forEach((card) => {
        card.style.display = (cat === 'all' || card.dataset.cat === cat) ? '' : 'none';
      });
    });
  });
</script>
