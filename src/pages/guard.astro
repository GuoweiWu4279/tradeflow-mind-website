---
import Layout from '~/layouts/PageLayout.astro';

const metadata = {
  title: 'Meridian Guard — Commitment Device for Active Traders',
  description:
    'Meridian Guard enforces the rules you set for yourself. Six trigger conditions, five action levels, and an Intel Layer that turns your session history into actionable insight.',
};

const guardCheckout =
  'https://meridianpsi.lemonsqueezy.com/checkout/buy/baeaa0f5-ba08-4ca5-a4dd-a092be966879?enabled=1539460';

const triggers = [
  { name: 'PSI Below',            desc: 'Psychological stability drops under a threshold you define.' },
  { name: 'Consecutive Losses',   desc: 'N losses in a row within the same session.' },
  { name: 'Session P&L Below',    desc: 'Daily realized P&L falls past your declared limit.' },
  { name: 'Unrealized P&L Below', desc: 'Open position floating loss exceeds your threshold — before you close.' },
  { name: 'Single Trade Loss',    desc: 'One trade loses more than a defined amount.' },
  { name: 'Session Time Over',    desc: 'You have traded longer than you planned for the day.' },
];

const levels = [
  { level: 'L1', name: 'Alert',           accent: '#059669', desc: 'A quiet notification. Does not interrupt trading.' },
  { level: 'L2', name: 'Acknowledge',     accent: '#0d9488', desc: 'Type your own pre-written phrase to continue.' },
  { level: 'L3', name: 'Countdown',       accent: '#d97706', desc: 'Forced waiting period. Cannot be skipped.' },
  { level: 'L4', name: 'Risk Alert Mode', accent: '#ea580c', desc: 'Persistent banner. Every entry requires active confirmation.' },
  { level: 'L5', name: 'Disconnect',      accent: '#dc2626', desc: 'Disconnects your broker. Positions are never closed by the system.' },
];

const examples = [
  { name: 'Daily Loss Limit',      rule: 'P&L below -$500',               action: 'Disconnect' },
  { name: 'Revenge Trade Check',   rule: '3 consecutive losses',           action: 'Countdown + Acknowledge' },
  { name: 'Tilt Early Warning',    rule: 'PSI below 65',                   action: 'Alert' },
  { name: 'Hard Tilt Stop',        rule: 'PSI below 45 + P&L below -$300', action: 'Disconnect 30 min' },
  { name: 'Position Risk Monitor', rule: 'Unrealized below -$400',         action: 'Risk Alert Mode' },
  { name: 'Session Length Rule',   rule: 'Session over 180 minutes',       action: 'Acknowledge required' },
];

const intelFeatures = [
  { title: 'PSI × Performance',  desc: 'Your P&L mapped against PSI zone. See exactly what Stable sessions average versus Critical.', img: '/screenshots/psi-performance.png',  alt: 'PSI × Performance' },
  { title: 'Monthly Digest',     desc: 'Composure trend, stable days, win rate, avg P&L, best and worst days — every month.',         img: '/screenshots/digest-march.png',       alt: 'Monthly Digest' },
  { title: 'Weekday Patterns',   desc: 'Find your weakest trading day. Track 6-month Composure progress over time.',                  img: '/screenshots/weekday-patterns.png',   alt: 'Weekday Patterns' },
  { title: "Today's Risk Brief", desc: 'Pre-session summary built from your own history — personalized before your first trade.',     img: '/screenshots/intel-risk-brief.png',   alt: "Today's Risk Brief" },
];
---

<Layout metadata={metadata}>

<!-- ─────────────────────────────────────────────────────────────────
     HERO
───────────────────────────────────────────────────────────────── -->
<section
  class="relative overflow-hidden md:-mt-[84px] not-prose"
  style="background-color:#f0ede8; background-image: linear-gradient(to bottom, rgba(240,237,232,0.15), rgba(240,237,232,0.5)), url('/guard-bg.jpg'); background-size:cover; background-position:center;"
>
  <div class="absolute bottom-0 left-0 right-0 h-40 pointer-events-none"
       style="background:linear-gradient(to bottom,transparent,#f0ede8);" aria-hidden="true"></div>

  <div class="md:pt-[84px]"></div>

  <div class="relative z-[1] max-w-6xl mx-auto px-6 py-16 md:py-24">
    <div class="grid lg:grid-cols-2 gap-10 lg:gap-16 items-center">

      <!-- ── Left: copy ── -->
      <div class="rounded-2xl bg-white/85 backdrop-blur-md px-7 py-8 md:px-9 md:py-10 shadow ring-1 ring-zinc-900/[0.06]">
        <!-- Eyebrow -->
        <p class="inline-flex items-center gap-2 text-[11px] font-semibold tracking-[0.16em] uppercase text-emerald-700 bg-emerald-50 border border-emerald-200 rounded-full px-3.5 py-1 mb-6">
          <span class="w-1.5 h-1.5 rounded-full bg-emerald-600" aria-hidden="true"></span>
          Meridian Guard
        </p>

        <!-- Headline — single element, uniform font-size + line-height -->
        <h1 class="text-4xl md:text-5xl font-bold tracking-tight leading-[1.18] text-zinc-900 mb-5">
          The rules you set for yourself.
          <span class="text-emerald-600">Enforced automatically.</span>
        </h1>

        <p class="text-lg text-zinc-700 leading-relaxed mb-8">
          When you are calm, you define the rules. When the moment comes — losing streak, tilt, blown limit — Guard enforces them without requiring a decision from you.
        </p>

        <!-- 3-step flow -->
        <div class="flex items-center gap-2 mb-8 text-xs text-zinc-600">
          <span class="w-7 h-7 rounded-full bg-emerald-100 border border-emerald-200 flex items-center justify-center font-bold text-emerald-800 shrink-0">1</span>
          <span>Set your rules</span>
          <span class="flex-1 border-t border-dashed border-zinc-300 mx-2"></span>
          <span class="w-7 h-7 rounded-full bg-zinc-100 border border-zinc-200 flex items-center justify-center font-bold text-zinc-500 shrink-0">2</span>
          <span>Trade normally</span>
          <span class="flex-1 border-t border-dashed border-zinc-300 mx-2"></span>
          <span class="w-7 h-7 rounded-full bg-zinc-900 flex items-center justify-center font-bold text-white shrink-0">3</span>
          <span>Guard acts for you</span>
        </div>

        <!-- CTAs -->
        <div class="flex flex-col sm:flex-row gap-3">
          <a href={guardCheckout}
             class="btn btn-lg font-semibold"
             style="background:#059669;color:white;border:1px solid #059669;">
            Start 7-day free trial
          </a>
          <a href="#guard-system"
             class="btn btn-lg font-semibold"
             style="border:1.5px solid rgba(0,0,0,0.18);color:#18181b;background:rgba(255,255,255,0.7);">
            See how it works
          </a>
        </div>

        <p class="text-xs text-zinc-500 mt-4">$34.99/mo after trial · Cancel any time · Trading involves substantial risk of loss.</p>
      </div>

      <!-- ── Right: screenshot ── -->
      <div class="relative hidden lg:block">
        <div class="absolute -inset-6 rounded-3xl blur-2xl opacity-20"
             style="background:radial-gradient(ellipse at center,rgba(5,150,105,0.4) 0%,transparent 70%);" aria-hidden="true"></div>
        <img src="/screenshots/psi-performance.png"
             alt="Meridian Guard PSI × Performance — example session data"
             class="relative rounded-2xl shadow-2xl w-full h-auto block"
             style="box-shadow:0 24px 64px rgba(0,0,0,0.18),0 4px 16px rgba(0,0,0,0.08); border:1px solid rgba(0,0,0,0.1);"
             loading="eager" />
      </div>

    </div>
  </div>
</section>


<!-- ─────────────────────────────────────────────────────────────────
     COMMITMENT DEVICE
───────────────────────────────────────────────────────────────── -->
<section class="py-16 px-6" style="background:#f0ede8;">
  <div class="max-w-3xl mx-auto">
    <div class="bg-white rounded-2xl border border-zinc-200 px-8 py-8 md:px-12 md:py-10 shadow-sm">
      <p class="text-[11px] font-semibold tracking-[0.2em] text-emerald-700 uppercase mb-4">Why Guard exists</p>
      <p class="text-xl md:text-2xl text-zinc-800 leading-[1.6]">
        Behavioral economists call this a <strong class="text-zinc-900 font-semibold">commitment device</strong> — a mechanism you set up in advance to constrain your future behavior.<br /><br />
        Institutional traders have compliance systems that do this automatically. Meridian Guard does the same for independent traders.
      </p>
    </div>
  </div>
</section>


<!-- ─────────────────────────────────────────────────────────────────
     GUARD SYSTEM
───────────────────────────────────────────────────────────────── -->
<section id="guard-system" class="py-20 md:py-28 px-6 bg-white border-t border-zinc-200/60">
  <div class="max-w-6xl mx-auto">

    <div class="max-w-2xl mb-16">
      <p class="text-[11px] font-semibold tracking-[0.2em] text-emerald-700 uppercase mb-3">The Guard System</p>
      <h2 class="text-3xl md:text-4xl font-bold text-zinc-900 tracking-tight mb-4">Six ways to detect. Five ways to respond.</h2>
      <p class="text-lg text-zinc-600 leading-relaxed">
        You set the pairing once. Guard watches every session and acts the moment a condition is met — no manual check-in required.
      </p>
    </div>

    <!-- Step 1: Triggers -->
    <div class="mb-20">
      <div class="flex items-baseline gap-4 mb-8">
        <div class="w-8 h-8 rounded-full bg-zinc-900 text-white flex items-center justify-center text-sm font-bold shrink-0">1</div>
        <div>
          <p class="text-[11px] font-semibold tracking-[0.15em] text-zinc-500 uppercase mb-0.5">Step 1</p>
          <h3 class="text-2xl font-bold text-zinc-900">Define when to intervene</h3>
        </div>
        <p class="hidden md:block text-sm text-zinc-500 ml-auto max-w-xs text-right leading-relaxed">
          Each condition fires once on entry, then resets. No repeated nudges.
        </p>
      </div>
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4">
        {triggers.map((t) => (
          <div class="rounded-xl border border-zinc-200 bg-zinc-50 p-5 hover:border-emerald-200 hover:bg-emerald-50/30 transition-colors">
            <div class="flex items-center gap-2 mb-2">
              <svg class="w-4 h-4 text-emerald-600 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/>
              </svg>
              <p class="font-semibold text-zinc-900 text-sm">{t.name}</p>
            </div>
            <p class="text-zinc-600 text-sm leading-relaxed pl-6">{t.desc}</p>
          </div>
        ))}
      </div>
    </div>

    <!-- Step 2: Action levels -->
    <div class="mb-20">
      <div class="flex items-baseline gap-4 mb-8">
        <div class="w-8 h-8 rounded-full bg-zinc-900 text-white flex items-center justify-center text-sm font-bold shrink-0">2</div>
        <div>
          <p class="text-[11px] font-semibold tracking-[0.15em] text-zinc-500 uppercase mb-0.5">Step 2</p>
          <h3 class="text-2xl font-bold text-zinc-900">Choose the response level</h3>
        </div>
        <p class="hidden md:block text-sm text-zinc-500 ml-auto max-w-xs text-right leading-relaxed">
          Severity increases from a quiet nudge to a full broker disconnect.
        </p>
      </div>

      <!-- Severity gradient bar -->
      <div class="flex h-1 rounded-full overflow-hidden mb-6">
        {levels.map((l) => <div class="flex-1" style={`background:${l.accent}`}></div>)}
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-5 gap-3">
        {levels.map((l) => (
          <div class="rounded-xl border bg-white p-4 flex flex-col gap-2 shadow-sm" style={`border-color:${l.accent}44`}>
            <span class="text-[10px] font-bold tracking-widest text-white rounded px-1.5 py-0.5 w-fit" style={`background:${l.accent}`}>{l.level}</span>
            <p class="font-semibold text-zinc-900 text-sm">{l.name}</p>
            <p class="text-zinc-600 text-xs leading-relaxed">{l.desc}</p>
          </div>
        ))}
      </div>
    </div>

    <!-- Example setups -->
    <div>
      <p class="text-[11px] font-semibold tracking-[0.2em] text-zinc-400 uppercase mb-2">Example setups</p>
      <h3 class="text-2xl font-bold text-zinc-900 mb-8">How traders configure Guard</h3>
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4">
        {examples.map((e) => (
          <div class="rounded-xl border border-zinc-200 bg-zinc-50 p-5 hover:border-zinc-300 transition-colors">
            <p class="font-semibold text-zinc-900 text-sm mb-3">{e.name}</p>
            <p class="text-zinc-500 text-xs font-mono mb-1">When: <span class="text-zinc-700">{e.rule}</span></p>
            <p class="text-xs font-mono font-semibold text-emerald-700">Action: {e.action}</p>
          </div>
        ))}
      </div>
      <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-3 mt-5">
        {[
          { name: 'Edge-trigger',    desc: 'Fires once per condition entry — no repeated alerts.' },
          { name: 'Cooldown',        desc: 'Prevents rapid re-triggering between conditions.' },
          { name: 'Emergency Reset', desc: 'One click clears all active Guard state.' },
          { name: 'Master switch',   desc: 'Disable Guard without losing your saved rules.' },
        ].map((u) => (
          <div class="rounded-xl border border-dashed border-zinc-300 bg-white p-4">
            <p class="font-semibold text-zinc-900 text-sm mb-1">{u.name}</p>
            <p class="text-zinc-500 text-xs leading-relaxed">{u.desc}</p>
          </div>
        ))}
      </div>
    </div>

  </div>
</section>


<!-- ─────────────────────────────────────────────────────────────────
     L2 CALLOUT (only dark section)
───────────────────────────────────────────────────────────────── -->
<section class="py-20 px-6" style="background:#18181b;">
  <div class="max-w-2xl mx-auto text-center">
    <p class="text-[11px] font-semibold tracking-[0.2em] text-emerald-400 uppercase mb-6">
      Why L2 — Acknowledge — is the most powerful level
    </p>
    <blockquote class="text-2xl md:text-3xl font-semibold text-white leading-[1.45] mb-8">
      "I will not revenge trade. My plan is my edge."
    </blockquote>
    <p class="text-zinc-400 leading-relaxed">
      You write that phrase yourself — when you are calm, before the session. In the moment, you must type it before continuing. Your own words, exactly when you need them most.
    </p>
  </div>
</section>


<!-- ─────────────────────────────────────────────────────────────────
     INTEL LAYER
───────────────────────────────────────────────────────────────── -->
<section class="py-20 md:py-28 px-6 border-t border-zinc-200/60" style="background:#f7f5f2;">
  <div class="max-w-6xl mx-auto">

    <div class="max-w-2xl mb-14">
      <span class="inline-flex items-center gap-1.5 text-xs font-semibold text-emerald-800 bg-emerald-100 border border-emerald-200 rounded-full px-3 py-1 mb-5">
        Guard exclusive
      </span>
      <h2 class="text-3xl md:text-4xl font-bold text-zinc-900 tracking-tight mb-4">
        Intel Layer — your history, turned into decisions.
      </h2>
      <p class="text-lg text-zinc-600 leading-relaxed">
        Guard stores 5 years of session data locally and surfaces behavioral patterns that are invisible in any single session.
      </p>
    </div>

    <div class="grid md:grid-cols-[2fr_3fr] gap-8 items-start">

      <!-- Tab cards -->
      <div class="flex flex-col gap-3">
        {intelFeatures.map((f, i) => (
          <button
            data-card-nav="intel"
            data-slide-idx={i}
            class:list={[
              'text-left rounded-xl p-4 border transition-colors duration-150',
              i === 0
                ? 'border-emerald-400 bg-white shadow-sm'
                : 'border-zinc-200 bg-white/70 hover:border-zinc-300 hover:bg-white',
            ]}
          >
            <p class="font-semibold text-zinc-900 text-sm mb-1">{f.title}</p>
            <p class="text-zinc-600 text-xs leading-relaxed">{f.desc}</p>
          </button>
        ))}
      </div>

      <!-- Screenshot -->
      <div class="relative group/intel">
        <div class="rounded-2xl overflow-hidden"
             style="box-shadow:0 20px 50px rgba(0,0,0,0.12),0 2px 8px rgba(0,0,0,0.06);border:1px solid rgba(0,0,0,0.09);">
          {intelFeatures.map((f, i) => (
            <div data-carousel="intel" class:list={[i > 0 && 'hidden']}>
              <img src={f.img} alt={f.alt} class="w-full h-auto block" loading="lazy" />
            </div>
          ))}
        </div>
        <button data-prev="intel"
          class="absolute left-3 top-1/2 -translate-y-1/2 z-10 w-9 h-9 rounded-full bg-black/40 hover:bg-black/65 backdrop-blur-sm text-white flex items-center justify-center opacity-0 group-hover/intel:opacity-100 focus-visible:opacity-100 transition-opacity"
          aria-label="Previous">
          <svg viewBox="0 0 20 20" fill="currentColor" class="w-4 h-4"><path fill-rule="evenodd" d="M11.78 5.22a.75.75 0 0 1 0 1.06L8.06 10l3.72 3.72a.75.75 0 1 1-1.06 1.06l-4.25-4.25a.75.75 0 0 1 0-1.06l4.25-4.25a.75.75 0 0 1 1.06 0Z" clip-rule="evenodd"/></svg>
        </button>
        <button data-next="intel"
          class="absolute right-3 top-1/2 -translate-y-1/2 z-10 w-9 h-9 rounded-full bg-black/40 hover:bg-black/65 backdrop-blur-sm text-white flex items-center justify-center opacity-0 group-hover/intel:opacity-100 focus-visible:opacity-100 transition-opacity"
          aria-label="Next">
          <svg viewBox="0 0 20 20" fill="currentColor" class="w-4 h-4"><path fill-rule="evenodd" d="M8.22 5.22a.75.75 0 0 1 1.06 0l4.25 4.25a.75.75 0 0 1 0 1.06l-4.25 4.25a.75.75 0 1 1-1.06-1.06L11.94 10 8.22 6.28a.75.75 0 0 1 0-1.06Z" clip-rule="evenodd"/></svg>
        </button>
      </div>

    </div>
  </div>
</section>


<!-- ─────────────────────────────────────────────────────────────────
     COMPARISON TABLE
───────────────────────────────────────────────────────────────── -->
<section class="py-20 px-6 bg-white border-t border-zinc-200/60">
  <div class="max-w-3xl mx-auto">
    <div class="text-center mb-10">
      <h2 class="text-3xl font-bold text-zinc-900">Meridian vs Meridian Guard</h2>
      <p class="text-zinc-600 mt-2">Guard includes everything in Core, plus the Guard System and Intel Layer.</p>
    </div>
    <div class="rounded-2xl border border-zinc-200 overflow-hidden shadow-sm">
      <div class="grid grid-cols-3 text-sm font-semibold" style="background:#18181b;color:white;">
        <div class="px-5 py-4 text-zinc-500"></div>
        <div class="px-5 py-4 border-l border-zinc-700/50">
          Meridian<br /><span class="font-normal text-zinc-400 text-xs">$24.99/mo</span>
        </div>
        <div class="px-5 py-4 border-l border-zinc-700/50 text-emerald-400">
          Meridian Guard<br /><span class="font-normal text-emerald-600 text-xs">$34.99/mo</span>
        </div>
      </div>
      {[
        ['Real-time PSI score',                  true,  true],
        ['7 behavioral signal bars',             true,  true],
        ['Personal baselines',                   true,  true],
        ['Session history (5 years)',            true,  true],
        ['Local — no cloud, no telemetry',       true,  true],
        ['Adapts to any trading style',          true,  true],
        ['Guard System (6 triggers, 5 actions)', false, true],
        ['Intel Layer — monthly digest',         false, true],
        ['PSI × P&L correlation',                false, true],
        ["Today's Risk Brief",                   false, true],
      ].map(([feature, core, guard], i) => (
        <div class="grid grid-cols-3 border-t border-zinc-100 text-sm" style={i % 2 === 1 ? 'background:#fafafa' : ''}>
          <div class="px-5 py-3.5 text-zinc-700">{feature}</div>
          <div class="px-5 py-3.5 border-l border-zinc-100">
            {core  ? <svg class="w-4 h-4 text-emerald-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/></svg>
                   : <span class="text-zinc-300">—</span>}
          </div>
          <div class="px-5 py-3.5 border-l border-zinc-100">
            {guard ? <svg class="w-4 h-4 text-emerald-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/></svg>
                   : <span class="text-zinc-300">—</span>}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>


<!-- ─────────────────────────────────────────────────────────────────
     FINAL CTA
───────────────────────────────────────────────────────────────── -->
<section class="py-20 px-6 border-t border-zinc-200/60" style="background:#f0ede8;">
  <div class="max-w-xl mx-auto text-center">
    <p class="text-[11px] font-semibold tracking-[0.2em] text-emerald-700 uppercase mb-4">Available now</p>
    <h2 class="text-3xl md:text-4xl font-bold text-zinc-900 tracking-tight mb-4">
      Meridian Guard is ready when you are.
    </h2>
    <p class="text-zinc-600 leading-relaxed mb-8">
      Everything in Meridian Core, plus the Guard System and Intel Layer. 7-day free trial. Cancel any time.
    </p>
    <div class="flex flex-col sm:flex-row gap-3 justify-center">
      <a href={guardCheckout}
         class="btn btn-lg font-semibold"
         style="background:#059669;color:white;border:1px solid #059669;">
        Start free trial — $34.99/mo
      </a>
      <a href="/pricing"
         class="btn btn-lg font-semibold"
         style="border:1.5px solid rgba(0,0,0,0.18);color:#18181b;background:transparent;">
        Compare all plans
      </a>
    </div>
    <p class="text-xs text-zinc-500 max-w-md mx-auto mt-6 leading-relaxed">
      Trading involves substantial risk of loss. Meridian Guard is a behavioral enforcement tool and does not guarantee trading outcomes. Results may vary.
    </p>
  </div>
</section>

</Layout>

<script>
  function initCarousel(id: string) {
    const slides = Array.from(document.querySelectorAll<HTMLElement>(`[data-carousel="${id}"]`));
    const cards  = Array.from(document.querySelectorAll<HTMLElement>(`[data-card-nav="${id}"]`));
    if (!slides.length) return;

    let current = 0;
    let animating = false;

    slides.forEach((s, i) => {
      s.style.transition = 'opacity 0.2s ease';
      s.style.opacity = i === 0 ? '1' : '0';
    });

    const ON  = ['border-emerald-400', 'bg-white', 'shadow-sm'];
    const OFF = ['border-zinc-200', 'bg-white/70'];

    function goTo(n: number) {
      if (animating) return;
      const next = ((n % slides.length) + slides.length) % slides.length;
      if (next === current) return;
      animating = true;

      cards[current]?.classList.remove(...ON);
      cards[current]?.classList.add(...OFF);
      cards[next]?.classList.remove(...OFF);
      cards[next]?.classList.add(...ON);

      slides[current].style.opacity = '0';
      const prev = current;
      current = next;
      setTimeout(() => {
        slides[prev].classList.add('hidden');
        slides[current].classList.remove('hidden');
        slides[current].style.opacity = '0';
        requestAnimationFrame(() => requestAnimationFrame(() => {
          slides[current].style.opacity = '1';
          animating = false;
        }));
      }, 200);
    }

    document.querySelector(`[data-prev="${id}"]`)?.addEventListener('click', () => goTo(current - 1));
    document.querySelector(`[data-next="${id}"]`)?.addEventListener('click', () => goTo(current + 1));
    cards.forEach((c, i) => c.addEventListener('click', () => goTo(i)));
  }

  document.addEventListener('DOMContentLoaded', () => initCarousel('intel'));
</script>
