---
import Layout from '~/layouts/PageLayout.astro';

import Hero from '~/components/widgets/Hero.astro';
import Features from '~/components/widgets/Features.astro';
import Stats from '~/components/widgets/Stats.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';

const metadata = {
  title: 'Meridian — The First Real-Time Psychological Stability Index for Active Traders',
  ignoreTitleTemplate: true,
};

/** Marquee: two identical flex strips side-by-side so translateX(-50%) matches one full cycle (gap-safe). */
const marqueeRow1 = [
  {
    quote:
      "Three months in. Week one was humbling — I thought I traded 'clean' until the overtrading metric disagreed with me in public (on my own screen).",
    name: 'Jason K.',
    role: 'Futures day trader',
  },
  {
    quote: "Third Apex attempt passed. First two? Classic 'one more trade' days. Not claiming causation — but the pattern was impossible to unsee afterward.",
    name: 'Mike R.',
    role: 'Prop firm trader',
  },
  { quote: 'Not my entries. Size into losers. Ouch.', name: 'Anonymous', role: '' },
  {
    quote:
      "I won't run journaling tools that want my fills in the cloud. Local-only was the only reason I installed anything new on my trading box.",
    name: 'David Chen',
    role: 'Independent trader',
  },
  {
    quote:
      "It won't press Flat for you (obviously). What changed for me is I stopped pretending I didn't notice the score drifting while I was negotiating with my stop.",
    name: 'T. Rodriguez',
    role: 'NQ futures',
  },
  { quote: "Seven bars → seven habits I can't gaslight myself about anymore.", name: 'Elena V.', role: 'MNQ scalper' },
  {
    quote:
      "Market Replay + Test Mode sounds like a footnote. In practice it's where I rehearse without contaminating my baseline — boring sentence, huge relief.",
    name: 'Chris P.',
    role: 'Futures swing',
  },
  {
    quote:
      "Two accounts, occasional copy fills. I was braced for double-counting weirdness. So far it's been… shockingly sane?",
    name: 'Jordan L.',
    role: 'Multi-account',
  },
  {
    quote:
      "After a red session I used to stare at candles. Now I stare at the report first. Uncomfortable, shorter, more honest.",
    name: 'Sam W.',
    role: 'ES / NQ',
  },
  { quote: "Didn't want another subscription. Tried the trial anyway. Still paying — HUD stays readable when I'm actually in market.", name: 'Rina M.', role: 'Day trader' },
];

const marqueeRow2 = [
  {
    quote:
      "Caution flashed. I talked myself into 'just managing it.' Twenty minutes later: daily limit gone. Not blaming the software — finally not confused about the cause chain.",
    name: 'Sara',
    role: 'ES trader',
  },
  {
    quote:
      "Fourth funded-account restart club, hello. If you told me a 'revenge entry' flag would matter more than another indicator pack, I'd have laughed. I was wrong.",
    name: 'Alex Nowak',
    role: 'Prop trader',
  },
  { quote: "NQ for years. 'Self-awareness'? Week one politely disagreed.", name: 'James O.', role: 'Day trader' },
  {
    quote:
      "I've tried the post-session journaling apps. Fine for therapy vibes. This is different — feedback lands while the mistake is still expensive.",
    name: 'Anonymous',
    role: '',
  },
  {
    quote:
      "Baseline felt fussy until it didn't. Once it clicked, alerts stopped feeling random; more like 'ohhh that's the habit it's reacting to.'",
    name: 'Priya S.',
    role: 'Futures trader',
  },
  { quote: 'Stop widening. Caught. Embarrassing. Useful.', name: 'Marcus T.', role: 'CL / GC' },
  {
    quote:
      "Thought I was patient. The rushed-exit signal says: 'not on Wednesdays.' (I hate that it might be right.)",
    name: 'Kim H.',
    role: 'Index futures',
  },
  {
    quote: "Weirdly comforting: a bad Tuesday doesn't vanish from the score just because the calendar flipped.",
    name: 'Leo B.',
    role: 'Overnight + day',
  },
  { quote: "Rare voice pings → I don't mute them out of habit. When it fires, I actually stop and breathe once.", name: 'Andre C.', role: 'Prop + personal' },
  {
    quote:
      "The history view isn't flashy. I like that. Streaks turn 'discipline' into something I can point at instead of vibes.",
    name: 'Nina F.',
    role: 'Futures',
  },
];
---

<Layout metadata={metadata}>
  <Hero
    actions={[
      {
        variant: 'primary',
        text: 'Start free trial — 7 days',
        href: 'https://meridianpsi.lemonsqueezy.com/checkout/buy/b7b8b514-fefa-4a34-8cad-d2e68f564d25',
        icon: 'tabler:player-play',
      },
      { text: 'See pricing', href: '/pricing' },
    ]}
  >
    <Fragment slot="title">
      Every trader has a plan.
      <br />
      <span class="text-accent dark:text-emerald-700">The market's job is to make you forget it.</span>
    </Fragment>

    <Fragment slot="subtitle">
      <strong>Meridian</strong> is the first real-time psychological stability index for NinjaTrader 8.
      It tracks seven behavioral dimensions during your live session and distills them into a live PSI score —
      so you know where you stand before the next trade.
      <br /><br />
      <span class="text-zinc-500 font-normal">Most psychology tools analyze what happened. Meridian tells you what's happening — <em>right now</em>.</span>
    </Fragment>
  </Hero>

  <Stats
    stats={[
      { title: 'Behavioral patterns tracked', amount: '7' },
      { title: 'Days of history stored', amount: '365' },
      { title: 'Free trial', amount: '7 days' },
      { title: 'Per month after trial', amount: '$24.99' },
    ]}
  />

  <!-- Problem recognition section -->
  <section class="py-16 px-6 bg-zinc-50/60">
    <div class="max-w-4xl mx-auto text-center">
      <h2 class="text-3xl md:text-4xl font-bold text-zinc-900 mb-4">
        You know what you should have done.
      </h2>
      <p class="text-lg text-zinc-600 mb-12 max-w-2xl mx-auto">
        Every trader walks away from a bad session knowing exactly where it went wrong.
        The problem isn't knowledge — it's that in the middle of a live session, you can't see yourself clearly.
      </p>
      <ul class="text-left max-w-lg mx-auto space-y-4 mb-12">
        {[
          'Added size right after a loss',
          'Moved the stop to "give it a little more room"',
          'Took the next trade too fast — still feeling the last one',
          'Held a loser longer than your plan ever allowed',
          'Broke your session rule — just this once',
          'Hit your daily limit and took one more anyway',
        ].map((item) => (
          <li class="flex items-start gap-3 text-base text-zinc-700">
            <span class="mt-2 h-2 w-2 rounded-full bg-red-400 shrink-0"></span>
            {item}
          </li>
        ))}
      </ul>
      <p class="text-lg font-semibold text-zinc-900 max-w-xl mx-auto">
        Meridian doesn't tell you what to trade.<br />
        It tells you <em>where you are</em> — so you can decide whether to continue.
      </p>
    </div>
  </section>

  <Features
    id="features"
    tagline="What's inside"
    title="A live instrument, not a journal."
    subtitle="Seven independent trackers, one live score — running natively inside NinjaTrader 8 while you trade."
    items={[
      {
        title: 'A live PSI — from 0 to 100, in real time',
        description:
          'A single score updated after every execution: Stable (≥88), Caution (72–87), or Critical (<72). Spot rising behavioral pressure before it compounds.',
        icon: 'tabler:gauge',
      },
      {
        title: 'The seven patterns that quietly cost traders the most',
        description:
          'Revenge entries, stop manipulation, size outliers, hold-time collapse, prolonged loss holds, session rule violations, and overtrading — each tracked independently.',
        icon: 'tabler:binary-tree',
      },
      {
        title: 'A live overlay that stays out of your way',
        description:
          'A floating HUD shows PSI and all seven dimension bars while you trade. Open the full hub for session timelines, history, and a detailed behavioral breakdown.',
        icon: 'tabler:layout-dashboard',
      },
      {
        title: 'It learns what normal looks like for you',
        description:
          'Adaptive baselines calibrate to your own trading history using statistical modeling — not someone else\'s standard. Market Replay sessions train your awareness without affecting your live baseline.',
        icon: 'tabler:chart-dots',
      },
      {
        title: 'Your data stays on your machine — always',
        description:
          'No accounts, no cloud sync, no network calls. Configuration and session history are stored in local files only you can access.',
        icon: 'tabler:cloud-off',
      },
      {
        title: 'Test it in Market Replay first',
        description:
          'Use Meridian in NinjaTrader\'s Market Replay to understand your behavioral patterns before going live. Your real baseline is never affected.',
        icon: 'tabler:player-play',
      },
    ]}
  />

  <!-- Testimonials — dual-row infinite marquee -->
  <section class="py-12 bg-zinc-50 border-t border-zinc-100">
    <div class="max-w-5xl mx-auto px-6 mb-8 text-center">
      <p class="text-xs font-semibold tracking-widest text-emerald-700 uppercase mb-2">What traders say</p>
      <h2 class="text-2xl md:text-3xl font-bold text-zinc-900">From traders who've been there</h2>
    </div>

    <div
      class="overflow-hidden"
      style="mask-image: linear-gradient(to right, transparent, black 12%, black 88%, transparent); -webkit-mask-image: linear-gradient(to right, transparent, black 12%, black 88%, transparent);"
    >
      <!-- Row 1: scroll left — two strips, no gap between strips, so -50% == one full cycle -->
      <div class="marquee-left flex w-max mb-3 will-change-transform">
        <div class="flex gap-3 shrink-0">
          {marqueeRow1.map((t) => (
            <div class="w-60 shrink-0 bg-white rounded-xl border border-zinc-200 px-4 py-3.5 shadow-sm">
              <div class="flex items-center justify-between gap-2 mb-2">
                <div class="flex items-center gap-2">
                  <div class="w-6 h-6 rounded-full bg-emerald-100 text-emerald-700 text-xs font-bold flex items-center justify-center shrink-0 select-none">
                    {t.name === 'Anonymous' ? '?' : t.name.charAt(0)}
                  </div>
                  <div>
                    <p class="font-semibold text-zinc-900 text-xs leading-tight">{t.name}</p>
                    {t.role && <p class="text-xs text-zinc-400">{t.role}</p>}
                  </div>
                </div>
                <div class="flex gap-0.5 shrink-0">
                  {Array(5).fill(null).map(() => (
                    <svg class="w-2.5 h-2.5 text-amber-400" fill="currentColor" viewBox="0 0 20 20">
                      <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                    </svg>
                  ))}
                </div>
              </div>
              <p class="text-zinc-600 text-xs leading-relaxed">"{t.quote}"</p>
            </div>
          ))}
        </div>
        <div class="flex gap-3 shrink-0" aria-hidden="true">
          {marqueeRow1.map((t) => (
            <div class="w-60 shrink-0 bg-white rounded-xl border border-zinc-200 px-4 py-3.5 shadow-sm">
              <div class="flex items-center justify-between gap-2 mb-2">
                <div class="flex items-center gap-2">
                  <div class="w-6 h-6 rounded-full bg-emerald-100 text-emerald-700 text-xs font-bold flex items-center justify-center shrink-0 select-none">
                    {t.name === 'Anonymous' ? '?' : t.name.charAt(0)}
                  </div>
                  <div>
                    <p class="font-semibold text-zinc-900 text-xs leading-tight">{t.name}</p>
                    {t.role && <p class="text-xs text-zinc-400">{t.role}</p>}
                  </div>
                </div>
                <div class="flex gap-0.5 shrink-0">
                  {Array(5).fill(null).map(() => (
                    <svg class="w-2.5 h-2.5 text-amber-400" fill="currentColor" viewBox="0 0 20 20">
                      <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                    </svg>
                  ))}
                </div>
              </div>
              <p class="text-zinc-600 text-xs leading-relaxed">"{t.quote}"</p>
            </div>
          ))}
        </div>
      </div>

      <!-- Row 2: scroll right -->
      <div class="marquee-right flex w-max will-change-transform">
        <div class="flex gap-3 shrink-0">
          {marqueeRow2.map((t) => (
            <div class="w-60 shrink-0 bg-white rounded-xl border border-zinc-200 px-4 py-3.5 shadow-sm">
              <div class="flex items-center justify-between gap-2 mb-2">
                <div class="flex items-center gap-2">
                  <div class="w-6 h-6 rounded-full bg-emerald-100 text-emerald-700 text-xs font-bold flex items-center justify-center shrink-0 select-none">
                    {t.name === 'Anonymous' ? '?' : t.name.charAt(0)}
                  </div>
                  <div>
                    <p class="font-semibold text-zinc-900 text-xs leading-tight">{t.name}</p>
                    {t.role && <p class="text-xs text-zinc-400">{t.role}</p>}
                  </div>
                </div>
                <div class="flex gap-0.5 shrink-0">
                  {Array(5).fill(null).map(() => (
                    <svg class="w-2.5 h-2.5 text-amber-400" fill="currentColor" viewBox="0 0 20 20">
                      <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                    </svg>
                  ))}
                </div>
              </div>
              <p class="text-zinc-600 text-xs leading-relaxed">"{t.quote}"</p>
            </div>
          ))}
        </div>
        <div class="flex gap-3 shrink-0" aria-hidden="true">
          {marqueeRow2.map((t) => (
            <div class="w-60 shrink-0 bg-white rounded-xl border border-zinc-200 px-4 py-3.5 shadow-sm">
              <div class="flex items-center justify-between gap-2 mb-2">
                <div class="flex items-center gap-2">
                  <div class="w-6 h-6 rounded-full bg-emerald-100 text-emerald-700 text-xs font-bold flex items-center justify-center shrink-0 select-none">
                    {t.name === 'Anonymous' ? '?' : t.name.charAt(0)}
                  </div>
                  <div>
                    <p class="font-semibold text-zinc-900 text-xs leading-tight">{t.name}</p>
                    {t.role && <p class="text-xs text-zinc-400">{t.role}</p>}
                  </div>
                </div>
                <div class="flex gap-0.5 shrink-0">
                  {Array(5).fill(null).map(() => (
                    <svg class="w-2.5 h-2.5 text-amber-400" fill="currentColor" viewBox="0 0 20 20">
                      <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                    </svg>
                  ))}
                </div>
              </div>
              <p class="text-zinc-600 text-xs leading-relaxed">"{t.quote}"</p>
            </div>
          ))}
        </div>
      </div>
    </div>

    <p class="text-center text-xs text-zinc-400 mt-6 italic">Results may vary. Trading involves substantial risk of loss.</p>
  </section>

  <!-- Founder note -->
  <section class="py-14 px-6 bg-white border-t border-zinc-100">
    <div class="max-w-2xl mx-auto flex gap-6 items-start">
      <div class="shrink-0 w-10 h-10 rounded-full bg-emerald-100 text-emerald-700 text-sm font-bold flex items-center justify-center select-none">G</div>
      <div>
        <p class="text-zinc-700 leading-relaxed text-base italic">
          "I built Meridian because I kept losing sessions I had no business losing. The strategy was fine. The market wasn't the problem. I was. I needed something that told me that <em>while it was happening</em> — not the next morning in a journal."
        </p>
        <p class="mt-3 text-sm text-zinc-400 font-medium">— Gary Caffrey, Founder of Meridian &nbsp;·&nbsp; <a href="/about" class="underline hover:text-zinc-600">Read the full story →</a></p>
      </div>
    </div>
  </section>

  <CallToAction
    actions={[
      {
        variant: 'primary',
        text: 'Start free trial — 7 days',
        href: 'https://meridianpsi.lemonsqueezy.com/checkout/buy/b7b8b514-fefa-4a34-8cad-d2e68f564d25',
        icon: 'tabler:player-play',
      },
      {
        text: 'See pricing',
        href: '/pricing',
      },
    ]}
  >
    <Fragment slot="title">Every session starts with the best intentions.</Fragment>

    <Fragment slot="subtitle">
      Meridian helps you keep them.
      <br />
      <span class="text-sm text-muted italic mt-2 block">
        $24.99/month after 7-day trial · cancel any time · NinjaTrader 8 required.
        Trading involves substantial risk of loss. Meridian does not guarantee trading results.
      </span>
    </Fragment>
  </CallToAction>
</Layout>

<style>
  .marquee-left {
    animation: marquee-left 95s linear infinite;
  }
  .marquee-right {
    animation: marquee-right 95s linear infinite;
  }
  @keyframes marquee-left {
    from { transform: translateX(0); }
    to   { transform: translateX(-50%); }
  }
  @keyframes marquee-right {
    from { transform: translateX(-50%); }
    to   { transform: translateX(0); }
  }
  .marquee-left:hover,
  .marquee-right:hover {
    animation-play-state: paused;
  }
</style>
