---
interface Props {
  /** 'header' = nav bar; 'compact' = footer / tight spaces */
  variant?: 'header' | 'compact';
}

const { variant = 'header' } = Astro.props;

const brandWord = 'PSI Monitor';

const wordClasses =
  variant === 'compact'
    ? 'text-[0.65rem] font-semibold uppercase tracking-[0.14em] text-zinc-900 dark:text-zinc-100'
    : 'text-[0.8125rem] md:text-[0.9375rem] font-semibold uppercase tracking-[0.12em] text-zinc-900 dark:text-zinc-100';

const mClasses =
  variant === 'compact'
    ? 'font-serif text-xl font-semibold leading-none text-emerald-800 dark:text-emerald-600'
    : 'font-serif text-2xl md:text-3xl font-semibold leading-none text-emerald-800 dark:text-emerald-600';

const barClasses = variant === 'compact' ? 'h-7 w-px shrink-0 bg-zinc-300 dark:bg-zinc-600' : 'h-9 md:h-10 w-px shrink-0 bg-zinc-300 dark:bg-zinc-600';
---

<span class="inline-flex items-center gap-2 md:gap-2.5">
  <span class="sr-only">{brandWord} — home</span>
  <span aria-hidden="true" class="inline-flex items-center gap-2 md:gap-2.5">
    <span class:list={[mClasses]}>M</span>
    <span class:list={[barClasses]}></span>
    <span class:list={[wordClasses]}>{brandWord}</span>
  </span>
</span>
