---
import Layout from '~/layouts/PageLayout.astro';
import HeroText from '~/components/widgets/HeroText.astro';
import FAQs from '~/components/widgets/FAQs.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';

import pricing from '~/data/pricing.json';

const metadata = {
  title: 'Pricing — Meridian',
  description:
    'Meridian pricing: from $49.99/month after a 7-day free trial. Trading involves substantial risk.',
};

const { tiers, footnote, headline, subhead } = pricing;
const [standard, guard] = tiers;
---

<Layout metadata={metadata}>
  <HeroText tagline="Pricing" title={headline} subtitle={subhead} />

  <!-- Billing toggle -->
  <div class="flex items-center justify-center mb-10 px-6">
    <div class="relative flex items-center bg-zinc-100 rounded-full p-1 gap-1">
      <button
        id="btn-monthly"
        class="relative z-10 px-5 py-2 text-sm font-semibold rounded-full transition-all duration-200 bg-white text-zinc-900 shadow-sm"
      >
        Monthly
      </button>
      <button
        id="btn-annual"
        class="relative z-10 px-5 py-2 text-sm font-semibold rounded-full transition-all duration-200 text-zinc-500"
      >
        Annual
        <span class="ml-2 inline-block rounded-full bg-emerald-100 text-emerald-700 text-xs font-semibold px-2 py-0.5">
          Save ~$120/yr
        </span>
      </button>
    </div>
  </div>

  <!-- Two pricing cards -->
  <section class="max-w-4xl mx-auto px-6 pb-6">
    <div class="grid md:grid-cols-2 gap-6 items-start">

      <!-- Meridian (standard) -->
      <div class="rounded-3xl border border-zinc-200 bg-white shadow-sm px-8 py-10">
        <div class="mb-6">
          <h2 class="text-xl font-bold text-zinc-900 mb-1">{standard.name}</h2>
          <p class="text-sm text-zinc-500">{standard.description}</p>
        </div>

        <div class="mb-6 min-h-[80px]">
          <div id="std-monthly-price" class="flex items-baseline gap-1">
            <span class="text-4xl font-bold text-zinc-900">${standard.monthlyPrice}</span>
            <span class="text-zinc-500 text-sm">/month</span>
          </div>
          <div id="std-annual-price" class="hidden flex items-baseline gap-1">
            <span class="text-4xl font-bold text-zinc-900">${standard.annualMonthly}</span>
            <span class="text-zinc-500 text-sm">/month</span>
          </div>
          <p id="std-monthly-note" class="text-xs text-zinc-400 mt-1">Billed monthly · 7-day free trial</p>
          <p id="std-annual-note" class="text-xs text-zinc-400 mt-1 hidden">
            Billed ${standard.annualPrice}/year · saves ~${standard.annualSavings}/yr · 7-day free trial
          </p>
        </div>

        <a
          id="std-cta"
          href={standard.monthlyCtaHref}
          class="block w-full text-center px-6 py-3 rounded-full bg-zinc-900 hover:bg-zinc-700 text-white font-semibold text-sm transition-colors mb-8"
        >
          Start free trial
        </a>

        <ul class="space-y-3">
          {standard.features.map((f) => (
            <li class="flex items-start gap-2.5 text-sm text-zinc-600">
              <svg class="w-4 h-4 text-emerald-500 shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7" />
              </svg>
              {f}
            </li>
          ))}
        </ul>
      </div>

      <!-- Meridian Guard -->
      <div class="rounded-3xl border-2 border-emerald-600/30 bg-gradient-to-b from-white to-emerald-50/30 shadow-lg shadow-emerald-900/5 px-8 py-10 relative overflow-hidden">
        <div class="absolute top-4 right-4">
          <span class="inline-flex items-center px-2.5 py-1 rounded-full bg-emerald-600 text-white text-[11px] font-semibold tracking-wide uppercase">Recommended</span>
        </div>
        <div class="mb-6">
          <h2 class="text-xl font-bold text-zinc-900 mb-1">{guard.name}</h2>
          <p class="text-sm text-zinc-500">{guard.description}</p>
        </div>

        <div class="mb-6 min-h-[80px]">
          <div id="guard-monthly-price" class="flex items-baseline gap-1">
            <span class="text-4xl font-bold text-zinc-900">${guard.monthlyPrice}</span>
            <span class="text-zinc-500 text-sm">/month</span>
          </div>
          <div id="guard-annual-price" class="hidden flex items-baseline gap-1">
            <span class="text-4xl font-bold text-zinc-900">${guard.annualMonthly}</span>
            <span class="text-zinc-500 text-sm">/month</span>
          </div>
          <p id="guard-monthly-note" class="text-xs text-zinc-400 mt-1">Billed monthly · 7-day free trial</p>
          <p id="guard-annual-note" class="text-xs text-zinc-400 mt-1 hidden">
            Billed ${guard.annualPrice}/year · saves ~${guard.annualSavings}/yr · 7-day free trial
          </p>
        </div>

        <a
          id="guard-cta"
          href={guard.monthlyCtaHref}
          class="block w-full text-center px-6 py-3 rounded-full bg-emerald-600 hover:bg-emerald-500 text-white font-semibold text-sm transition-colors mb-8"
        >
          Start free trial
        </a>

        <ul class="space-y-3">
          <li class="flex items-start gap-2.5 text-sm text-zinc-600">
            <svg class="w-4 h-4 text-emerald-500 shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7" />
            </svg>
            Everything in Meridian
          </li>
          <li class="flex items-start gap-2.5 text-sm text-zinc-600">
            <svg class="w-4 h-4 text-emerald-500 shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7" />
            </svg>
            Guard System — rules that enforce themselves (6 triggers · 5 action levels)
          </li>
          <li class="flex items-start gap-2.5 text-sm text-zinc-600">
            <svg class="w-4 h-4 text-emerald-500 shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7" />
            </svg>
            Intel Layer — monthly digest, weekday patterns & Composure progress
          </li>
          <li class="flex items-start gap-2.5 text-sm text-zinc-600">
            <svg class="w-4 h-4 text-emerald-500 shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7" />
            </svg>
            PSI × P&L correlation — see what your Stable sessions average vs Critical
          </li>
          <li class="flex items-start gap-2.5 text-sm text-zinc-600">
            <svg class="w-4 h-4 text-emerald-500 shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7" />
            </svg>
            Today's Risk Brief — personalized pre-session summary
          </li>
          <li class="flex items-start gap-2.5 text-sm text-zinc-600 mt-2">
            <svg class="w-4 h-4 text-zinc-400 shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
            <a href="/guard#comparison" class="text-zinc-400 hover:text-zinc-600 underline underline-offset-2 text-xs">See full Guard & Intel feature breakdown →</a>
          </li>
        </ul>
      </div>

    </div>

    <!-- Trust strip -->
    <div class="mt-8 flex flex-wrap items-center justify-center gap-x-8 gap-y-2 text-xs text-zinc-400">
      <span class="flex items-center gap-1.5">
        <svg class="w-3.5 h-3.5 text-emerald-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/></svg>
        24-hour support response
      </span>
      <span class="flex items-center gap-1.5">
        <svg class="w-3.5 h-3.5 text-emerald-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/></svg>
        Cancel anytime
      </span>
      <span class="flex items-center gap-1.5">
        <svg class="w-3.5 h-3.5 text-emerald-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/></svg>
        All data stays on your PC — no cloud
      </span>
      <span class="flex items-center gap-1.5">
        <svg class="w-3.5 h-3.5 text-emerald-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/></svg>
        Checkout secured by Whop
      </span>
    </div>

    <p class="mt-6 text-center text-xs text-zinc-500 leading-relaxed max-w-2xl mx-auto">
      {footnote}
      <a href="/disclaimer" class="underline text-emerald-800 hover:text-emerald-900"> Risk disclaimer</a>.
    </p>
  </section>

  <FAQs
    title="Billing and product questions"
    tagline=""
    classes={{ container: 'max-w-6xl' }}
    items={[
      {
        title: 'How does the free trial work?',
        description:
          'Your first seven days include full access at no cost. If you choose to continue afterward, you pay the plan rate you selected — monthly or annual. You may cancel during the trial at any time and no charge applies.',
      },
      {
        title: 'What is the difference between monthly and annual?',
        description:
          'Same full product, same features. Monthly is billed every month. Annual is billed once per year at a reduced effective rate — saving around $60 per year. Both include a 7-day free trial.',
      },
      {
        title: 'What is the difference between Meridian and Meridian Guard?',
        description:
          'Meridian is the full real-time PSI monitor. Meridian Guard is an upgraded tier that adds the Guard System (a commitment-device engine with 6 trigger conditions and 5 action levels) and the Intel Layer (monthly digest, PSI × P&L correlation, weekday patterns, and a personalized pre-session risk brief). Both products are available now — start with either tier and switch at any time.',
      },
      {
        title: 'Can I cancel at any time?',
        description:
          'Yes. Cancel during the trial and you will not be charged at all. Cancel an active subscription whenever you like and you retain access through the end of the period you have already paid for. To cancel, visit your Whop account at whop.com/@me/settings/memberships — log in with the email you used at checkout.',
      },
      {
        title: 'What payment methods are accepted?',
        description:
          'Checkout is processed securely by Whop. Major credit and debit cards (Visa, Mastercard, American Express, Discover) and other methods shown at checkout are supported where available. We do not store your full card details on Meridian servers.',
      },
      {
        title: 'What does the refund policy cover?',
        description:
          'Please see our Refund Policy for the full terms. In general, it explains how we handle installation or technical issues on supported setups, and how courtesy refunds work within the stated time frames.',
      },
      {
        title: 'What does PSI measure — and can it predict profits?',
        description:
          'PSI summarizes behavioral-stability signals from your live session using the patterns Meridian is designed to monitor. It is a risk-awareness and discipline tool, not a forecast of trading results, and it is not investment advice. Trading involves substantial risk of loss; many factors beyond psychology determine outcomes.',
      },
    ]}
  />

  <CallToAction
    actions={[
      {
        variant: 'primary',
        text: 'Start free trial — Meridian',
        href: standard.monthlyCtaHref,
        icon: 'tabler:player-play',
      },
      { text: 'System requirements', href: '/releases#requirements' },
    ]}
  >
    <Fragment slot="title">Seven-day trial. Full access.</Fragment>
    <Fragment slot="subtitle">
      $49.99/month or $479.90/year after the trial period. NinjaTrader 8 required. Credit card required at checkout.
      <span class="block text-xs text-muted mt-2">Trading involves substantial risk of loss. Meridian does not provide trading signals or investment advice.</span>
    </Fragment>
  </CallToAction>
</Layout>

<script>
  const btnMonthly = document.getElementById('btn-monthly') as HTMLButtonElement;
  const btnAnnual  = document.getElementById('btn-annual')  as HTMLButtonElement;

  const stdMonthlyPrice  = document.getElementById('std-monthly-price');
  const stdAnnualPrice   = document.getElementById('std-annual-price');
  const stdMonthlyNote   = document.getElementById('std-monthly-note');
  const stdAnnualNote    = document.getElementById('std-annual-note');
  const stdCta           = document.getElementById('std-cta') as HTMLAnchorElement;

  const guardMonthlyPrice = document.getElementById('guard-monthly-price');
  const guardAnnualPrice  = document.getElementById('guard-annual-price');
  const guardMonthlyNote  = document.getElementById('guard-monthly-note');
  const guardAnnualNote   = document.getElementById('guard-annual-note');
  const guardCta          = document.getElementById('guard-cta') as HTMLAnchorElement;

  const MONTHLY_URL       = 'https://whop.com/checkout/plan_4Z0XZqQl7TaDH';
  const ANNUAL_URL        = 'https://whop.com/checkout/plan_JhWetoQ39OCNz';
  const GUARD_MONTHLY_URL = 'https://whop.com/checkout/plan_ZHX4ySB65fahf';
  const GUARD_ANNUAL_URL  = 'https://whop.com/checkout/plan_frPOgHtDTvBkR';

  function setMonthly() {
    btnMonthly.classList.add('bg-white', 'text-zinc-900', 'shadow-sm');
    btnMonthly.classList.remove('text-zinc-500');
    btnAnnual.classList.remove('bg-white', 'text-zinc-900', 'shadow-sm');
    btnAnnual.classList.add('text-zinc-500');

    stdMonthlyPrice?.classList.remove('hidden');
    stdAnnualPrice?.classList.add('hidden');
    stdMonthlyNote?.classList.remove('hidden');
    stdAnnualNote?.classList.add('hidden');
    if (stdCta) stdCta.href = MONTHLY_URL;

    guardMonthlyPrice?.classList.remove('hidden');
    guardAnnualPrice?.classList.add('hidden');
    guardMonthlyNote?.classList.remove('hidden');
    guardAnnualNote?.classList.add('hidden');
    if (guardCta) guardCta.href = GUARD_MONTHLY_URL;
  }

  function setAnnual() {
    btnAnnual.classList.add('bg-white', 'text-zinc-900', 'shadow-sm');
    btnAnnual.classList.remove('text-zinc-500');
    btnMonthly.classList.remove('bg-white', 'text-zinc-900', 'shadow-sm');
    btnMonthly.classList.add('text-zinc-500');

    stdMonthlyPrice?.classList.add('hidden');
    stdAnnualPrice?.classList.remove('hidden');
    stdMonthlyNote?.classList.add('hidden');
    stdAnnualNote?.classList.remove('hidden');
    if (stdCta) stdCta.href = ANNUAL_URL;

    guardMonthlyPrice?.classList.add('hidden');
    guardAnnualPrice?.classList.remove('hidden');
    guardMonthlyNote?.classList.add('hidden');
    guardAnnualNote?.classList.remove('hidden');
    if (guardCta) guardCta.href = GUARD_ANNUAL_URL;
  }

  btnMonthly?.addEventListener('click', setMonthly);
  btnAnnual?.addEventListener('click', setAnnual);
</script>
