---
import { getCollection } from 'astro:content';
import Layout from '~/layouts/PageLayout.astro';
import HeroText from '~/components/widgets/HeroText.astro';

import products from '~/data/products.json';

const metadata = {
  title: 'Download PSI Monitor',
  description:
    'Download PSI Monitor for NinjaTrader 8. Confirm the risk disclaimer before downloading. Introductory license $24.99.',
};

const allEntries = await getCollection('changelog');
const sorted = allEntries.sort((a, b) => b.data.publishDate.getTime() - a.data.publishDate.getTime());
const latest = sorted.find((e) => e.data.isLatest) ?? sorted[0];
const olderVersions = sorted.filter((e) => e.id !== latest?.id).slice(0, 5);

const req = products.systemRequirements;
---

<Layout metadata={metadata}>
  <HeroText
    title="Download PSI Monitor"
    subtitle={`Current build: v${latest?.data.version ?? '1.0.0'} · For licensed users and approved beta testers.`}
  />

  <section id="requirements" class="max-w-4xl mx-auto px-6 mb-14">
    <div class="grid md:grid-cols-2 gap-6">
      <div class="rounded-2xl border border-zinc-200 bg-white p-6 shadow-sm">
        <h2 class="text-lg font-semibold mb-4 text-zinc-900">System requirements</h2>
        <ul class="space-y-2 text-sm text-zinc-600">
          <li class="flex gap-2">
            <span class="text-zinc-400 shrink-0">OS</span><span class="ml-auto font-medium text-zinc-900 text-right">{req.os}</span>
          </li>
          <li class="flex gap-2">
            <span class="text-zinc-400 shrink-0">NinjaTrader</span><span class="ml-auto font-medium text-zinc-900 text-right">{req.ninjaTrader}</span>
          </li>
          <li class="flex gap-2">
            <span class="text-zinc-400 shrink-0">RAM</span><span class="ml-auto font-medium text-zinc-900 text-right">{req.ram}</span>
          </li>
          <li class="flex gap-2">
            <span class="text-zinc-400 shrink-0">Disk</span><span class="ml-auto font-medium text-zinc-900 text-right">{req.disk}</span>
          </li>
        </ul>
        {req.note && <p class="mt-4 text-xs text-zinc-500 leading-relaxed">{req.note}</p>}
      </div>

      <div id="install" class="rounded-2xl border border-zinc-200 bg-white p-6 shadow-sm">
        <h2 class="text-lg font-semibold mb-4 text-zinc-900">Installation (summary)</h2>
        <ol class="space-y-2 text-sm text-zinc-600 list-decimal list-inside leading-relaxed">
          <li>Purchase a license, then download the build package from the link below.</li>
          <li>Copy the add-on sources into your NinjaTrader 8 custom folder and compile (see vendor README).</li>
          <li>Restart NinjaTrader 8 and launch <strong>PSI Monitor</strong> from the Control Center add-ons menu.</li>
          <li>Configure session window, risk limits, and dimension weights in Settings.</li>
        </ol>
        <p class="mt-4 text-xs text-zinc-500">
          Detailed screenshots will live in the docs section — wording may change with your shipping installer.
        </p>
      </div>
    </div>
  </section>

  <section class="max-w-4xl mx-auto px-6 mb-16">
    <div class="rounded-2xl border-2 border-emerald-700/30 bg-gradient-to-b from-white to-emerald-50/30 p-8 text-center relative overflow-hidden shadow-md">
      <div class="relative">
        <div
          class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-emerald-100 text-emerald-800 text-sm font-medium mb-4"
        >
          Latest — v{latest?.data.version}
        </div>
        <h2 class="text-2xl font-bold mb-2 text-zinc-900">PSI Monitor {latest?.data.version}</h2>
        <p class="text-zinc-600 mb-6 text-sm">
          Released {
            latest?.data.publishDate.toLocaleDateString('en-US', {
              year: 'numeric',
              month: 'long',
              day: 'numeric',
            })
          }
          · NinjaTrader 8 add-on
        </p>

        <div class="max-w-lg mx-auto mb-6">
          <label class="flex items-start gap-3 text-left cursor-pointer group">
            <input
              type="checkbox"
              id="disclaimer-confirm"
              class="mt-0.5 w-4 h-4 rounded border-zinc-300 text-emerald-600 cursor-pointer shrink-0"
            />
            <span class="text-sm text-zinc-600">
              I have read the <a href="/disclaimer" class="text-emerald-800 underline font-medium">risk disclaimer</a>.
              I understand PSI Monitor is a behavioral monitor only, does not provide trading advice, and that futures and
              forex trading involve substantial risk of loss.
            </span>
          </label>
        </div>

        <a
          id="download-btn"
          href={latest?.data.downloadUrl ?? '#'}
          class="inline-flex items-center gap-2 px-8 py-3.5 rounded-full bg-emerald-600 text-white font-semibold opacity-40 pointer-events-none transition-all hover:bg-emerald-700"
          aria-disabled="true"
        >
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"></path>
          </svg>
          Download v{latest?.data.version} (.zip)
        </a>
        <p class="text-xs text-zinc-500 mt-3">
          Need a license? <a href="/checkout" class="text-emerald-800 font-medium underline">Buy for $24.99</a>
        </p>
      </div>
    </div>
  </section>

  {
    olderVersions.length > 0 && (
      <section class="max-w-4xl mx-auto px-6 pb-20">
        <h2 class="text-lg font-semibold mb-4 text-zinc-800">Previous versions</h2>
        <div class="rounded-xl border border-zinc-200 overflow-hidden divide-y divide-zinc-200 bg-white">
          {olderVersions.map((entry) => (
            <div class="flex items-center justify-between px-5 py-3.5 hover:bg-zinc-50 transition-colors">
              <div>
                <span class="font-medium text-sm text-zinc-900">v{entry.data.version}</span>
                <span class="ml-3 text-xs text-zinc-500">
                  {entry.data.publishDate.toLocaleDateString('en-US', {
                    year: 'numeric',
                    month: 'short',
                    day: 'numeric',
                  })}
                </span>
              </div>
              {entry.data.downloadUrl && (
                <a href={entry.data.downloadUrl} class="text-xs text-emerald-700 font-medium hover:underline">
                  Download
                </a>
              )}
            </div>
          ))}
        </div>
        <p class="text-sm text-zinc-500 mt-4">
          Full notes: <a href="/changelog" class="text-emerald-800 underline">Changelog</a>.
        </p>
      </section>
    )
  }
</Layout>

<script>
  const checkbox = document.getElementById('disclaimer-confirm');
  const btn = document.getElementById('download-btn');

  checkbox?.addEventListener('change', () => {
    if (checkbox.checked) {
      btn?.classList.remove('opacity-40', 'pointer-events-none');
      btn?.removeAttribute('aria-disabled');
    } else {
      btn?.classList.add('opacity-40', 'pointer-events-none');
      btn?.setAttribute('aria-disabled', 'true');
    }
  });
</script>
