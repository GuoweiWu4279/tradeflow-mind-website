---
import { getCollection, render } from 'astro:content';
import Layout from '~/layouts/PageLayout.astro';
import HeroText from '~/components/widgets/HeroText.astro';
import FAQs from '~/components/widgets/FAQs.astro';

const metadata = {
  title: 'FAQ — Meridian',
  description: 'Frequently asked questions about Meridian — installation, pricing, trading, privacy, and support.',
  robots: { index: true, follow: true },
};

const allFaqs = await getCollection('faq');
const sorted = allFaqs.sort((a, b) => a.data.order - b.data.order);

const categories = [
  { id: 'psychology', label: 'Trading Psychology & Risk' },
  { id: 'installation', label: 'Installation' },
  { id: 'trading', label: 'Trading & Usage' },
  { id: 'technical', label: 'Technical' },
  { id: 'billing', label: 'Billing & Refunds' },
  { id: 'general', label: 'General' },
];

const faqsByCategory = categories.map(cat => ({
  ...cat,
  items: sorted.filter(f => f.data.category === cat.id),
})).filter(cat => cat.items.length > 0);

// FAQPage JSON-LD for GEO — helps Gemini, ChatGPT, Perplexity cite this page
const faqJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: sorted.map(entry => ({
    '@type': 'Question',
    name: entry.data.question,
    acceptedAnswer: {
      '@type': 'Answer',
      text: entry.body
        .replace(/^---[\s\S]*?---\n?/, '')
        .replace(/\*\*(.+?)\*\*/g, '$1')
        .replace(/\[(.+?)\]\(.+?\)/g, '$1')
        .replace(/#+\s/g, '')
        .replace(/`/g, '')
        .replace(/\n+/g, ' ')
        .trim(),
    },
  })),
};

const faqJsonLdHtml = JSON.stringify(faqJsonLd).replace(/</g, '\\u003c');
---

<Layout metadata={metadata}>
  <!-- FAQPage structured data for GEO (Gemini / ChatGPT / Perplexity) -->
  <script type="application/ld+json" set:html={faqJsonLdHtml} />
  <HeroText
    title="Frequently Asked Questions"
    subtitle="Can't find what you're looking for? Contact us at contactmeridianpsi@gmail.com"
  />

  <section class="faq-page max-w-3xl mx-auto px-6 pb-20">
    {faqsByCategory.map(async (cat) => (
      <div class="mb-12">
        <h2 class="text-sm font-semibold uppercase tracking-widest text-zinc-500 dark:text-zinc-400 mb-6 border-b border-zinc-200 dark:border-zinc-800 pb-2">
          {cat.label}
        </h2>
        <div class="space-y-4">
          {cat.items.map(async (entry) => {
            const { Content } = await render(entry);
            return (
              <details class="group faq-item border border-zinc-200 dark:border-zinc-800 rounded-xl overflow-hidden">
                <summary class="flex items-center justify-between px-5 py-4 cursor-pointer font-medium text-zinc-900 dark:text-white hover:bg-zinc-50 dark:hover:bg-zinc-800/50 transition-colors duration-200 ease-out list-none [&::-webkit-details-marker]:hidden">
                  {entry.data.question}
                  <svg class="faq-chevron w-4 h-4 text-zinc-400 shrink-0 ml-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
                  </svg>
                </summary>
                <div class="faq-item-panel px-5 pb-5 pt-1 prose dark:prose-invert prose-sm max-w-none prose-a:text-blue-600 dark:prose-a:text-blue-400">
                  <Content />
                </div>
              </details>
            );
          })}
        </div>
      </div>
    ))}

    <!-- Support CTA -->
    <div class="rounded-2xl border border-zinc-200 dark:border-zinc-700 p-6 text-center bg-zinc-50 dark:bg-zinc-900/40 mt-8">
      <h3 class="font-semibold mb-2">Still have questions?</h3>
      <p class="text-sm text-zinc-500 dark:text-zinc-400 mb-4">Our support team typically responds within 1–2 business days.</p>
      <a href="mailto:contactmeridianpsi@gmail.com" class="inline-flex items-center gap-2 px-5 py-2.5 rounded-full border border-zinc-300 dark:border-zinc-600 text-sm font-medium hover:border-zinc-500 transition-colors">
        Contact Support →
      </a>
    </div>
  </section>
</Layout>

<style is:global>
  /* Smooth accordion height (Chrome 131+ / browsers with interpolate-size + ::details-content) */
  .faq-page {
    interpolate-size: allow-discrete;
  }

  .faq-page details.faq-item::details-content {
    height: 0;
    overflow: clip;
    transition:
      height 0.38s cubic-bezier(0.4, 0, 0.2, 1),
      content-visibility 0.38s allow-discrete;
  }

  .faq-page details.faq-item[open]::details-content {
    height: auto;
  }

  .faq-page details.faq-item .faq-chevron {
    transition: transform 0.38s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .faq-page details.faq-item[open] .faq-chevron {
    transform: rotate(180deg);
  }

  /* Fallback / extra polish: content eases in when opening */
  .faq-page details.faq-item[open] > .faq-item-panel {
    animation: faq-panel-in 0.32s cubic-bezier(0.22, 1, 0.36, 1) both;
  }

  @keyframes faq-panel-in {
    from {
      opacity: 0;
      transform: translateY(-6px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .faq-page details.faq-item::details-content {
      transition: none;
    }
    .faq-page details.faq-item .faq-chevron {
      transition: none;
    }
    .faq-page details.faq-item[open] > .faq-item-panel {
      animation: none;
    }
  }
</style>
