<style>
  .marquee-left {
    animation: marquee-left 130s linear infinite;
  }
  .marquee-right {
    animation: marquee-right 130s linear infinite;
  }
  @keyframes marquee-left {
    from { transform: translateX(0); }
    to   { transform: translateX(-50%); }
  }
  @keyframes marquee-right {
    from { transform: translateX(-50%); }
    to   { transform: translateX(0); }
  }
  .marquee-left:hover,
  .marquee-right:hover {
    animation-play-state: paused;
  }

  /* Roadmap section animations */
  .roadmap-heading,
  .roadmap-step {
    opacity: 0;
    transform: translateY(20px);
    transition: opacity 0.55s ease, transform 0.55s ease;
  }
  .roadmap-connector {
    transform: scaleX(0);
    transform-origin: left center;
    transition: transform 0.9s cubic-bezier(0.4, 0, 0.2, 1);
    transition-delay: 150ms;
  }
  #how-it-works.is-visible .roadmap-heading,
  #how-it-works.is-visible .roadmap-step {
    opacity: 1;
    transform: translateY(0);
  }
  #how-it-works.is-visible .roadmap-connector {
    transform: scaleX(1);
  }
  /* Hover lift on detail cards */
  .roadmap-card {
    transition: transform 0.2s ease, box-shadow 0.2s ease;
  }
  .roadmap-step:hover .roadmap-card {
    transform: translateY(-3px);
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.07);
  }

  /* Step detail tab navigation */
  .step-tab-btn {
    flex: 1;
    min-width: 80px;
    padding: 0.75rem 1rem;
    font-size: 0.875rem;
    font-weight: 600;
    text-align: center;
    border-bottom: 2px solid transparent;
    color: theme('colors.zinc.500');
    transition: color 0.2s ease, border-color 0.2s ease;
    white-space: nowrap;
  }
  .step-tab-num {
    display: block;
    font-size: 0.7rem;
    font-weight: 400;
    opacity: 0.6;
    margin-bottom: 0.125rem;
    letter-spacing: 0.06em;
  }
  .step-tab-btn:hover:not(.is-active) {
    color: theme('colors.zinc.800');
    border-color: theme('colors.zinc.300');
  }
  .step-tab-btn.is-active {
    border-color: theme('colors.emerald.600');
    color: theme('colors.emerald.700');
  }</style>

<script>
  function initCarousel(id: string) {
    const slides   = Array.from(document.querySelectorAll<HTMLElement>(`[data-carousel="${id}"]`));
    const captions = Array.from(document.querySelectorAll<HTMLElement>(`[data-caption="${id}"]`));
    const dots     = Array.from(document.querySelectorAll<HTMLElement>(`[data-dot="${id}"]`));
    if (!slides.length) return;
    let current = 0;
    let animating = false;

    slides.forEach((s, i) => {
      s.style.transition = 'opacity 0.25s ease';
      s.style.opacity = i === 0 ? '1' : '0';
    });

    function goTo(index: number) {
      if (animating) return;
      const prev = current;
      const next = ((index % slides.length) + slides.length) % slides.length;
      if (prev === next) return;
      animating = true;

      dots[prev]?.classList.remove('bg-zinc-700', 'w-4');
      dots[prev]?.classList.add('bg-zinc-300', 'w-1.5');
      dots[next]?.classList.add('bg-zinc-700', 'w-4');
      dots[next]?.classList.remove('bg-zinc-300', 'w-1.5');

      slides[prev].style.opacity = '0';
      setTimeout(() => {
        slides[prev].classList.add('hidden');
        if (captions[prev]) captions[prev].classList.add('hidden');
        current = next;
        slides[current].classList.remove('hidden');
        if (captions[current]) captions[current].classList.remove('hidden');
        slides[current].style.opacity = '0';
        requestAnimationFrame(() => {
          requestAnimationFrame(() => {
            slides[current].style.opacity = '1';
            animating = false;
          });
        });
      }, 250);
    }

    document.querySelector(`[data-prev="${id}"]`)?.addEventListener('click', () => goTo(current - 1));
    document.querySelector(`[data-next="${id}"]`)?.addEventListener('click', () => goTo(current + 1));
    dots.forEach((dot, i) => dot.addEventListener('click', () => goTo(i)));
  }

  function initSlider(id: string) {
    const slides = Array.from(document.querySelectorAll<HTMLElement>(`[data-slide="${id}"]`));
    if (!slides.length) return;
    const dots = Array.from(document.querySelectorAll<HTMLElement>(`[data-dot="${id}"]`));
    const labelEl = document.querySelector<HTMLElement>(`[data-label-display="${id}"]`);
    let current = 0;
    let animating = false;

    slides.forEach((s, i) => {
      s.style.transition = 'opacity 0.25s ease';
      s.style.opacity = i === 0 ? '1' : '0';
    });

    function goTo(n: number) {
      if (animating) return;
      const prev = current;
      const next = ((n % slides.length) + slides.length) % slides.length;
      if (prev === next) return;
      animating = true;

      dots[prev]?.classList.remove('w-4', 'bg-emerald-500');
      dots[prev]?.classList.add('w-1.5', 'bg-zinc-300');
      dots[next]?.classList.add('w-4', 'bg-emerald-500');
      dots[next]?.classList.remove('w-1.5', 'bg-zinc-300');
      if (labelEl) labelEl.textContent = slides[next].dataset.slideLabel ?? '';

      slides[prev].style.opacity = '0';
      setTimeout(() => {
        slides[prev].classList.add('hidden');
        current = next;
        slides[current].classList.remove('hidden');
        slides[current].style.opacity = '0';
        requestAnimationFrame(() => {
          requestAnimationFrame(() => {
            slides[current].style.opacity = '1';
            animating = false;
          });
        });
      }, 250);
    }

    document.querySelector(`[data-prev="${id}"]`)?.addEventListener('click', () => goTo(current - 1));
    document.querySelector(`[data-next="${id}"]`)?.addEventListener('click', () => goTo(current + 1));
    dots.forEach((dot, i) => dot.addEventListener('click', () => goTo(i)));
  }

  function initRoadmap() {
    const section = document.getElementById('how-it-works');
    if (!section) return;
    const observer = new IntersectionObserver(
      ([entry]) => {
        if (entry.isIntersecting) {
          section.classList.add('is-visible');
          observer.disconnect();
        }
      },
      { threshold: 0.12 }
    );
    observer.observe(section);
  }

  function initStepTabs() {
    const tabs = Array.from(document.querySelectorAll<HTMLElement>('[data-step-tab]'));
    const track = document.getElementById('step-panels-track') as HTMLElement | null;
    if (!tabs.length || !track) return;
    let current = 0;
    tabs.forEach(tab => {
      tab.addEventListener('click', () => {
        const next = parseInt((tab as HTMLElement).dataset.stepTab ?? '0', 10);
        if (next === current) return;
        tabs.forEach((t, i) => t.classList.toggle('is-active', i === next));
        track.style.transform = `translateX(-${next * 25}%)`;
        current = next;
      });
    });
  }

  function boot() {
    initCarousel('history');
    initSlider('intel-features');
    initRoadmap();
    initStepTabs();
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', boot);
  } else {
    boot();
  }
</script>
