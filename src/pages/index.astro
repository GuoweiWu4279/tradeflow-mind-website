---
import Layout from '~/layouts/PageLayout.astro';

import Hero from '~/components/widgets/Hero.astro';
import Stats from '~/components/widgets/Stats.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';

const metadata = {
  title: 'Meridian — The First Real-Time Psychological Stability Index for Active Traders',
  ignoreTitleTemplate: true,
};

const marqueeRow1 = [
  {
    quote: "Three months in. I thought I had clean execution — the overtrading metric disagreed from day one.",
    name: 'Jason K.',
    role: 'Futures day trader',
  },
  {
    quote: "Passed my third Apex evaluation. The first two I blew up on days where, in hindsight, I should have just closed the platform. The pattern was obvious once I could see it.",
    name: 'Mike R.',
    role: 'Prop firm trader',
  },
  {
    quote: "Turned out I wasn't losing because of my entries. I was adding to losing positions and ignoring my own rules. Took data to admit it.",
    name: 'Anonymous',
    role: '',
  },
  {
    quote: "I don't use tools that send my fill data to the cloud. Local-only was non-negotiable for me.",
    name: 'David Chen',
    role: 'Independent trader',
  },
  {
    quote: "It doesn't close your positions for you — that part is still on you. But I stopped pretending I didn't notice the score dropping while I was moving my stop around.",
    name: 'T. Rodriguez',
    role: 'NQ futures',
  },
  {
    quote: "The seven bars make it immediately clear which habit is pulling the score down. I kept telling myself I was trading fine. The data disagreed consistently.",
    name: 'Elena V.',
    role: 'MNQ scalper',
  },
  {
    quote: "Being able to use Market Replay without it touching my live baseline was more useful than I expected.",
    name: 'Chris P.',
    role: 'Futures swing',
  },
  {
    quote: "I run two accounts with copy fills. I was expecting double-counting issues in the score. It handled it cleanly without any configuration.",
    name: 'Jordan L.',
    role: 'Multi-account',
  },
  {
    quote: "After a losing session I used to review charts to explain what happened. Now I check the session report first. It's faster and more honest.",
    name: 'Sam W.',
    role: 'ES / NQ',
  },
  {
    quote: "Didn't want another subscription. Tried the trial anyway. Kept it — the overlay is actually readable mid-session without being in the way.",
    name: 'Rina M.',
    role: 'Day trader',
  },
];

const marqueeRow2 = [
  {
    quote: "The caution signal fired and I decided I could manage through it. Twenty minutes later I had hit my daily limit. I can't blame the tool — I ignored it.",
    name: 'Sara',
    role: 'ES trader',
  },
  {
    quote: "I've restarted funded accounts more times than I want to count. If someone had told me a revenge-entry detector would matter more than another indicator, I wouldn't have believed them.",
    name: 'Alex Nowak',
    role: 'Prop trader',
  },
  {
    quote: "Four years trading NQ. Thought I had a solid read on my own behavior. First week of data showed me I had several habits I wasn't aware of.",
    name: 'James O.',
    role: 'Day trader',
  },
  {
    quote: "Post-session journals have their place. This is different — the feedback arrives while the session is still running, not the next morning.",
    name: 'Anonymous',
    role: '',
  },
  {
    quote: "Took a few sessions to calibrate. Once it did, the alerts started making sense — I could trace each one back to a specific pattern.",
    name: 'Priya S.',
    role: 'Futures trader',
  },
  {
    quote: "The stop-widening flag caught me doing something I always denied — moving my stop out when a trade went against me. Useful confirmation, even if it wasn't comfortable.",
    name: 'Marcus T.',
    role: 'CL / GC',
  },
  {
    quote: "Thought my exits were disciplined. Turns out there's a consistent pattern on certain days. I don't love it, but I can work with the information.",
    name: 'Kim H.',
    role: 'Index futures',
  },
  {
    quote: "A rough Tuesday doesn't disappear from the score just because Wednesday started. That's accurate. That's how it actually feels.",
    name: 'Leo B.',
    role: 'Overnight + day',
  },
  {
    quote: "The alerts are infrequent enough that I don't tune them out. When one fires, I actually pause before doing anything.",
    name: 'Andre C.',
    role: 'Prop + personal',
  },
  {
    quote: "The history view is simple. I like that. Seeing consistent streaks makes discipline feel measurable instead of just a goal.",
    name: 'Nina F.',
    role: 'Futures',
  },
];
---

<Layout metadata={metadata}>
  <Hero
    actions={[
      {
        variant: 'primary',
        text: 'Start free trial — 7 days',
        href: 'https://meridianpsi.lemonsqueezy.com/checkout/buy/b7b8b514-fefa-4a34-8cad-d2e68f564d25',
        icon: 'tabler:player-play',
      },
      { text: 'See pricing', href: '/pricing' },
    ]}
  >
    <Fragment slot="title">
      Every trader has a plan.
      <br />
      <span class="text-accent dark:text-emerald-700">The market's job is to make you forget it.</span>
    </Fragment>

    <Fragment slot="subtitle">
      <strong>Meridian</strong> is the first real-time psychological stability monitor for active traders. It tracks seven behavioral patterns, learns your personal baseline, and updates your PSI score in less than 100ms during the session.
      <br /><br />
      <span class="text-zinc-500 font-normal">Most psychology tools analyze what happened. Meridian tells you what's happening — <em>right now</em>.</span>
    </Fragment>
  </Hero>

  <Stats
    stats={[
      { title: 'Live behavioral signals', amount: '7' },
      { title: 'Updated after and during session', amount: '<100ms' },
      { title: 'Session history', amount: '5 years' },
      { title: 'Free trial, no charge', amount: '7-day' },
    ]}
  />

  <!-- Problem recognition section — institutional vs retail framing -->
  <section class="py-16 px-6 bg-zinc-50/60">
    <div class="max-w-4xl mx-auto text-center">
      <h2 class="text-3xl md:text-4xl font-bold text-zinc-900 mb-4">
        Institutional traders have risk managers.<br />You have yourself.
      </h2>
      <p class="text-lg text-zinc-600 mb-12 max-w-2xl mx-auto">
        They have compliance officers, position limits, and systems that enforce rules outside their control. Retail traders have experience, hard-won rules — and then the moment everything goes wrong, nothing stops them from breaking all of them.
      </p>
      <ul class="text-left max-w-lg mx-auto space-y-4 mb-12">
        {[
          'Added size right after a loss',
          'Moved the stop to "give it a little more room"',
          'Took the next trade too fast — still feeling the last one',
          'Held a loser longer than your plan ever allowed',
          'Broke your session rule — just this once',
          'Hit your daily limit and took one more anyway',
        ].map((item) => (
          <li class="flex items-start gap-3 text-base text-zinc-700">
            <span class="mt-2 h-2 w-2 rounded-full bg-red-400 shrink-0"></span>
            {item}
          </li>
        ))}
      </ul>
      <p class="text-lg font-semibold text-zinc-900 max-w-xl mx-auto">
        Meridian doesn't tell you what to trade.<br />
        It tells you <em>where you are</em> — so you can decide whether to continue.
      </p>
    </div>
  </section>

  <!-- Live score — dark showcase -->
  <section class="relative py-28 px-6 overflow-hidden">
    <!-- Gradient fade from white above into dark, and back to white below -->
    <div class="pointer-events-none absolute inset-0 bg-[#0a0a0a]"></div>

    <!-- Red ambient glow — matches the screenshot's critical alarm color -->
    <div class="pointer-events-none absolute top-1/2 left-1/4 -translate-x-1/2 -translate-y-1/2 w-[500px] h-[500px] rounded-full bg-red-700/10 blur-[100px]"></div>
    <!-- Subtle green counter-glow on the right for the green toggle -->
    <div class="pointer-events-none absolute top-1/2 right-1/4 translate-x-1/2 -translate-y-1/2 w-[300px] h-[300px] rounded-full bg-emerald-700/8 blur-[80px]"></div>

    <div class="relative z-20 max-w-6xl mx-auto grid md:grid-cols-[55fr_45fr] gap-12 md:gap-20 items-center">
      <!-- Screenshot — larger, floats with depth shadow -->
      <div class="order-1 md:order-1">
        <div class="rounded-2xl overflow-hidden shadow-[0_40px_100px_rgba(0,0,0,0.8),0_0_0_1px_rgba(255,255,255,0.06)]">
          <img
            src="/screenshots/psi-critical.png"
            alt="Meridian PSI Monitor showing a Critical score of 47 with behavioral signal bars"
            class="w-full h-auto block"
            loading="eager"
          />
        </div>
      </div>
      <!-- Text (white on dark) -->
      <div class="order-2 md:order-2">
        <p class="text-xs font-semibold tracking-widest text-zinc-400 uppercase mb-3">Live session view</p>
        <h2 class="text-3xl md:text-4xl font-bold text-white leading-snug mb-5">
          A live view of your trading stability.
        </h2>
        <p class="text-zinc-400 leading-relaxed text-base mb-6">
          Your PSI updates in real time during the session, with clear signals showing what is driving the score.
        </p>
        <ul class="space-y-3 text-sm text-zinc-300">
          {['Updates during the session, not just after fills', 'Seven visible signal bars show what is driving the score', 'Session stats: trades, win rate, alerts, duration', 'PSI timeline shows how pressure evolved across the session'].map(item => (
            <li class="flex items-start gap-2.5">
              <span class="mt-1 h-1.5 w-1.5 rounded-full bg-zinc-500 shrink-0"></span>
              {item}
            </li>
          ))}
        </ul>
        <div class="mt-8">
          <a href="/features" class="inline-flex items-center gap-1.5 text-sm font-medium text-white/75 hover:text-white transition-colors">
            See full feature breakdown &rarr;
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Section 2: Seven dimensions — CSS visual layout, no screenshot needed -->
  <section class="py-16 px-6 bg-zinc-50/60 border-t border-zinc-100">
    <div class="max-w-5xl mx-auto">
      <div class="mb-8">
        <p class="text-xs font-semibold tracking-widest text-emerald-700 uppercase mb-2">Behavioral signals</p>
        <h2 class="text-2xl md:text-3xl font-bold text-zinc-900 leading-snug mb-3">
          Seven patterns. Each one specific to a known failure mode.
        </h2>
        <p class="text-zinc-500 leading-relaxed text-sm max-w-2xl">
          Every signal tracks a behavioral pattern from behavioral-finance research. They run independently and combine into a single PSI score.
        </p>
      </div>
      <div class="space-y-2">
        {[
          { name: 'Revenge Entry',     desc: 'Re-entry after loss with elevated size',              pct: 82 },
          { name: 'Stop Manipulation', desc: 'Widening stops in the adverse direction',             pct: 55 },
          { name: 'Size Spike',        desc: 'Position exceeds your declared rule',                 pct: 95 },
          { name: 'Hold Bias',         desc: 'Abnormal hold duration vs your own baseline',        pct: 38 },
          { name: 'Position Overstay', desc: 'Holding a loser past your 90th-percentile hold time', pct: 60 },
          { name: 'Rule Violations',   desc: 'Trading outside your declared session rules',         pct: 44 },
          { name: 'Overtrading Pace',  desc: 'Entry frequency accelerating vs your history',        pct: 71 },
        ].map(({ name, desc, pct }) => (
          <div class="flex items-center gap-4 bg-white rounded-lg border border-zinc-100 px-5 py-2.5 shadow-sm">
            <span class="w-36 shrink-0 text-sm font-semibold text-zinc-900">{name}</span>
            <div class="flex-1 h-1.5 bg-zinc-100 rounded-full overflow-hidden">
              <div class="h-full rounded-full bg-gradient-to-r from-emerald-500 to-emerald-400" style={`width:${pct}%`}></div>
            </div>
            <span class="w-56 shrink-0 text-xs text-zinc-400 text-right hidden sm:block">{desc}</span>
          </div>
        ))}
      </div>
      <div class="mt-5">
        <a href="/features#seven-dimensions" class="inline-flex items-center gap-1.5 text-sm font-medium text-emerald-700 hover:text-emerald-900 transition-colors">
          Read the technical detail &rarr;
        </a>
      </div>
    </div>
  </section>

  <!-- Section 3: Session history — left carousel, right text -->
  <section class="py-20 lg:py-28 px-6 bg-white border-t border-zinc-100">
    <div class="max-w-6xl mx-auto grid md:grid-cols-2 gap-12 md:gap-20 items-start">
      <!-- Left: sliding carousel -->
      <div class="relative group/carousel">
        <!-- Overflow container clips the sliding track -->
        <div class="relative overflow-hidden rounded-2xl shadow-xl border border-zinc-800">
          <div data-track="history" class="flex transition-transform duration-300 ease-out">
            <div class="min-w-full shrink-0">
              <img
                src="/screenshots/session-log-december.png"
                alt="Session log December 2025"
                class="w-full h-auto block"
                loading="lazy"
              />
            </div>
            <div class="min-w-full shrink-0">
              <img
                src="/screenshots/session-log-april.png"
                alt="Session log April 2026"
                class="w-full h-auto block"
                loading="lazy"
              />
            </div>
          </div>
          <!-- Dot indicators over image -->
          <div class="absolute bottom-3 left-1/2 -translate-x-1/2 z-10 flex gap-1.5">
            <button data-dot="history" class="h-1.5 w-4 rounded-full bg-white/90 transition-all" aria-label="Slide 1"></button>
            <button data-dot="history" class="h-1.5 w-1.5 rounded-full bg-white/40 hover:bg-white/70 transition-all" aria-label="Slide 2"></button>
          </div>
        </div>
        <!-- Caption (swapped by JS) -->
        <div class="mt-3 px-1 min-h-[2rem]">
          <div data-caption="history-0" class="flex items-center flex-wrap gap-2">
            <span class="bg-red-500 text-white text-xs font-bold px-3 py-1 rounded-full">Month 1 — December 2025</span>
            <span class="text-red-500 font-semibold text-sm">Composure 49%</span>
            <span class="text-zinc-400 text-sm">·</span>
            <span class="text-red-500 font-semibold text-sm">Avg P&amp;L &minus;$629</span>
          </div>
          <div data-caption="history-1" class="flex items-center flex-wrap gap-2 hidden">
            <span class="bg-emerald-500 text-white text-xs font-bold px-3 py-1 rounded-full">Month 5 — April 2026</span>
            <span class="text-emerald-600 font-semibold text-sm">Composure 79%</span>
            <span class="text-zinc-400 text-sm">·</span>
            <span class="text-emerald-600 font-semibold text-sm">Avg P&amp;L +$997</span>
          </div>
        </div>
        <!-- Overlay prev arrow -->
        <button
          data-prev="history"
          class="absolute left-3 top-[43%] -translate-y-1/2 z-10 h-9 w-9 rounded-full bg-black/30 hover:bg-black/60 backdrop-blur-sm text-white flex items-center justify-center transition-all opacity-0 group-hover/carousel:opacity-100 focus-visible:opacity-100"
          aria-label="Previous"
        >
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="w-4 h-4"><path fill-rule="evenodd" d="M11.78 5.22a.75.75 0 0 1 0 1.06L8.06 10l3.72 3.72a.75.75 0 1 1-1.06 1.06l-4.25-4.25a.75.75 0 0 1 0-1.06l4.25-4.25a.75.75 0 0 1 1.06 0Z" clip-rule="evenodd" /></svg>
        </button>
        <!-- Overlay next arrow -->
        <button
          data-next="history"
          class="absolute right-3 top-[43%] -translate-y-1/2 z-10 h-9 w-9 rounded-full bg-black/30 hover:bg-black/60 backdrop-blur-sm text-white flex items-center justify-center transition-all opacity-0 group-hover/carousel:opacity-100 focus-visible:opacity-100"
          aria-label="Next"
        >
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="w-4 h-4"><path fill-rule="evenodd" d="M8.22 5.22a.75.75 0 0 1 1.06 0l4.25 4.25a.75.75 0 0 1 0 1.06l-4.25 4.25a.75.75 0 1 1-1.06-1.06L11.94 10 8.22 6.28a.75.75 0 0 1 0-1.06Z" clip-rule="evenodd" /></svg>
        </button>
      </div>
      <!-- Right: text -->
      <div>
        <p class="text-xs font-semibold tracking-widest text-emerald-700 uppercase mb-3">Session review and history</p>
        <h2 class="text-3xl md:text-4xl font-bold text-zinc-900 leading-snug mb-5">
          Not just P&amp;L. Whether you traded right.
        </h2>
        <p class="text-zinc-500 leading-relaxed text-base mb-6">
          Meridian tracks discipline session by session. Over time, the pattern becomes visible — and so does the improvement.
        </p>
        <ul class="space-y-3 text-sm text-zinc-700">
          {[
            'Every session saved with PSI score, Composure, and trade stats',
            'Month-over-month behavioral progress visible at a glance',
            'Separate from P&L — shows whether you traded in control',
            '5 years of session history with Meridian Guard',
          ].map(item => (
            <li class="flex items-start gap-2.5">
              <span class="mt-1 h-1.5 w-1.5 rounded-full bg-emerald-500 shrink-0"></span>
              {item}
            </li>
          ))}
        </ul>
      </div>
    </div>
  </section>

  <!-- Section 4: Personalized baselines -->
  <section class="py-20 lg:py-28 px-6 bg-zinc-50/60 border-t border-zinc-100">
    <div class="max-w-6xl mx-auto grid md:grid-cols-[3fr_2fr] gap-12 md:gap-20 items-center">
      <!-- Text -->
      <div class="order-2 md:order-1">
        <p class="text-xs font-semibold tracking-widest text-emerald-700 uppercase mb-3">Personalized baselines</p>
        <h2 class="text-3xl md:text-4xl font-bold text-zinc-900 leading-snug mb-5">
          Built around your behavior. Not a generic threshold.
        </h2>
        <p class="text-zinc-600 leading-relaxed text-base mb-6">
          Meridian learns what normal looks like for you, then makes drift visible when your behavior starts to change. The PSI score is built around your own history, so it stays useful across different trading styles instead of relying on a one-size-fits-all warning level.
        </p>
        <ul class="space-y-3 text-sm text-zinc-700">
          {[
            'Built from your own trading history',
            'Personal baseline instead of a generic rule',
            'Detailed profile settings for different styles, rules, and workflows',
            'Becomes more useful as more sessions are recorded',
          ].map(item => (
            <li class="flex items-start gap-2.5">
              <span class="mt-1 h-1.5 w-1.5 rounded-full bg-emerald-500 shrink-0"></span>
              {item}
            </li>
          ))}
        </ul>
        <div class="mt-8">
          <a href="/features" class="inline-flex items-center gap-1.5 text-sm font-medium text-emerald-700 hover:text-emerald-900 transition-colors">
            Full technical breakdown &rarr;
          </a>
        </div>
      </div>
      <!-- Baseline screenshot -->
      <div class="order-1 md:order-2">
        <div class="rounded-2xl overflow-hidden shadow-xl border border-zinc-800">
          <img
            src="/screenshots/baseline-learning.png"
            alt="Meridian baseline learning panel showing personal trading statistics"
            class="w-full h-auto block"
            loading="lazy"
          />
        </div>
      </div>
    </div>
  </section>

  <!-- Guard teaser -->
  <section class="py-20 lg:py-28 px-6 bg-zinc-900 text-white border-t border-zinc-800">
    <div class="max-w-6xl mx-auto">
      <div class="md:grid md:grid-cols-[5fr_7fr] md:gap-16 md:items-center">
        <!-- Left: copy -->
        <div class="mb-12 md:mb-0">
          <p class="text-xs font-semibold tracking-[0.15em] text-emerald-400 uppercase mb-4">Meridian Guard — Coming soon</p>
          <h2 class="text-3xl md:text-4xl font-bold mb-5">
            You already know the rules.<br />Guard makes sure you follow them.
          </h2>
          <p class="text-zinc-400 text-base leading-relaxed mb-8">
            When you are calm, you write the rules. When the moment comes, Guard enforces them automatically — without requiring a decision from you.
          </p>
          <div class="space-y-5 mb-8">
            <div>
              <p class="text-emerald-400 text-xs font-bold tracking-widest uppercase mb-1">Guard System</p>
              <p class="text-zinc-300 text-sm leading-relaxed">6 trigger conditions. 5 action levels — from a quiet alert to a full broker disconnect. Set once, active every session.</p>
            </div>
            <div>
              <p class="text-emerald-400 text-xs font-bold tracking-widest uppercase mb-1">Intel Layer</p>
              <p class="text-zinc-300 text-sm leading-relaxed">Monthly digest, PSI × P&amp;L correlation, weakest-day analysis, and a daily pre-session risk brief — built from your own history.</p>
            </div>
            <div>
              <p class="text-white text-xs font-bold tracking-widest uppercase mb-1">Key finding</p>
              <p class="text-zinc-300 text-sm leading-relaxed">Stable PSI sessions averaged +$1,296. Critical sessions averaged −$550. Guard shows you before you get there.</p>
            </div>
          </div>
          <a
            href="/guard"
            class="inline-flex items-center gap-2 bg-emerald-600 hover:bg-emerald-500 text-white font-semibold text-sm rounded-full px-8 py-3 transition-colors duration-200"
          >
            See everything in Meridian Guard
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
            </svg>
          </a>
        </div>

        <!-- Right: Intel screenshot carousel -->
        <div class="relative group/carousel">
          <div class="relative overflow-hidden rounded-2xl border border-zinc-700 shadow-2xl">
            <div data-track="intel-home" class="flex transition-transform duration-300 ease-out">
              <!-- Slide 1: PSI x Performance -->
              <div class="min-w-full shrink-0">
                <div class="bg-zinc-800 px-5 py-3 border-b border-zinc-700 flex items-center gap-2">
                  <span class="h-1.5 w-1.5 rounded-full bg-emerald-400 shrink-0"></span>
                  <p class="text-xs font-semibold text-zinc-300">PSI × Performance — session-level correlation</p>
                </div>
                <img src="/screenshots/psi-performance.png" alt="PSI x Performance" class="w-full h-auto block" loading="lazy" />
              </div>
              <!-- Slide 2: Monthly Digest December -->
              <div class="min-w-full shrink-0">
                <div class="bg-zinc-50 px-5 py-3 border-b border-zinc-200 flex items-center gap-2">
                  <span class="h-1.5 w-1.5 rounded-full bg-zinc-400 shrink-0"></span>
                  <p class="text-xs font-semibold text-zinc-500">Monthly Digest — December 2025 (Grade C)</p>
                </div>
                <img src="/screenshots/digest-december.png" alt="Monthly Digest December" class="w-full h-auto block" loading="lazy" />
              </div>
              <!-- Slide 3: Monthly Digest March -->
              <div class="min-w-full shrink-0">
                <div class="bg-zinc-50 px-5 py-3 border-b border-zinc-200 flex items-center gap-2">
                  <span class="h-1.5 w-1.5 rounded-full bg-emerald-500 shrink-0"></span>
                  <p class="text-xs font-semibold text-zinc-500">Monthly Digest — March 2026 (Grade B+)</p>
                </div>
                <img src="/screenshots/digest-march.png" alt="Monthly Digest March" class="w-full h-auto block" loading="lazy" />
              </div>
              <!-- Slide 4: Weekday Patterns -->
              <div class="min-w-full shrink-0">
                <div class="bg-zinc-50 px-5 py-3 border-b border-zinc-200 flex items-center gap-2">
                  <span class="h-1.5 w-1.5 rounded-full bg-zinc-400 shrink-0"></span>
                  <p class="text-xs font-semibold text-zinc-500">Weekday patterns + 6-month Composure progress</p>
                </div>
                <img src="/screenshots/weekday-patterns.png" alt="Weekday Patterns" class="w-full h-auto block" loading="lazy" />
              </div>
            </div>
            <!-- Dot indicators -->
            <div class="absolute bottom-3 left-1/2 -translate-x-1/2 z-10 flex gap-1.5">
              <button data-dot="intel-home" class="h-1.5 w-4 rounded-full bg-white/90 transition-all" aria-label="Slide 1"></button>
              <button data-dot="intel-home" class="h-1.5 w-1.5 rounded-full bg-white/40 hover:bg-white/70 transition-all" aria-label="Slide 2"></button>
