---
import '@fontsource-variable/inter';
---

<style is:inline>
  :root {
    --aw-font-sans: 'Inter Variable';
    --aw-font-serif: 'Inter Variable';
    --aw-font-heading: 'Inter Variable';

    --aw-color-primary: #B9A287;        /* warm tan — main accent */
    --aw-color-secondary: #8B7355;      /* darker tan */
    --aw-color-accent: #B9A287;

    --aw-color-text-heading: #2A1A08;   /* very dark warm brown */
    --aw-color-text-default: #3D2410;   /* dark warm brown */
    --aw-color-text-muted: #8B7355;     /* medium warm tan */
    --aw-color-bg-page: #F5F0E8;        /* warm off-white */

    --aw-color-bg-page-dark: #1E1208;   /* deepest warm dark */

    ::selection {
      background-color: #E1D0BC;
      color: #2A1A08;
    }
  }

  .dark {
    --aw-font-sans: 'Inter Variable';
    --aw-font-serif: 'Inter Variable';
    --aw-font-heading: 'Inter Variable';

    --aw-color-primary: #CBC2A9;        /* lighter tan on dark */
    --aw-color-secondary: #B9A287;
    --aw-color-accent: #CBC2A9;

    --aw-color-text-heading: #E9E4D9;
    --aw-color-text-default: #E1D0BC;
    --aw-color-text-muted: #B9A287;
    --aw-color-bg-page: #1E1208;

    ::selection {
      background-color: #57401E;
      color: #E9E4D9;
    }
  }
</style>
