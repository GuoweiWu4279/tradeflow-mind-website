---
import Layout from '~/layouts/PageLayout.astro';
import HeroText from '~/components/widgets/HeroText.astro';
import Button from '~/components/ui/Button.astro';

import products from '~/data/products.json';

const metadata = {
  title: 'Start Free Trial — Meridian',
  description: 'Start your 7-day free trial of Meridian. Full access. Then $49.99/month. Cancel any time.',
};

const { price, currency, trialDays } = products.pricing;
const checkoutUrl = products.purchase.checkoutUrl;
const supportEmail = products.purchase.supportEmail;
---

<Layout metadata={metadata}>
  <HeroText
    tagline="Free trial"
    title="Start your 7-day free trial"
    subtitle={`Full access to Meridian. Then ${currency} $${price}/month — cancel any time.`}
  />

  <section class="max-w-4xl mx-auto px-6 pb-20">
    <div class="grid md:grid-cols-2 gap-8 items-start">

      <!-- Left: What you get + social proof -->
      <div class="space-y-6">
        <div>
          <h2 class="text-sm font-semibold text-zinc-900 mb-4">What's included in your trial</h2>
          <ul class="space-y-3">
            {[
              'Live PSI score (0–100) updated after every execution',
              'All seven behavioral dimension trackers',
              'Floating HUD overlay + full session hub',
              'Adaptive baselines that calibrate to your own patterns',
              '100% local — no cloud, no accounts, no network calls',
              'Market Replay support to train without affecting your live baseline',
            ].map((item) => (
              <li class="flex items-start gap-3 text-sm text-zinc-700">
                <span class="mt-0.5 flex h-5 w-5 shrink-0 items-center justify-center rounded-full bg-emerald-500">
                  <svg class="w-3 h-3 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7" />
                  </svg>
                </span>
                {item}
              </li>
            ))}
          </ul>
        </div>

        <div class="rounded-xl bg-zinc-50 border border-zinc-200 p-5">
          <p class="text-sm text-zinc-600 leading-relaxed">
            "been using it about 3 months. didn't realize how bad my overtrading was until i actually saw the numbers. first week of data was kind of humbling"
          </p>
          <p class="text-xs text-zinc-400 mt-3 font-medium">— Jason K., Futures day trader</p>
        </div>

        <div class="rounded-xl bg-zinc-50 border border-zinc-200 p-5">
          <p class="text-sm text-zinc-600 leading-relaxed">
            "passed apex eval on my 3rd attempt. first two i blew up on days i genuinely should've just logged off. not saying this is the reason but it helped me see the pattern"
          </p>
          <p class="text-xs text-zinc-400 mt-3 font-medium">— Mike, Prop firm trader</p>
        </div>
      </div>

      <!-- Right: CTA card -->
      <div class="rounded-2xl border border-emerald-200/80 bg-gradient-to-b from-white to-emerald-50/30 px-8 py-10 shadow-md text-center sticky top-24">
        <p class="text-xs font-semibold tracking-widest text-emerald-700 uppercase mb-4">Free trial</p>
        <div class="mb-2">
          <span class="text-5xl font-extrabold text-zinc-900">$0</span>
        </div>
        <p class="text-sm text-zinc-500 mb-1">for {trialDays} days</p>
        <p class="text-xs text-zinc-400 mb-8">then ${price}/month · cancel any time</p>

        <Button
          variant="primary"
          href={checkoutUrl}
          class="w-full px-8 py-3.5 rounded-full font-semibold text-base"
        >
          Start free trial — {trialDays} days
        </Button>

        <div class="mt-6 space-y-2.5 text-xs text-zinc-500">
          <p class="flex items-center justify-center gap-1.5">
            <svg class="w-3.5 h-3.5 text-emerald-600 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"/>
            </svg>
            Secure checkout via Whop
          </p>
          <p class="flex items-center justify-center gap-1.5">
            <svg class="w-3.5 h-3.5 text-emerald-600 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
            </svg>
            No charge during the {trialDays}-day trial
          </p>
          <p class="flex items-center justify-center gap-1.5">
            <svg class="w-3.5 h-3.5 text-emerald-600 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 10h10a8 8 0 018 8v2M3 10l6 6m-6-6l6-6"/>
            </svg>
            30-day money-back guarantee if it won't run
          </p>
        </div>

        <div class="mt-8 pt-6 border-t border-zinc-100 space-y-1.5">
          <p class="text-xs text-zinc-400">
            Already subscribed? <a href="/download" class="text-emerald-700 font-medium hover:underline">Go to downloads →</a>
          </p>
          <p class="text-xs text-zinc-400">
            Questions? <a href={`mailto:${supportEmail}`} class="underline hover:text-zinc-600">{supportEmail}</a>
          </p>
        </div>
      </div>
    </div>

    <p class="text-center text-xs text-zinc-400 mt-10 leading-relaxed max-w-xl mx-auto">
      NinjaTrader 8 required. Trading involves substantial risk of loss. Meridian is a behavioral monitor only and does not provide trading signals or investment advice.
    </p>
  </section>
</Layout>
