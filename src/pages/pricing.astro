---
import Layout from '~/layouts/PageLayout.astro';
import HeroText from '~/components/widgets/HeroText.astro';
import FAQs from '~/components/widgets/FAQs.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';
import { Icon } from 'astro-icon/components';

import pricing from '~/data/pricing.json';

const { singleTier, annualPreview, footnote, headline, subhead } = pricing;

const metadata = {
  title: 'Pricing — Meridian',
  description:
    'Meridian pricing: $24.99/month or $239.88/year after a 7-day free trial. Trading involves substantial risk.',
};

const features = singleTier.features;
---

<Layout metadata={metadata}>
  <HeroText tagline="Pricing" title={headline} subtitle={subhead} />

  <section class="max-w-lg mx-auto px-6 pb-6">

    <!-- Billing toggle -->
    <div class="flex items-center justify-center mb-10">
      <div class="relative flex items-center bg-zinc-100 rounded-full p-1 gap-1">
        <button
          id="btn-monthly"
          class="relative z-10 px-5 py-2 text-sm font-semibold rounded-full transition-all duration-200 bg-white text-zinc-900 shadow-sm"
        >
          Monthly
        </button>
        <button
          id="btn-annual"
          class="relative z-10 px-5 py-2 text-sm font-semibold rounded-full transition-all duration-200 text-zinc-500"
        >
          Annual
          <span
            id="save-badge"
            class="ml-2 inline-block rounded-full bg-emerald-100 text-emerald-700 text-xs font-semibold px-2 py-0.5 transition-opacity duration-200 opacity-100"
          >
            Save $60/yr
          </span>
        </button>
      </div>
    </div>

    <!-- Pricing card -->
    <div class="relative rounded-3xl border border-emerald-200/80 bg-gradient-to-b from-white to-emerald-50/40 shadow-lg shadow-emerald-900/5 px-8 py-10 text-center">

      <!-- Badge -->
      <span class="inline-block rounded-full bg-emerald-600 px-3 py-1 text-xs font-semibold uppercase tracking-wide text-white mb-4">
        7-day free trial
      </span>

      <!-- Price block -->
      <div class="mt-4 flex flex-col items-center gap-1 min-h-[96px]">
        <div class="flex items-baseline justify-center">
          <span class="text-3xl font-semibold text-zinc-900">$</span>
          <span id="price-display" class="text-6xl font-extrabold tracking-tight text-zinc-900 tabular-nums transition-all duration-150">
            {singleTier.price}
          </span>
          <span class="ml-1 text-lg font-medium text-zinc-500">/mo</span>
        </div>
        <div id="billing-note-monthly" class="text-sm text-zinc-500 mt-1">
          After 7-day free trial · cancel any time
        </div>
        <div id="billing-note-annual" class="text-sm text-zinc-500 mt-1 hidden">
          Billed at $239.88/year · <span class="text-emerald-700 font-semibold">save $60/year</span> vs monthly
        </div>
      </div>

      <!-- Features -->
      <ul class="mt-8 space-y-3 text-left max-w-md mx-auto">
        {
          features.map((line: string) => (
            <li class="flex gap-3 text-sm text-zinc-700">
              <span class="mt-0.5 flex h-5 w-5 shrink-0 items-center justify-center rounded-full bg-emerald-500">
                <Icon name="tabler:check" class="h-3.5 w-3.5 text-white" />
              </span>
              <span>{line}</span>
            </li>
          ))
        }
      </ul>

      <!-- CTA -->
      <div class="mt-10 flex flex-col items-center gap-3">
        <a
          id="cta-btn"
          href={singleTier.ctaHref}
          class="inline-flex items-center justify-center rounded-full bg-emerald-600 hover:bg-emerald-700 text-white px-8 py-3 text-base font-semibold transition-colors"
        >
          Start free trial
        </a>
        <p class="text-xs text-zinc-500">No payment required during trial</p>
        <a href="/download" class="text-sm text-emerald-700 font-medium hover:underline">
          Already subscribed? Go to downloads →
        </a>
      </div>
    </div>

    <p class="mt-8 text-center text-xs text-zinc-500 leading-relaxed max-w-xl mx-auto">
      {footnote}
      <a href="/disclaimer" class="underline text-emerald-800 hover:text-emerald-900"> Risk disclaimer</a>.
    </p>
  </section>

  <FAQs
    title="Billing and product questions"
    tagline=""
    classes={{ container: 'max-w-6xl' }}
    items={[
      {
        title: 'How does the free trial work?',
        description:
          'Your first seven days include full access to Meridian at no cost. If you choose to continue afterward, you pay the plan rate you selected — monthly or annual. You may cancel during the trial at any time and no charge applies.',
      },
      {
        title: 'What is the difference between monthly and annual?',
        description:
          'Same full product, same features. Monthly is $24.99/month billed every month. Annual is $239.88 billed once per year — about $19.99/month — saving around $60 versus paying monthly. Both include a 7-day free trial.',
      },
      {
        title: 'Can I cancel at any time?',
        description:
          'Yes. Cancel during the trial and you will not be charged at all. Cancel an active subscription whenever you like and you retain access through the end of the period you have already paid for. To cancel, visit the Lemon Squeezy customer portal at app.lemonsqueezy.com/my-orders — enter the email you used at checkout and you will receive a sign-in link.',
      },
      {
        title: 'What payment methods are accepted?',
        description:
          'Checkout is processed securely by Lemon Squeezy. Major credit and debit cards (Visa, Mastercard, American Express) and PayPal are supported. We do not store your full card details on our own systems.',
      },
      {
        title: 'What does the refund policy cover?',
        description:
          'Please see our Refund Policy for the full terms. In general, it explains how we handle installation or technical issues on supported setups, and how courtesy refunds work within the stated time frames.',
      },
      {
        title: 'What does PSI measure — and can it predict profits?',
        description:
          'PSI summarizes behavioral-stability signals from your live session using the patterns Meridian is designed to monitor. It is a risk-awareness and discipline tool, not a forecast of trading results, and it is not investment advice. Trading involves substantial risk of loss; many factors beyond psychology determine outcomes.',
      },
    ]}
  />

  <CallToAction
    actions={[
      {
        variant: 'primary',
        text: singleTier.cta,
        href: singleTier.ctaHref,
        icon: 'tabler:player-play',
      },
      { text: 'System requirements', href: '/download' },
    ]}
  >
    <Fragment slot="title">Try Meridian free for seven days</Fragment>
    <Fragment slot="subtitle">
      Full product access during the trial. Monthly at $24.99 or annual at $239.88/year. NinjaTrader 8 is required.
    </Fragment>
  </CallToAction>
</Layout>

<script>
  const btnMonthly = document.getElementById('btn-monthly') as HTMLButtonElement;
  const btnAnnual  = document.getElementById('btn-annual')  as HTMLButtonElement;
  const priceDisplay = document.getElementById('price-display') as HTMLElement;
  const noteMonthly  = document.getElementById('billing-note-monthly') as HTMLElement;
  const noteAnnual   = document.getElementById('billing-note-annual')  as HTMLElement;
  const ctaBtn = document.getElementById('cta-btn') as HTMLAnchorElement;

  const MONTHLY_PRICE  = '24.99';
  const ANNUAL_PRICE   = '19.99';
  const MONTHLY_URL = 'https://meridianpsi.lemonsqueezy.com/checkout/buy/b7b8b514-fefa-4a34-8cad-d2e68f564d25';
  const ANNUAL_URL  = 'https://meridianpsi.lemonsqueezy.com/checkout/buy/04e32f4e-a20e-469f-ba4e-274d381739c6';

  function setMonthly() {
    priceDisplay.textContent = MONTHLY_PRICE;
    ctaBtn.href = MONTHLY_URL;
    noteMonthly.classList.remove('hidden');
    noteAnnual.classList.add('hidden');
    btnMonthly.classList.add('bg-white', 'text-zinc-900', 'shadow-sm');
    btnMonthly.classList.remove('text-zinc-500');
    btnAnnual.classList.remove('bg-white', 'text-zinc-900', 'shadow-sm');
    btnAnnual.classList.add('text-zinc-500');
  }

  function setAnnual() {
    priceDisplay.textContent = ANNUAL_PRICE;
    ctaBtn.href = ANNUAL_URL;
    noteAnnual.classList.remove('hidden');
    noteMonthly.classList.add('hidden');
    btnAnnual.classList.add('bg-white', 'text-zinc-900', 'shadow-sm');
    btnAnnual.classList.remove('text-zinc-500');
    btnMonthly.classList.remove('bg-white', 'text-zinc-900', 'shadow-sm');
    btnMonthly.classList.add('text-zinc-500');
  }

  btnMonthly.addEventListener('click', setMonthly);
  btnAnnual.addEventListener('click', setAnnual);
</script>
