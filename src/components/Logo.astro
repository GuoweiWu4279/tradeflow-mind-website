---
import { SITE } from 'astrowind:config';

interface Props {
  /** 'header' = nav bar; 'compact' = footer / tight spaces */
  variant?: 'header' | 'compact';
}

const { variant = 'header' } = Astro.props;
const name = SITE?.name ?? 'Meridian';

const sizeClass =
  variant === 'compact'
    ? 'h-7 md:h-8 w-auto max-w-[200px] object-contain object-left'
    : 'h-10 md:h-12 w-auto max-w-[240px] sm:max-w-none object-contain object-left';
---

<img
  src="/meridian-logo.png"
  alt={`${name} — home`}
  class:list={[sizeClass, 'self-center']}
  width="220"
  height="48"
  loading="eager"
  decoding="async"
/>
