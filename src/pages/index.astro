<style>
  /* ——— Marquee ——— */
  .marquee-left { animation: marquee-left 160s linear infinite; }
  .marquee-right { animation: marquee-right 160s linear infinite; }
  @keyframes marquee-left {
    from { transform: translateX(0); }
    to   { transform: translateX(-50%); }
  }
  @keyframes marquee-right {
    from { transform: translateX(-50%); }
    to   { transform: translateX(0); }
  }
  @media (prefers-reduced-motion: reduce) {
    .marquee-left,
    .marquee-right {
      animation: none;
    }
  }

  /* ——— Accordion items (step-detail) ——— */
  .acc-item {
    border-radius: 0.75rem;
    border: 1px solid transparent;
    cursor: pointer;
    transition: background-color 0.2s ease, border-color 0.2s ease, box-shadow 0.2s ease;
    outline: none;
  }
  .acc-item-num {
    color: #4b734e;
    letter-spacing: 0.08em;
  }
  .acc-item:focus-visible { box-shadow: 0 0 0 2px #4b734e; }
  .acc-item-title { color: #52525b; transition: color 0.2s ease; }
  .acc-item-icon {
    background: rgba(75, 115, 78, 0.12);
    color: #4b734e;
    transition: background-color 0.2s ease, color 0.2s ease;
  }
  .acc-item-body {
    transition: max-height 0.38s cubic-bezier(0.4, 0, 0.2, 1);
    max-height: 0;
  }
  .acc-chevron {
    color: rgba(0,0,0,0.18);
    opacity: 0;
    transform: translateX(-6px);
    transition: opacity 0.2s ease, transform 0.2s ease, color 0.2s ease;
  }
  /* Active state */
  .acc-item-active {
    background: white;
    border-color: #4b734e;
    box-shadow: 0 2px 16px rgba(75, 115, 78, 0.12);
  }
  .acc-item-active .acc-item-title { color: #18181b; }
  .acc-item-active .acc-item-num { color: #4b734e; }
  .acc-item-active .acc-item-icon { background: #4b734e; color: white; }
  .acc-item-active .acc-chevron { opacity: 1; transform: translateX(0); color: rgba(0,0,0,0.3); }
  /* Hover */
  .acc-item:not(.acc-item-active):hover { background: rgba(0,0,0,0.025); border-color: rgba(0,0,0,0.08); }
  .acc-item:not(.acc-item-active):hover .acc-item-title { color: #18181b; }

  /* Image cross-fade — absolute stacking inside square container */
  .acc-img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: contain;
    transition: opacity 0.4s ease;
    opacity: 0;
  }

  /* ——— Word-blur animation ——— */
  .word-blur-word {
    display: inline-block;
    opacity: 0;
    filter: blur(8px);
  }
  .word-blur-done .word-blur-word {
    animation: wordReveal 0.45s ease forwards;
  }
  @keyframes wordReveal {
    to { opacity: 1; filter: blur(0px); }
  }
  @media (prefers-reduced-motion: reduce) {
    .word-blur-word { opacity: 1; filter: blur(0); }
    .word-blur-done .word-blur-word { animation: none; }
  }
</style>

<script>
  // ——— Scroll-triggered fade-up ———
  function initFadeUp() {
    const els = document.querySelectorAll<HTMLElement>('.fade-up');
    if (!els.length || !('IntersectionObserver' in window)) {
      els.forEach((el) => el.classList.add('is-visible'));
      return;
    }
    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add('is-visible');
            observer.unobserve(entry.target);
          }
        });
      },
      { threshold: 0.08, rootMargin: '0px 0px -40px 0px' }
    );
    els.forEach((el) => observer.observe(el));
  }

  // ——— Word-blur animation ———
  // Uses TreeWalker to wrap only text nodes, preserving all HTML tags intact
  function initWordBlur() {
    const targets = document.querySelectorAll<HTMLElement>('.word-blur-target');
    if (!('IntersectionObserver' in window)) {
      targets.forEach((el) => el.classList.add('word-blur-done'));
      return;
    }
    targets.forEach((el) => {
      const walker = document.createTreeWalker(el, NodeFilter.SHOW_TEXT);
      const textNodes: Text[] = [];
      let node: Text | null;
      while ((node = walker.nextNode() as Text | null)) {
        if (node.nodeValue && node.nodeValue.trim()) textNodes.push(node);
      }
      let wordIdx = 0;
      textNodes.forEach((textNode) => {
        const text = textNode.nodeValue || '';
        const parts = text.split(/(\s+)/);
        const frag = document.createDocumentFragment();
        parts.forEach((part) => {
          if (/^\s+$/.test(part) || part === '') {
            frag.appendChild(document.createTextNode(part));
          } else {
            const span = document.createElement('span');
            span.className = 'word-blur-word';
            span.style.animationDelay = `${wordIdx++ * 45}ms`;
            span.textContent = part;
            frag.appendChild(span);
          }
        });
        textNode.parentNode?.replaceChild(frag, textNode);
      });
    });
    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add('word-blur-done');
            observer.unobserve(entry.target);
          }
        });
      },
      { threshold: 0.1 }
    );
    targets.forEach((el) => observer.observe(el));
    // Hero heading is already visible — trigger immediately
    const hero = document.querySelector('.word-blur-target') as HTMLElement | null;
    if (hero) hero.classList.add('word-blur-done');
  }

  // ——— Accordion (step-detail) ———
  function initAccordion() {
    const items = Array.from(document.querySelectorAll<HTMLElement>('[data-acc-item]'));
    const images = Array.from(document.querySelectorAll<HTMLImageElement>('[data-step-img]'));
    if (!items.length) return;
    let current = 0;

    function activate(next: number) {
      if (next === current) return;

      // Opacity-only crossfade (images are absolutely stacked)
      if (images[current]) images[current].style.opacity = '0';
      if (images[next]) images[next].style.opacity = '1';

      // Update accordion items
      items.forEach((item, i) => {
        const isActive = i === next;
        item.classList.toggle('acc-item-active', isActive);
        item.setAttribute('tabindex', isActive ? '0' : '-1');
        const body = item.querySelector<HTMLElement>('.acc-item-body');
        if (body) body.style.maxHeight = isActive ? body.scrollHeight + 'px' : '0';
      });

      current = next;
    }

    // Click & keyboard
    items.forEach((item, i) => {
      item.addEventListener('click', () => activate(i));
      item.addEventListener('keydown', (e) => {
        if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); activate(i); }
        else if (e.key === 'ArrowDown') { e.preventDefault(); activate((i + 1) % items.length); }
        else if (e.key === 'ArrowUp') { e.preventDefault(); activate((i - 1 + items.length) % items.length); }
      });
    });

    // Init: first image visible, rest hidden; first accordion body open
    images.forEach((img, i) => { img.style.opacity = i === 0 ? '1' : '0'; });
    const firstBody = items[0]?.querySelector<HTMLElement>('.acc-item-body');
    if (firstBody) firstBody.style.maxHeight = firstBody.scrollHeight + 'px';
  }

  function boot() {
    initFadeUp();
    initWordBlur();
    initAccordion();
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', boot);
  } else {
    boot();
  }
</script>
