---
import Layout from '~/layouts/PageLayout.astro';

import Hero from '~/components/widgets/Hero.astro';
import Stats from '~/components/widgets/Stats.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';

const metadata = {
  title: 'Meridian — The First Real-Time Psychological Stability Index for Active Traders',
  ignoreTitleTemplate: true,
};

const marqueeRow1 = [
  {
    quote: "Three months in. I thought I had clean execution — the overtrading metric disagreed from day one.",
    name: 'Jason K.',
    role: 'Futures day trader',
  },
  {
    quote: "Passed my third Apex evaluation. The first two I blew up on days where, in hindsight, I should have just closed the platform.",
    name: 'Mike R.',
    role: 'Prop firm trader',
  },
  {
    quote: "Turned out I wasn't losing because of my entries. I was adding to losing positions and ignoring my own rules.",
    name: 'Anonymous',
    role: '',
  },
  {
    quote: "Didn't want another subscription. Tried the trial anyway. Kept it — the overlay is actually readable mid-session without being in the way.",
    name: 'Rina M.',
    role: 'Day trader',
  },
];

const marqueeRow2 = [
  {
    quote: "The caution signal fired and I decided I could manage through it. Twenty minutes later I had hit my daily limit. I can't blame the tool — I ignored it.",
    name: 'Sara',
    role: 'ES trader',
  },
  {
    quote: "If someone had told me a revenge-entry detector would matter more than another indicator, I wouldn't have believed them.",
    name: 'Alex Nowak',
    role: 'Prop trader',
  },
  {
    quote: "Four years trading NQ. Thought I had a solid read on my own behavior. First week of data showed me several habits I wasn't aware of.",
    name: 'James O.',
    role: 'Day trader',
  },
  {
    quote: "Took a few sessions to calibrate. Once it did, the alerts started making sense — I could trace each one back to a specific pattern.",
    name: 'Priya S.',
    role: 'Futures trader',
  },
];

const steps = [
  {
    label: 'Configure',
    desc: 'Set your rules once',
    fullDesc: 'Your profile defines how Meridian reads your behavior — position limits, session windows, stop conventions. Every alert is personalized to your declared rules, not a generic threshold.',
    bullets: ['Session rules & time windows', 'Position size limits and stop conventions', 'Profile settings per account', 'Personal baseline adapts with each session'],
    image: '/screenshots/baseline-learning.png',
    imgAlt: 'Meridian personal baseline configuration panel',
    icon: '<svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z" /><path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" /></svg>',
  },
  {
    label: 'Live Monitor',
    desc: 'PSI updates in <100ms',
    fullDesc: 'PSI updates within 100ms of every fill, every stop move, every size decision. Seven behavioral signal bars show exactly what is affecting the score right now.',
    bullets: ['PSI score updates after every action in <100ms', 'Seven behavioral signal bars visible while trading', 'Floating HUD overlay — stays readable mid-session', 'Session stats: trades, win rate, alerts, duration'],
    image: '/screenshots/psi-critical.png',
    imgAlt: 'Meridian PSI Monitor showing a Critical score with seven behavioral signal bars',
    icon: '<svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z" /></svg>',
  },
  {
    label: 'Guard',
    desc: 'Automated enforcement',
    fullDesc: 'Guard is a commitment device. When you are calm, you write the rules. When the moment comes, Guard enforces them automatically — no decision required from you.',
    bullets: ['6 configurable trigger conditions', '5 response levels — quiet toast to full broker disconnect', 'Set once, active every session automatically', 'No manual override required in the heat of the moment'],
    image: '/screenshots/psi-performance.png',
    imgAlt: 'Meridian PSI vs P&L correlation chart',
    link: { href: '/guard', text: 'Explore Meridian Guard' },
    icon: '<svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" /></svg>',
  },
  {
    label: 'Review & Intel',
    desc: 'Patterns across sessions',
    fullDesc: 'Every session is saved with PSI score, Composure, and trade stats. Over months, behavioral patterns become visible — and so does the improvement.',
    bullets: ['Session log: PSI, Composure, and trade stats', 'Monthly behavioral grade and P&L correlation', "Today's Risk Brief — built from your own history", '5 years of session history stored locally'],
    image: '/screenshots/intel-session-calendar.png',
    imgAlt: 'Meridian session calendar showing PSI, Composure and P&L per session',
    icon: '<svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 17v-2m3 2v-4m3 4v-6m2 10H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" /></svg>',
  },
];

const signals = [
  { name: 'Revenge Entry',     desc: 'Re-entry after loss with elevated size' },
  { name: 'Stop Manipulation', desc: 'Widening stops in the adverse direction' },
  { name: 'Size Spike',        desc: 'Position exceeds your declared rule' },
  { name: 'Hold Bias',         desc: 'Abnormal hold duration vs your baseline' },
  { name: 'Position Overstay', desc: 'Holding a loser past your 90th-percentile time' },
  { name: 'Rule Violations',   desc: 'Trading outside your declared session rules' },
  { name: 'Overtrading Pace',  desc: 'Entry frequency accelerating vs history' },
];
---

<Layout metadata={metadata}>
  <!-- ——— HERO — light, clean ——— -->
  <section class="relative overflow-hidden md:-mt-[76px] not-prose" style="background: #EBE9E4;">
    <!-- Header spacer -->
    <div class="md:pt-[76px]"></div>
    <div class="relative max-w-6xl mx-auto px-6">
      <div class="pt-20 pb-24 md:pt-32 md:pb-32 lg:pt-40 lg:pb-40">
        <div class="text-center max-w-4xl mx-auto">
          <!-- Eyebrow badge -->
          <div class="inline-flex items-center gap-2.5 border px-4 py-1.5 mb-8 fade-up rounded-full" style="border-color: rgba(221,185,24,0.7); background: rgba(221,185,24,0.1);">
            <span class="w-1.5 h-1.5 rounded-full" style="background:#DDB918;" aria-hidden="true"></span>
            <span class="text-[11px] font-semibold tracking-[0.15em] uppercase" style="color:#073460;">Trading psychology monitor</span>
          </div>
          <!-- Title with word-blur animation -->
          <h1 class="text-5xl md:text-6xl lg:text-[4.25rem] font-bold leading-[1.08] tracking-tight mb-6 word-blur-target" style="color:#073460;">
            Every trader has a plan. The market's job is to make you forget it.
          </h1>
          <!-- Subtitle -->
          <p class="text-base md:text-lg leading-relaxed max-w-2xl mx-auto mb-10 fade-up" style="color:#356197;">
            <strong style="color:#073460; font-weight:600;">Meridian</strong> is the first real-time behavioral and psychological stability monitor for active traders. Seven behavioral patterns, grounded in cognitive science. PSI updates in under 100ms.
          </p>
          <!-- CTAs -->
          <div class="flex flex-col sm:flex-row sm:justify-center gap-3 fade-up">
            <a href="/pricing" class="btn btn-lg font-semibold" style="background:#073460; color:#EBE9E4; border:1px solid #073460;">Start free trial</a>
            <a href="#how-it-works" class="btn btn-lg font-semibold" style="border:1px solid rgba(7,52,96,0.3); color:#073460; background:transparent;">How it works</a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Stats bar -->
  <section class="px-6 fade-up">
    <div class="max-w-6xl mx-auto">
      <Stats
        stats={[
          { title: 'Live behavioral signals', amount: '7' },
          { title: 'Update latency', amount: '<100ms' },
          { title: 'Session history', amount: '5 yr' },
          { title: 'Free trial', amount: '7 day' },
        ]}
      />
    </div>
  </section>

  <!-- ——— PROBLEM — light centered ——— -->
  <section class="relative py-24 md:py-32 px-6" style="background:#E1DFDB; border-top:1px solid rgba(7,52,96,0.08); border-bottom:1px solid rgba(7,52,96,0.08);">
    <div class="relative max-w-3xl mx-auto text-center">
      <!-- Eyebrow badge -->
      <div class="inline-flex items-center gap-2.5 border px-4 py-1.5 mb-8 rounded-full" style="border-color: rgba(221,185,24,0.7); background: rgba(221,185,24,0.1);">
        <span class="w-1.5 h-1.5 rounded-full" style="background:#DDB918;" aria-hidden="true"></span>
        <span class="text-[11px] font-semibold tracking-[0.15em] uppercase" style="color:#073460;">The Problem</span>
      </div>
      <!-- Heading with word-blur animation -->
      <h2 class="text-4xl md:text-5xl lg:text-6xl font-bold leading-[1.1] tracking-tight mb-6 word-blur-target" style="color:#073460;">
        Institutional traders have risk managers. You have yourself.
      </h2>
      <!-- Body -->
      <p class="text-base md:text-lg leading-relaxed mb-10 max-w-2xl mx-auto" style="color:#356197;">
        Compliance officers, position limits, systems enforcing rules outside their control.
        Retail traders have experience and hard-won rules — and nothing to stop them from breaking those rules
        the moment it matters most. Meridian is that system.
      </p>
      <!-- CTAs -->
      <div class="flex flex-col sm:flex-row sm:justify-center gap-4">
        <a href="/pricing" class="btn btn-lg font-semibold" style="background:#073460; color:#EBE9E4; border:1px solid #073460;">Start free trial</a>
        <a href="#step-detail" class="btn btn-lg font-semibold" style="border:1px solid rgba(7,52,96,0.3); color:#073460; background:transparent;">See Meridian in action</a>
      </div>
    </div>
  </section>

  <!-- ——— ROADMAP / HOW IT WORKS ——— -->
  <section id="how-it-works" class="section bg-zinc-50 dark:bg-zinc-900/40 border-y border-zinc-100 dark:border-zinc-800">
    <div class="container-wide">
      <div class="text-center mb-20 max-w-2xl mx-auto">
        <p class="eyebrow mb-4 fade-up">How it works</p>
        <h2 class="text-3xl md:text-5xl font-bold tracking-tight text-zinc-900 dark:text-zinc-100 mb-5 fade-up">
          Before. During. After. Every session.
        </h2>
        <p class="lead fade-up">
          Meridian fits into every stage of how you trade — from setup, to real-time monitoring and
          automatic guardrails, to post-session review.
        </p>
      </div>

      <!-- 4-step roadmap -->
      <div class="relative">
        <!-- dotted connector line (desktop) -->
        <div
          class="hidden md:block absolute top-6 left-[12.5%] right-[12.5%] border-t border-dashed border-zinc-300 dark:border-zinc-700"
          aria-hidden="true"
        ></div>

        <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-4 gap-6">
          {[
            { num: '01', title: 'Configure',     sub: 'Any strategy. Any style.',      bullets: ['Session rules & time windows', 'Size limits and stop conventions', 'Profile settings per account'] },
            { num: '02', title: 'Live Monitor',  sub: '7 signals. <100ms updates.',    bullets: ['PSI score updates in real time', 'Seven behavioral signal bars', 'Floating HUD overlay'] },
            { num: '03', title: 'Guard',         sub: 'Rules that enforce themselves.', bullets: ['6 trigger conditions', '5 response levels', 'Toast to broker disconnect'] },
            { num: '04', title: 'Review & Intel', sub: 'Every session. Every pattern.', bullets: ['PSI, Composure, and trade stats', 'Monthly digest & P&L correlation', "Today's Risk Brief"] },
          ].map((step, i) => (
            <div class="fade-up" style={`transition-delay:${i * 80}ms`}>
              <!-- Number disc -->
              <div class="relative z-10 mx-auto w-12 h-12 rounded-full bg-white dark:bg-zinc-950 border border-zinc-200 dark:border-zinc-800 flex items-center justify-center mb-5 text-sm font-semibold tracking-tight text-zinc-900 dark:text-zinc-100">
                {step.num}
              </div>
              <div class="text-center mb-5">
                <h3 class="text-base font-semibold text-zinc-900 dark:text-zinc-100 mb-1">{step.title}</h3>
                <p class="text-sm text-zinc-500 dark:text-zinc-400">{step.sub}</p>
              </div>
              <ul class="card card-hover p-5 space-y-2.5">
                {step.bullets.map((b) => (
                  <li class="flex items-start gap-2.5 text-sm text-zinc-600 dark:text-zinc-300">
                    <svg class="mt-0.5 w-4 h-4 text-emerald-600 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7" />
                    </svg>
                    <span>{b}</span>
                  </li>
                ))}
              </ul>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- ——— STEP DETAIL — light accordion + cross-fade image ——— -->
  <section id="step-detail" class="py-20 lg:py-28 px-6" style="background:#EBE9E4; border-top:1px solid rgba(7,52,96,0.08); border-bottom:1px solid rgba(7,52,96,0.08);">
    <div class="max-w-6xl mx-auto">

      <!-- Section header -->
      <div class="max-w-xl mb-12 lg:mb-16">
        <div class="inline-flex items-center gap-2.5 border px-4 py-1.5 mb-6 rounded-full" style="border-color:rgba(221,185,24,0.7); background:rgba(221,185,24,0.1);">
          <span class="w-1.5 h-1.5 rounded-full" style="background:#DDB918;" aria-hidden="true"></span>
          <span class="text-[11px] font-semibold tracking-[0.15em] uppercase" style="color:#073460;">See it in action</span>
        </div>
        <h2 class="text-4xl md:text-5xl font-bold leading-[1.1] tracking-tight mb-4 word-blur-target" style="color:#073460;">
          Pick a stage. See what you'd get.
        </h2>
        <p class="text-base leading-relaxed" style="color:#356197;">
          Four core stages. Each solves a distinct part of the psychological consistency problem.
        </p>
      </div>

      <!-- Grid: left = cross-fade image, right = accordion -->
      <div class="lg:grid lg:grid-cols-[55%_45%] lg:gap-14 items-start">

        <!-- Left: image display — fixed square, black fill, object-contain, cross-fade -->
        <div class="relative overflow-hidden rounded-xl mb-8 lg:mb-0" style="background:#000; aspect-ratio:1/1; border:1px solid rgba(7,52,96,0.12);">
          {steps.map((step, i) => (
            <img
              data-step-img={i}
              src={step.image}
              alt={step.imgAlt}
              class="acc-img"
              loading="lazy"
            />
          ))}
        </div>

        <!-- Right: accordion items -->
        <div class="space-y-1 lg:pt-2" role="list" aria-label="Product stages">
          {steps.map((step, i) => (
            <div
              data-acc-item={i}
              role="listitem"
              class:list={['acc-item', { 'acc-item-active': i === 0 }]}
              tabindex="0"
            >
              <div class="flex items-start gap-4 p-5">
                <!-- Icon disc -->
                <div class="acc-item-icon flex-shrink-0 p-2 rounded-lg mt-0.5" aria-hidden="true" set:html={step.icon} />
                <!-- Text content -->
                <div class="flex-1 min-w-0">
                  <h3 class="acc-item-title text-lg font-semibold">
                    <span class="acc-item-num text-xs font-medium tracking-widest mr-1" style="opacity:0.4;">0{i + 1} —</span>
                    {step.label}
                  </h3>
                  <!-- Expandable body -->
                  <div class="acc-item-body overflow-hidden" style="max-height:0;">
                    <p class="text-sm leading-relaxed mt-2 mb-4" style="color:#356197;">{step.fullDesc}</p>
                    <ul class="space-y-1.5 text-sm mb-2" style="color:#073460;">
                      {step.bullets.map((b) => (
                        <li class="flex items-start gap-2.5">
                          <span class="mt-[7px] w-1 h-1 rounded-full shrink-0" style="background:#DDB918;"></span>
                          <span set:html={b} />
                        </li>
                      ))}
                    </ul>
                    {step.link && (
                      <a href={step.link.href} class="inline-flex items-center gap-1.5 text-sm font-medium mt-3 transition-colors" style="color:#073460;">
                        {step.link.text}
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" /></svg>
                      </a>
                    )}
                  </div>
                </div>
                <!-- Chevron -->
                <svg class="acc-chevron w-5 h-5 shrink-0 mt-1.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
                </svg>
              </div>
            </div>
          ))}
        </div>

      </div>
    </div>
  </section>

  <!-- ——— SEVEN DIMENSIONS ——— -->
  <section class="section bg-zinc-50 dark:bg-zinc-900/40 border-y border-zinc-100 dark:border-zinc-800">
    <div class="container-wide">
      <div class="text-center max-w-2xl mx-auto mb-16">
        <p class="eyebrow mb-4 fade-up">Behavioral signals</p>
        <h2 class="text-3xl md:text-5xl font-bold tracking-tight text-zinc-900 dark:text-zinc-100 mb-5 fade-up">
          Seven patterns. Each tied to a known failure mode.
        </h2>
        <p class="lead fade-up">
          Every signal tracks a behavioral pattern from behavioral-finance research. They run
          independently and combine into a single PSI score.
        </p>
      </div>

      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-3 fade-up">
        {signals.map((s, i) => (
          <div class="card card-hover p-5 flex items-start gap-4">
            <span class="shrink-0 mt-0.5 w-7 h-7 rounded-lg bg-emerald-50 dark:bg-emerald-900/30 text-emerald-700 dark:text-emerald-400 text-xs font-semibold flex items-center justify-center">
              {String(i + 1).padStart(2, '0')}
            </span>
            <div>
              <h3 class="text-sm font-semibold text-zinc-900 dark:text-zinc-100 mb-1">{s.name}</h3>
              <p class="text-sm text-zinc-500 dark:text-zinc-400 leading-relaxed">{s.desc}</p>
            </div>
          </div>
        ))}
      </div>

      <div class="text-center mt-10">
        <a href="/features#seven-dimensions" class="btn-tertiary">
          Read the technical detail
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" /></svg>
        </a>
      </div>
    </div>
  </section>

  <!-- ——— SESSION HISTORY — before / after comparison ——— -->
  <section class="section">
    <div class="container-wide">
      <div class="text-center max-w-2xl mx-auto mb-16">
        <p class="eyebrow mb-4 fade-up">Session review and history</p>
        <h2 class="text-3xl md:text-5xl font-bold tracking-tight text-zinc-900 dark:text-zinc-100 mb-5 fade-up">
          Not just P&amp;L. Whether you traded right.
        </h2>
        <p class="lead fade-up">
          Meridian tracks discipline session by session. Over time, the pattern becomes visible — and
          so does the improvement.
        </p>
      </div>

      <div class="grid md:grid-cols-2 gap-8 fade-up">
        <!-- Before -->
        <div>
          <div class="rounded-2xl overflow-hidden border border-zinc-200 dark:border-zinc-800">
            <img src="/screenshots/session-log-december.png" alt="Session log December 2025 — Composure 49%, average P&amp;L -$629" class="w-full h-auto block" loading="lazy" />
          </div>
          <div class="mt-4 flex items-center flex-wrap gap-2">
            <span class="text-xs font-semibold px-2.5 py-1 rounded-md bg-zinc-100 dark:bg-zinc-800 text-zinc-700 dark:text-zinc-300">Month 1 — Dec 2025</span>
            <span class="text-sm text-zinc-500 dark:text-zinc-400">Composure <span class="text-zinc-900 dark:text-zinc-100 font-semibold">49%</span></span>
            <span class="text-zinc-300 dark:text-zinc-600">·</span>
            <span class="text-sm text-zinc-500 dark:text-zinc-400">Avg P&amp;L <span class="text-zinc-900 dark:text-zinc-100 font-semibold">&minus;$629</span></span>
          </div>
        </div>

        <!-- After -->
        <div>
          <div class="rounded-2xl overflow-hidden border border-zinc-200 dark:border-zinc-800">
            <img src="/screenshots/session-log-april.png" alt="Session log April 2026 — Composure 79%, average P&amp;L +$997" class="w-full h-auto block" loading="lazy" />
          </div>
          <div class="mt-4 flex items-center flex-wrap gap-2">
            <span class="text-xs font-semibold px-2.5 py-1 rounded-md bg-emerald-50 dark:bg-emerald-900/30 text-emerald-700 dark:text-emerald-400">Month 5 — Apr 2026</span>
            <span class="text-sm text-zinc-500 dark:text-zinc-400">Composure <span class="text-emerald-700 dark:text-emerald-400 font-semibold">79%</span></span>
            <span class="text-zinc-300 dark:text-zinc-600">·</span>
            <span class="text-sm text-zinc-500 dark:text-zinc-400">Avg P&amp;L <span class="text-emerald-700 dark:text-emerald-400 font-semibold">+$997</span></span>
          </div>
        </div>
      </div>

      <p class="text-center text-xs text-zinc-500 dark:text-zinc-400 mt-8 italic">
        Illustrative data from a single user's history. Results may vary. Trading involves substantial risk of loss.
      </p>
    </div>
  </section>

  <!-- ——— INTEL — small grid, not full carousel ——— -->
  <section class="section bg-zinc-50 dark:bg-zinc-900/40 border-y border-zinc-100 dark:border-zinc-800">
    <div class="container-wide">
      <div class="text-center max-w-2xl mx-auto mb-16">
        <p class="eyebrow mb-4 fade-up">Intel layer</p>
