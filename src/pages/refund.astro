---
import Layout from '~/layouts/PageLayout.astro';
import HeroText from '~/components/widgets/HeroText.astro';

const metadata = {
  title: 'Refund Policy — Meridian',
  description: '30-day money-back guarantee policy for Meridian.',
};
---

<Layout metadata={metadata}>
  <HeroText
    title="Refund Policy"
    subtitle="We stand behind our software with a 30-day money-back guarantee."
  />

  <section class="max-w-4xl mx-auto px-6 pb-20 prose dark:prose-invert prose-headings:font-semibold prose-a:text-blue-600 dark:prose-a:text-blue-400">

    <div class="not-prose bg-green-50 dark:bg-green-950/30 border border-green-200 dark:border-green-800 rounded-xl p-6 mb-10">
      <p class="text-green-900 dark:text-green-200 font-semibold">
        30-Day Money-Back Guarantee — No questions asked if the software fails to run on a supported system.
      </p>
    </div>

    <h2>Eligibility for Refund</h2>
    <p>You are eligible for a full refund within <strong>30 days of purchase</strong> if:</p>
    <ul>
      <li>Meridian fails to install correctly on a system meeting the published minimum requirements</li>
      <li>The software produces a consistent, reproducible critical error that prevents basic functionality</li>
      <li>You have contacted support and we have been unable to resolve the issue within 7 business days</li>
    </ul>

    <h2>Change-of-Mind Requests</h2>
    <p>
      If you start the trial and decide Meridian isn't for you, simply cancel before the trial ends — you will not be charged. If you have been charged and contact us within <strong>24 hours</strong> of the first charge, we will issue a full refund as a courtesy, no questions asked.
    </p>
    <p>Refund requests are not accepted for:</p>
    <ul>
      <li>Requests made more than 24 hours after the billing date, where no technical issue is present</li>
      <li>Dissatisfaction with trading outcomes or P&amp;L results (Meridian is a psychology monitoring tool, not a signal provider)</li>
      <li>Requests made after the 30-day window has elapsed</li>
    </ul>

    <h2>How to Request a Refund</h2>
    <p>To request a refund, email <a href="mailto:contactmeridianpsi@gmail.com">contactmeridianpsi@gmail.com</a> with:</p>
    <ol>
      <li>Your order number or receipt</li>
      <li>A brief description of the issue you encountered</li>
      <li>The NinjaTrader version and Windows version you are running</li>
    </ol>
    <p>We will respond within 2 business days and process approved refunds within 5–10 business days via the original payment method.</p>

    <h2>Subscription Cancellation</h2>
    <p>
      Monthly and annual subscriptions can be cancelled at any time from your account dashboard. Cancellation stops future billing. You retain access to the software until the end of your current paid period. Cancellation does not automatically trigger a refund — refund eligibility follows the criteria above.
    </p>

    <p class="text-sm text-zinc-500 dark:text-zinc-400 mt-10 border-t pt-6">
      Last updated: April 2026.
    </p>

  </section>
</Layout>
