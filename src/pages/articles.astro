---
import Layout from '~/layouts/PageLayout.astro';
import { getCollection } from 'astro:content';
import { getPermalink } from '~/utils/permalinks';
import { findImage } from '~/utils/images';

const metadata = {
  title: 'Trading Insights — Meridian',
  description: 'In-depth articles on trading psychology, risk management, and execution discipline for active futures traders.',
  robots: { index: true, follow: true },
};

const allPosts = await getCollection('post');

const templateIds = [
  'astrowind-template-in-depth',
  'get-started-website-with-astro-tailwind-css',
  'how-to-customize-astrowind-to-your-brand',
  'useful-resources-to-create-websites',
  'markdown-elements-demo-post',
  'landing',
];

const posts = await Promise.all(
  allPosts
    .filter((p) => !p.data.draft && !templateIds.includes(p.id))
    .sort((a, b) => {
      const da = a.data.publishDate ? new Date(a.data.publishDate).valueOf() : 0;
      const db = b.data.publishDate ? new Date(b.data.publishDate).valueOf() : 0;
      return db - da;
    })
    .map(async (post) => ({
      ...post,
      resolvedImage: post.data.image ? await findImage(post.data.image) : null,
    }))
);

const categoryMap: Record<string, string> = {
  'trading-psychology': 'Trading Psychology',
  'risk-management':    'Risk Management',
  'prop-trading':       'Prop Trading',
  'execution':          'Execution',
};

const categories = [...new Set(posts.map((p) => p.data.category).filter(Boolean))];

function readingTime(body: string) {
  return Math.max(1, Math.ceil(body.split(/\s+/).length / 220));
}
function formatDate(d?: Date) {
  if (!d) return '';
  return new Date(d).toLocaleDateString('en-US', { month: 'short', d: 'numeric', year: 'numeric' });
}
---

<Layout metadata={metadata}>
  <section class="max-w-6xl mx-auto px-6 pt-16 pb-20">

    <!-- Page header -->
    <div class="mb-10">
      <h1 class="text-4xl md:text-5xl font-bold text-zinc-900 tracking-tight mb-3">Trading Insights</h1>
      <p class="text-lg text-zinc-500 max-w-xl">Articles on trading psychology, risk infrastructure, and execution discipline.</p>
    </div>

    <!-- Category tabs -->
    {categories.length > 0 && (
      <div class="flex flex-wrap gap-2 mb-10" id="cat-tabs">
        <button
          data-cat="all"
          class="cat-btn active px-4 py-1.5 rounded-full text-sm font-medium transition-colors bg-zinc-900 text-white"
        >
          All Posts
        </button>
        {categories.map((cat) => (
          <button
            data-cat={cat}
            class="cat-btn px-4 py-1.5 rounded-full text-sm font-medium transition-colors bg-zinc-100 text-zinc-600 hover:bg-zinc-200"
          >
            {categoryMap[cat!] ?? cat}
          </button>
        ))}
      </div>
    )}

    <!-- Grid -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-7" id="articles-grid">
      {posts.map((post) => {
        const cat = post.data.category ?? '';
        const label = categoryMap[cat] ?? cat;
        const href = getPermalink(post.id, 'post');
        const mins = readingTime(post.body ?? '');
        const date = formatDate(post.data.publishDate);
        const img = post.resolvedImage;

        return (
          <article
            data-cat={cat}
            class="article-card group flex flex-col rounded-2xl overflow-hidden border border-zinc-200 bg-white hover:shadow-lg transition-shadow duration-300"
          >
            <!-- Cover image -->
            <a href={href} class="block overflow-hidden" style="aspect-ratio: 16/9;">
              {img ? (
                <img
                  src={typeof img === 'string' ? img : (img as any).src ?? img}
                  alt={post.data.title}
                  class="w-full h-full object-cover group-hover:scale-[1.03] transition-transform duration-500"
                  loading="lazy"
                />
              ) : (
                /* Gradient placeholder when no image */
                <div class="w-full h-full bg-gradient-to-br from-zinc-800 via-zinc-700 to-emerald-900 flex items-end p-5">
                  <span class="text-xs font-semibold tracking-widest uppercase text-emerald-400 opacity-80">
                    {label || 'Article'}
                  </span>
                </div>
              )}
            </a>

            <!-- Card body -->
            <div class="flex flex-col flex-1 p-5">
              <!-- Meta row -->
              <div class="flex items-center gap-2 text-xs text-zinc-400 mb-3">
                <span>{date}</span>
                <span>·</span>
                <span>{mins} min read</span>
                {label && (
                  <>
                    <span>·</span>
                    <span class="text-emerald-700 font-medium">{label}</span>
                  </>
                )}
              </div>

              <!-- Title -->
              <a href={href} class="block mb-2">
                <h2 class="text-base font-bold text-zinc-900 leading-snug group-hover:text-emerald-700 transition-colors duration-150 line-clamp-3">
                  {post.data.title}
                </h2>
              </a>

              <!-- Excerpt -->
              {post.data.excerpt && (
                <p class="text-sm text-zinc-500 leading-relaxed line-clamp-2 flex-1">
                  {post.data.excerpt}
                </p>
              )}

              <!-- Read more -->
              <div class="mt-4 pt-4 border-t border-zinc-100">
                <a
                  href={href}
                  class="inline-flex items-center gap-1 text-xs font-semibold text-zinc-700 hover:text-emerald-700 transition-colors"
                >
                  Read article
                  <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M9 5l7 7-7 7"/>
                  </svg>
                </a>
              </div>
            </div>
          </article>
        );
      })}
    </div>

    <!-- Empty state -->
    {posts.length === 0 && (
      <p class="text-center text-zinc-400 py-24 text-sm">No articles yet. Check back soon.</p>
    )}
  </section>
</Layout>

<style>
  .cat-btn.active {
    background-color: #18181b;
    color: #fff;
  }
</style>

<script>
  const tabs = document.querySelectorAll<HTMLButtonElement>('.cat-btn');
  const cards = document.querySelectorAll<HTMLElement>('.article-card');

  tabs.forEach((tab) => {
    tab.addEventListener('click', () => {
      const cat = tab.dataset.cat ?? 'all';

      tabs.forEach((t) => {
        t.classList.remove('active', 'bg-zinc-900', 'text-white');
        t.classList.add('bg-zinc-100', 'text-zinc-600');
      });
      tab.classList.add('active', 'bg-zinc-900', 'text-white');
      tab.classList.remove('bg-zinc-100', 'text-zinc-600');

      cards.forEach((card) => {
        if (cat === 'all' || card.dataset.cat === cat) {
          card.style.display = '';
        } else {
          card.style.display = 'none';
        }
      });
    });
  });
</script>
