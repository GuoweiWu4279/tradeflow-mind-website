---
import Layout from '~/layouts/PageLayout.astro';

import Hero from '~/components/widgets/Hero.astro';
import Note from '~/components/widgets/Note.astro';
import Features from '~/components/widgets/Features.astro';
import Steps from '~/components/widgets/Steps.astro';
import FAQs from '~/components/widgets/FAQs.astro';
import Stats from '~/components/widgets/Stats.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';

const metadata = {
  title: 'TradeFlow Mind — Trading Psychology Stability Index for NinjaTrader 8',
  ignoreTitleTemplate: true,
};
---

<Layout metadata={metadata}>

  <!-- Hero -->
  <Hero
    actions={[
      {
        variant: 'primary',
        text: 'Start Free Trial',
        href: '/download',
        icon: 'tabler:download',
      },
      { text: 'See Pricing', href: '/pricing' },
    ]}
  >
    <Fragment slot="title">
      Know Your Mind.
      <br />
      <span class="text-accent dark:text-white">Trade with Discipline.</span>
    </Fragment>

    <Fragment slot="subtitle">
      TradeFlow Mind is a real-time <strong>psychological stability index</strong> for NinjaTrader 8.
      Monitor your emotional state during live sessions and build the self-awareness that disciplined traders rely on.
      <br /><br />
      <span class="text-sm text-muted italic">
        Monitoring tool only. Does not provide trading signals or financial advice.
        <a href="/disclaimer" class="underline">Risk Disclaimer</a>.
      </span>
    </Fragment>
  </Hero>

  <!-- Note / Philosophy banner -->
  <Note
    title="Designed for:"
    description="Futures and forex traders on NinjaTrader 8 who take trading psychology seriously."
  />

  <!-- Stats -->
  <Stats
    stats={[
      { title: 'Active Traders', amount: '500+' },
      { title: 'Avg. Rating', amount: '4.8★' },
      { title: 'NinjaTrader Version', amount: 'NT8' },
      { title: 'Data Sent to Servers', amount: '0' },
    ]}
  />

  <!-- Features -->
  <Features
    id="features"
    tagline="Core Features"
    title="What TradeFlow Mind Does"
    subtitle="A focused set of tools to help you understand your psychological patterns during trading — nothing more, nothing less."
    items={[
      {
        title: 'Real-Time Stability Index',
        description:
          'A composite psychological stability score (0–100) calculated in real time during your NinjaTrader session, based on configurable behavioral inputs you define.',
        icon: 'tabler:activity',
      },
      {
        title: 'Session-by-Session Tracking',
        description:
          'Automatically records each trading session. Review your psychological patterns over time and identify recurring stress triggers across sessions.',
        icon: 'tabler:timeline',
      },
      {
        title: 'Threshold Alerts',
        description:
          'Set personal stability thresholds. Receive in-platform visual and audio alerts when your index drops below your chosen level.',
        icon: 'tabler:bell',
      },
      {
        title: 'NinjaTrader 8 Native',
        description:
          'Runs directly inside NinjaTrader 8 as an indicator panel. No external applications, no browser windows — stays within your existing workflow.',
        icon: 'tabler:plug',
      },
      {
        title: '100% Local — No Data Uploads',
        description:
          'All analysis runs on your machine. Your trading data and behavioral patterns are never transmitted to any external server. Privacy by design.',
        icon: 'tabler:shield-lock',
      },
      {
        title: 'Historical Export',
        description:
          'Export session data to CSV and compare psychological stability trends alongside your trading results over time. Identify your patterns.',
        icon: 'tabler:chart-bar',
      },
    ]}
  />

  <!-- How it works -->
  <Steps
    title="How It Works"
    items={[
      {
        title: 'Step 1: <span class="font-normal">Download & Install</span>',
        description:
          'Import TradeFlow Mind into NinjaTrader 8 via the standard NinjaScript Add-On import process. Takes under 2 minutes.',
        icon: 'tabler:download',
      },
      {
        title: 'Step 2: <span class="font-normal">Configure Your Thresholds</span>',
        description:
          'Set up your stability index parameters and alert thresholds in the indicator settings panel. Customize to match your trading style.',
        icon: 'tabler:settings',
      },
      {
        title: 'Step 3: <span class="font-normal">Trade & Monitor</span>',
        description:
          'The stability index panel is visible in your chart workspace during live trading. Watch your psychological state in real time.',
        icon: 'tabler:eye',
      },
      {
        title: 'Step 4: <span class="font-normal">Review & Learn</span>',
        description:
          'After each session, review your stability data. Over time, identify the conditions under which your discipline tends to weaken.',
        icon: 'tabler:report-analytics',
      },
    ]}
    image={{
      src: 'https://images.unsplash.com/photo-1611974789855-9c2a0a7236a3?ixlib=rb-4.0.3&auto=format&fit=crop&w=1740&q=80',
      alt: 'Trader at workstation monitoring market',
    }}
  />

  <!-- FAQ (abbreviated) -->
  <FAQs
    title="Common Questions"
    subtitle="For full answers, visit the FAQ page."
    tagline="FAQ"
    classes={{ container: 'max-w-6xl' }}
    items={[
      {
        title: 'Does TradeFlow Mind provide trading signals?',
        description:
          'No. TradeFlow Mind is a psychological monitoring tool only. It does not provide trading signals, market analysis, or any form of financial advice. All trading decisions remain entirely yours.',
      },
      {
        title: 'Is my trading data private?',
        description:
          'Yes. All calculations run locally on your machine. No trading data is ever sent to external servers. See our Privacy Policy for details.',
      },
      {
        title: 'Which version of NinjaTrader is required?',
        description:
          'NinjaTrader 8.0.23.0 or later is required. TradeFlow Mind is not compatible with NinjaTrader 7.',
      },
      {
        title: 'What is the refund policy?',
        description:
          '30-day money-back guarantee if the software fails to run on a supported system. See the Refund Policy page for full details.',
      },
    ]}
  />

  <!-- CTA -->
  <CallToAction
    actions={[
      {
        variant: 'primary',
        text: 'Download Free Trial',
        href: '/download',
        icon: 'tabler:download',
      },
      {
        text: 'View Pricing',
        href: '/pricing',
      },
    ]}
  >
    <Fragment slot="title">
      Ready to trade with more self-awareness?
    </Fragment>

    <Fragment slot="subtitle">
      14-day free trial. No credit card required. Works with your existing NinjaTrader 8 setup.
      <br />
      <span class="text-sm text-muted italic mt-2 block">
        Trading involves substantial risk of loss. TradeFlow Mind does not guarantee trading results.
      </span>
    </Fragment>
  </CallToAction>

</Layout>
