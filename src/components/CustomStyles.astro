---
import '@fontsource-variable/inter';
---

<style is:inline>
  :root {
    --aw-font-sans: 'Inter Variable';
    --aw-font-serif: 'Inter Variable';
    --aw-font-heading: 'Inter Variable';

    --aw-color-primary: #059669;       /* emerald-600 — CTAs, links */
    --aw-color-secondary: #047857;     /* emerald-700 */
    --aw-color-accent: #059669;
    /* Logo mark green (muted) — numerals, subtle accents */
    --aw-color-logo-green: #4b734e;

    --aw-color-text-heading: #18181b;  /* zinc-900 */
    --aw-color-text-default: #3f3f46;  /* zinc-700 */
    --aw-color-text-muted: #71717a;    /* zinc-500 */
    --aw-color-bg-page: #fafafa;

    --aw-color-bg-page-dark: rgb(9 9 11); /* zinc-950 */

    ::selection {
      background-color: #d1fae5;
      color: #064e3b;
    }
  }

  .dark {
    --aw-font-sans: 'Inter Variable';
    --aw-font-serif: 'Inter Variable';
    --aw-font-heading: 'Inter Variable';

    --aw-color-primary: #34d399;
    --aw-color-secondary: #6ee7b7;
    --aw-color-accent: #34d399;

    --aw-color-text-heading: #fafafa;
    --aw-color-text-default: #e4e4e7;
    --aw-color-text-muted: #a1a1aa;
    --aw-color-bg-page: rgb(9 9 11);

    ::selection {
      background-color: #064e3b;
      color: #d1fae5;
    }
  }
</style>
