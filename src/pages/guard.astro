---
import Layout from '~/layouts/PageLayout.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';

/** Hero background: replace `public/guard-bg.jpg` (not hashed — easy to swap after AI export). */
const guardBgUrl = '/guard-bg.jpg';

const metadata = {
  title: 'Meridian Guard — Commitment Device for Active Traders',
  description:
    'Meridian Guard enforces the rules you set for yourself. Six trigger conditions, five action levels, and an Intel Layer that turns your session history into actionable insight.',
};

const guardCheckout =
  'https://whop.com/checkout/plan_ZHX4ySB65fahf';

const guardSchemaJson = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "SoftwareApplication",
  "name": "Meridian Guard",
  "applicationCategory": "BusinessApplication",
  "applicationSubCategory": "Trading Risk Management",
  "operatingSystem": "Windows 10 or later",
  "description": "Meridian Guard is an automated behavioral enforcement system for active traders on NinjaTrader 8. It acts as a commitment device — you define the rules when calm, and Guard enforces them automatically when triggered. Six trigger conditions, five action levels including automated broker disconnect.",
  "url": "https://www.meridianpsi.com/guard",
  "featureList": [
    "Six trigger conditions: PSI Below, Consecutive Losses, Session P&L Below, Unrealized P&L Below, Single Trade Loss, Session Time Over",
    "Five response levels: Alert, Acknowledge (phrase confirmation), Countdown (forced pause), Risk Alert Mode, Broker Disconnect",
    "Automated broker disconnect — positions are never closed automatically",
    "Intel Layer: monthly behavioral digest, weekday patterns, PSI × P&L correlation, Today's Risk Brief",
    "Composure progress tracking over six months",
    "100% local — no cloud, no telemetry"
  ],
  "offers": {
    "@type": "Offer",
    "price": "34.99",
    "priceCurrency": "USD",
    "priceSpecification": {
      "@type": "UnitPriceSpecification",
      "price": "34.99",
      "priceCurrency": "USD",
      "billingDuration": "P1M"
    }
  },
  "softwareVersion": "1.0.0",
  "requirements": "NinjaTrader 8 (64-bit), Windows 10 or later, 4 GB RAM",
  "publisher": {
    "@type": "Organization",
    "name": "Meridian",
    "url": "https://www.meridianpsi.com"
  },
  "isPartOf": {
    "@type": "SoftwareApplication",
    "name": "Meridian",
    "url": "https://www.meridianpsi.com"
  }
});

/** Intel Layer — black 16:9 frame, image only (no in-frame captions). Copy: Intel/Weekday Patterns.png → intel-weekdaypattern.png */
const intelSlides = [
  /** Full screenshot visible — `cover` was cropping too much on this asset */
  { img: '/screenshots/psi-performance.png', alt: 'PSI × Performance' },
  { img: '/screenshots/digest-march.png', alt: 'Monthly Digest' },
  { img: '/screenshots/intel-weekdaypattern.png', alt: 'Weekday Patterns' },
  { img: '/screenshots/intel-risk-brief.png', alt: "Today's Risk Brief" },
];

const triggers = [
  { name: 'PSI Below', desc: 'Psychological stability drops under a threshold you define.' },
  { name: 'Consecutive Losses', desc: 'N losses in a row within the same session.' },
  { name: 'Session P&L Below', desc: 'Daily realized P&L falls past your declared limit.' },
  { name: 'Unrealized P&L Below', desc: 'Open position floating loss exceeds your threshold — before you close.' },
  { name: 'Single Trade Loss', desc: 'One trade loses more than a defined amount.' },
  { name: 'Session Time Over', desc: 'You have traded longer than you planned for the day.' },
];

const levels = [
  { level: 'L1', name: 'Alert',          color: '#059669', desc: 'A quiet notification. Does not interrupt trading.' },
  { level: 'L2', name: 'Acknowledge',    color: '#0d9488', desc: 'Type your own pre-written phrase before continuing.' },
  { level: 'L3', name: 'Countdown',      color: '#d97706', desc: 'Forced waiting period. Cannot be skipped.' },
  { level: 'L4', name: 'Risk Alert Mode',color: '#ea580c', desc: 'Persistent banner. Every entry requires active confirmation.' },
  { level: 'L5', name: 'Disconnect',     color: '#dc2626', desc: 'Disconnects your broker. Positions are never closed by the system.' },
];

const examples = [
  { name: 'Daily Loss Limit',       rule: 'P&L below -$500',                      action: 'Disconnect' },
  { name: 'Revenge Trade Check',    rule: '3 consecutive losses',                  action: 'Countdown + Acknowledge' },
  { name: 'Tilt Early Warning',     rule: 'PSI below 65',                          action: 'Alert' },
  { name: 'Hard Tilt Stop',         rule: 'PSI below 45 + P&L below -$300',        action: 'Disconnect 30 min' },
  { name: 'Position Risk Monitor',  rule: 'Unrealized below -$400',                action: 'Risk Alert Mode' },
  { name: 'Session Length Rule',    rule: 'Session over 180 minutes',              action: 'Acknowledge required' },
];
---

<Layout metadata={metadata}>
  <script type="application/ld+json" set:html={guardSchemaJson} />

  <!-- ═══════════════════════════════════════════════════════
       HERO  —  Left text / right screenshot
       ═══════════════════════════════════════════════════════ -->
  <section
    class="relative overflow-hidden md:-mt-[84px] not-prose guard-hero-surface"
    style={`--guard-hero-bg: url('${guardBgUrl}')`}
  >
    <!-- bottom fade into next section -->
    <div class="absolute bottom-0 left-0 right-0 h-32 pointer-events-none"
         style="background: linear-gradient(to bottom, transparent, #f0ede8);" aria-hidden="true"></div>

    <div class="md:pt-[84px]"></div>

    <div class="relative z-[1] max-w-6xl mx-auto px-6 py-14 md:py-20 lg:py-24">
      <div class="grid lg:grid-cols-[1fr_1fr] gap-12 lg:gap-16 items-center">

        <!-- Left: frosted panel so copy stays readable on busy background -->
        <div class="rounded-2xl bg-white/88 backdrop-blur-md px-6 py-7 md:px-8 md:py-9 shadow-sm ring-1 ring-zinc-900/[0.06]">
          <div class="inline-flex items-center gap-2.5 border px-4 py-1.5 mb-7 rounded-full"
               style="border-color:rgba(5,150,105,0.35); background:rgba(5,150,105,0.1);">
            <span class="w-1.5 h-1.5 rounded-full bg-emerald-600" aria-hidden="true"></span>
            <span class="text-[11px] font-semibold tracking-[0.15em] uppercase text-emerald-800">Meridian Guard</span>
          </div>

          <h1 class="text-4xl md:text-5xl font-bold tracking-tight leading-[1.18] text-zinc-900 mb-6">
            The rules you set for yourself.<br />
            <span class="text-emerald-600">Enforced automatically.</span>
          </h1>

          <p class="text-lg text-zinc-700 leading-relaxed mb-8 max-w-lg">
            When you are calm, you define the rules. When the moment comes — losing streak, tilt, blown limit — Guard enforces them. No decision required from you.
          </p>

          <!-- 3-step micro-flow -->
          <div class="flex items-center gap-3 mb-9 text-sm text-zinc-700">
            <div class="flex flex-col items-center gap-1">
              <div class="w-8 h-8 rounded-full bg-emerald-100 border border-emerald-200 flex items-center justify-center text-emerald-800 font-bold text-xs">1</div>
              <span class="text-xs text-zinc-600 whitespace-nowrap">Set your rules</span>
            </div>
            <div class="h-px flex-1 border-t border-dashed border-zinc-300"></div>
            <div class="flex flex-col items-center gap-1">
              <div class="w-8 h-8 rounded-full bg-zinc-100 border border-zinc-200 flex items-center justify-center text-zinc-600 font-bold text-xs">2</div>
              <span class="text-xs text-zinc-600 whitespace-nowrap">Trade normally</span>
            </div>
            <div class="h-px flex-1 border-t border-dashed border-zinc-300"></div>
            <div class="flex flex-col items-center gap-1">
              <div class="w-8 h-8 rounded-full bg-zinc-900 border border-zinc-700 flex items-center justify-center text-white font-bold text-xs">3</div>
              <span class="text-xs text-zinc-600 whitespace-nowrap">Guard acts for you</span>
            </div>
          </div>

          <div class="flex flex-col sm:flex-row gap-3">
            <a href={guardCheckout} class="btn btn-lg btn-primary font-semibold">
              Start 7-day free trial
            </a>
            <a href="#guard-system"
               class="btn btn-lg font-semibold border-[1.5px] border-zinc-300 text-zinc-800 bg-white/80 hover:bg-white">
              See how it works
            </a>
          </div>

          <p class="text-xs text-zinc-600 mt-5 leading-relaxed">
            $69.99/mo after trial · Cancel any time · Trading involves substantial risk of loss.
          </p>
        </div>

        <!-- Right: Guard trigger screenshot in dark device frame -->
        <div class="relative hidden lg:block">
          <div class="absolute -inset-4 rounded-3xl opacity-30 blur-2xl"
               style="background: radial-gradient(ellipse at center, rgba(5,150,105,0.28) 0%, transparent 70%);"
               aria-hidden="true"></div>
          <figure
            class="relative m-0 w-full rounded-2xl overflow-hidden shadow-2xl bg-zinc-950 flex items-center justify-center"
            style="border:1px solid rgba(255,255,255,0.12); box-shadow:0 32px 64px rgba(0,0,0,0.22), 0 4px 16px rgba(0,0,0,0.10); aspect-ratio:1170/677; max-height:min(440px,56vh);"
          >
            <img
              src="/guard-hero.png"
              alt="Meridian Guard — broker disconnected after a rule breach, with reconnect instructions"
              class="block w-full h-full object-contain"
              loading="eager"
            />
          </figure>
        </div>

      </div>
    </div>
  </section>


  <!-- ═══════════════════════════════════════════════════════
       COMMITMENT DEVICE  —  editorial pull-quote
       ═══════════════════════════════════════════════════════ -->
  <section class="py-16 px-6" style="background:#f0ede8;">
    <div class="max-w-3xl mx-auto">
      <div class="rounded-2xl border border-zinc-300/60 bg-white/80 shadow-sm px-8 py-8 md:px-12 md:py-10">
        <p class="text-[11px] font-semibold tracking-[0.2em] text-emerald-700 uppercase mb-5">Why Guard exists</p>
        <p class="text-xl md:text-2xl font-medium text-zinc-800 leading-[1.55]">
          Behavioral economists call this a <strong class="text-zinc-900">commitment device</strong> — a mechanism you set up in advance to constrain your future behavior.<br /><br />
          Institutional traders have compliance systems that do this automatically. Meridian Guard does the same for independent traders.
        </p>
      </div>
    </div>
  </section>


  <!-- ═══════════════════════════════════════════════════════
       GUARD SYSTEM  —  Step 1 triggers + Step 2 levels
       ═══════════════════════════════════════════════════════ -->
  <section id="guard-system" class="py-20 md:py-28 px-6 bg-white border-t border-zinc-200/60">
    <div class="max-w-6xl mx-auto">

      <!-- Section header -->
      <div class="max-w-2xl mb-16">
        <p class="text-[11px] font-semibold tracking-[0.2em] text-emerald-700 uppercase mb-3">The Guard System</p>
        <h2 class="text-3xl md:text-4xl font-bold text-zinc-900 tracking-tight mb-4">
          Six ways to detect. Five ways to respond.
        </h2>
        <p class="text-zinc-600 leading-relaxed text-lg">
          You set the pairing once. Guard watches every session and acts the moment a condition is met — no manual check-in required.
        </p>
      </div>

      <!-- STEP 1: Trigger conditions -->
      <div class="mb-20">
        <div class="flex items-center gap-4 mb-8">
          <div class="flex-none w-9 h-9 rounded-full bg-zinc-900 text-white flex items-center justify-center text-sm font-bold">1</div>
          <div>
            <p class="text-[11px] font-semibold tracking-[0.15em] text-zinc-500 uppercase">Step 1</p>
            <h3 class="text-xl md:text-2xl font-bold text-zinc-900">Define when to intervene</h3>
          </div>
          <p class="hidden md:block text-sm text-zinc-500 ml-auto max-w-xs text-right leading-relaxed">
            Each condition fires once on entry, then resets. No repeated nudges.
          </p>
        </div>

        <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4">
          {triggers.map((item) => (
            <div class="group rounded-xl border border-zinc-200 bg-zinc-50/60 p-5 md:p-6 hover:border-emerald-200 hover:bg-emerald-50/30 transition-all duration-200">
              <div class="flex items-start gap-3 mb-2">
                <svg class="w-4 h-4 mt-0.5 text-emerald-600 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/>
                </svg>
                <p class="font-semibold text-zinc-900">{item.name}</p>
              </div>
              <p class="text-zinc-600 text-sm leading-relaxed pl-7">{item.desc}</p>
            </div>
          ))}
        </div>
      </div>

      <!-- STEP 2: Action levels with color spectrum -->
      <div class="mb-20">
        <div class="flex items-center gap-4 mb-8">
          <div class="flex-none w-9 h-9 rounded-full bg-zinc-900 text-white flex items-center justify-center text-sm font-bold">2</div>
          <div>
            <p class="text-[11px] font-semibold tracking-[0.15em] text-zinc-500 uppercase">Step 2</p>
            <h3 class="text-xl md:text-2xl font-bold text-zinc-900">Choose the response level</h3>
          </div>
          <p class="hidden md:block text-sm text-zinc-500 ml-auto max-w-xs text-right leading-relaxed">
            Severity increases from a quiet nudge to a full broker disconnect.
          </p>
        </div>

        <!-- Severity bar -->
        <div class="flex h-1.5 rounded-full overflow-hidden mb-6 gap-0.5">
          {levels.map((l) => (
            <div class="flex-1 rounded-full" style={`background:${l.color};`}></div>
          ))}
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-5 gap-3">
          {levels.map((item) => (
            <div class="rounded-xl border bg-white p-4 flex flex-col gap-2 shadow-sm hover:shadow-md transition-shadow"
                 style={`border-color:${item.color}33;`}>
              <div class="flex items-center gap-2">
                <span class="text-[10px] font-bold tracking-widest px-1.5 py-0.5 rounded text-white"
                      style={`background:${item.color};`}>{item.level}</span>
                <span class="font-semibold text-zinc-900 text-sm">{item.name}</span>
              </div>
              <p class="text-zinc-600 text-xs leading-relaxed">{item.desc}</p>
            </div>
          ))}
        </div>
      </div>

      <!-- Example setups -->
      <div>
        <p class="text-[11px] font-semibold tracking-[0.2em] text-zinc-500 uppercase mb-3">Example setups</p>
        <h3 class="text-2xl font-bold text-zinc-900 mb-8">How traders configure Guard</h3>
        <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4">
          {examples.map((item) => (
            <div class="rounded-xl border border-zinc-200 bg-zinc-50 p-5 hover:border-zinc-300 transition-colors">
              <p class="font-semibold text-zinc-900 text-sm mb-3">{item.name}</p>
              <div class="space-y-1">
                <p class="text-zinc-500 text-xs font-mono">When: <span class="text-zinc-700">{item.rule}</span></p>
                <p class="text-xs font-mono font-medium" style="color:#059669;">Action: {item.action}</p>
              </div>
            </div>
          ))}
        </div>

        <!-- Utility features -->
        <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-3 mt-6">
          {[
            { name: 'Edge-trigger',    desc: 'Fires once per condition entry — no repeated alerts.' },
            { name: 'Cooldown',        desc: 'Prevents rapid re-triggering between conditions.' },
            { name: 'Emergency Reset', desc: 'One click clears all active Guard state.' },
            { name: 'Master switch',   desc: 'Disable Guard entirely without losing your rules.' },
          ].map((item) => (
            <div class="rounded-xl border border-dashed border-zinc-300 bg-white/80 p-4">
              <p class="font-semibold text-zinc-900 text-sm mb-1">{item.name}</p>
              <p class="text-zinc-500 text-xs leading-relaxed">{item.desc}</p>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>


  <!-- ═══════════════════════════════════════════════════════
       L2 CALLOUT  —  Only deep-color section on the page
       ═══════════════════════════════════════════════════════ -->
  <section class="py-20 px-6" style="background:#18181b;">
    <div class="max-w-3xl mx-auto text-center">
      <p class="text-[11px] font-semibold tracking-[0.2em] text-emerald-400 uppercase mb-6">
        Why L2 — Acknowledge — is the most powerful level
      </p>
      <blockquote class="text-2xl md:text-3xl font-semibold text-white leading-[1.4] mb-8">
        "I will not revenge trade.<br class="hidden sm:block" />
        My plan is my edge."
      </blockquote>
      <p class="text-zinc-400 leading-relaxed max-w-xl mx-auto">
        You write that phrase yourself — when you are calm, before the session starts. In the moment, you have to type it before the platform lets you continue. Your own words, at the exact moment you need them most.
      </p>
    </div>
  </section>


  <!-- ═══════════════════════════════════════════════════════
       INTEL LAYER  —  Guard-exclusive feature
       ═══════════════════════════════════════════════════════ -->
  <section class="py-20 md:py-28 px-6 border-t border-zinc-200/60" style="background:#f7f5f2;">
    <div class="max-w-6xl mx-auto">

      <!-- Header -->
      <div class="max-w-2xl mb-14">
        <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full text-xs font-semibold bg-emerald-100 text-emerald-800 border border-emerald-200 mb-5">
          Guard exclusive
        </div>
        <h2 class="text-3xl md:text-4xl font-bold text-zinc-900 tracking-tight mb-4">
          Intel Layer — your session history,<br class="hidden md:block" /> turned into decisions.
        </h2>
        <p class="text-zinc-600 leading-relaxed text-lg">
          Guard stores 5 years of session history locally and surfaces behavioral patterns that are invisible in any single session.
        </p>
      </div>

      <!-- Side-by-side: tab cards left + fixed 16:9 frame (same pattern as homepage Intel) -->
      <div class="grid md:grid-cols-[2fr_3fr] gap-8 items-start" data-guard-intel>
        <!-- Left: tab nav cards -->
        <div class="flex flex-col gap-3" role="tablist" aria-label="Intel Layer views">
          {[
            { idx: 0, title: 'PSI × Performance',  desc: 'Your P&L mapped against PSI zone — see exactly what Stable sessions average versus Critical.' },
            { idx: 1, title: 'Monthly Digest',      desc: 'Composure trend, stable days, win rate, avg P&L, best and worst days — every month.' },
            { idx: 2, title: 'Weekday Patterns',    desc: 'Find your weakest trading day and track 6-month Composure progress.' },
            { idx: 3, title: "Today's Risk Brief",  desc: 'Pre-session summary built from your own history — personalized before your first trade.' },
          ].map((card) => (
            <button
              type="button"
              role="tab"
              data-guard-intel-tab
              data-guard-intel-idx={card.idx}
              aria-selected={card.idx === 0 ? 'true' : 'false'}
              tabindex={card.idx === 0 ? 0 : -1}
              class:list={[
                'text-left rounded-xl p-4 border transition-all duration-200',
                card.idx === 0
                  ? 'border-emerald-400 bg-white shadow-sm shadow-emerald-100'
                  : 'border-zinc-200 bg-white/60 hover:border-zinc-300 hover:bg-white',
              ]}
            >
              <h3 class="font-semibold text-zinc-900 mb-1 text-sm">{card.title}</h3>
              <p class="text-zinc-600 text-xs leading-relaxed">{card.desc}</p>
            </button>
          ))}
        </div>

        <!-- Right: fixed frame + stacked views (absolute), arrows inside frame -->
        <div class="relative group/guard-intel min-w-0">
          <div
            id="guard-intel-panel"
            class="guard-media-frame relative overflow-hidden rounded-xl shadow-sm ring-1 ring-zinc-900/[0.06] w-full"
            style="position: relative; isolation: isolate; z-index: 0; width: 100%; aspect-ratio: 16 / 9; min-height: 0; background: #1C1C1E;"
            role="tabpanel"
          >
            {intelSlides.map((slide, i) => (
              <div
                class:list={['guard-intel-view', { 'is-active': i === 0 }]}
                data-guard-intel-view
                style="position: absolute; inset: 0; overflow: hidden;"
                aria-hidden={i === 0 ? 'false' : 'true'}
              >
                <img
                  src={slide.img}
                  alt={slide.alt}
                  class="absolute inset-0 h-full w-full"
                  style={`object-fit: ${slide.objectFit ?? 'contain'}; object-position: ${slide.objectPosition ?? 'center'};`}
                  loading={i === 0 ? 'eager' : 'lazy'}
                  decoding="async"
                />
              </div>
            ))}

            <button
              type="button"
              data-guard-intel-prev
              class="absolute left-2.5 top-1/2 z-20 flex h-9 w-9 -translate-y-1/2 items-center justify-center rounded-full bg-black/40 text-white opacity-0 backdrop-blur-sm transition-all hover:bg-black/70 focus-visible:opacity-100 group-hover/guard-intel:opacity-100"
              aria-label="Previous Intel view"
            >
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="h-4 w-4" aria-hidden="true">
                <path fill-rule="evenodd" d="M11.78 5.22a.75.75 0 0 1 0 1.06L8.06 10l3.72 3.72a.75.75 0 1 1-1.06 1.06l-4.25-4.25a.75.75 0 0 1 0-1.06l4.25-4.25a.75.75 0 0 1 1.06 0Z" clip-rule="evenodd" />
              </svg>
            </button>
            <button
              type="button"
              data-guard-intel-next
              class="absolute right-2.5 top-1/2 z-20 flex h-9 w-9 -translate-y-1/2 items-center justify-center rounded-full bg-black/40 text-white opacity-0 backdrop-blur-sm transition-all hover:bg-black/70 focus-visible:opacity-100 group-hover/guard-intel:opacity-100"
              aria-label="Next Intel view"
            >
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="h-4 w-4" aria-hidden="true">
                <path fill-rule="evenodd" d="M8.22 5.22a.75.75 0 0 1 1.06 0l4.25 4.25a.75.75 0 0 1 0 1.06l-4.25 4.25a.75.75 0 1 1-1.06-1.06L11.94 10 8.22 6.28a.75.75 0 0 1 0-1.06Z" clip-rule="evenodd" />
              </svg>
            </button>
          </div>
        </div>
      </div>
    </div>
  </section>


  <!-- ═══════════════════════════════════════════════════════
       COMPARISON TABLE
       ═══════════════════════════════════════════════════════ -->
  <section id="comparison" class="py-20 px-6 bg-white border-t border-zinc-200/60">
    <div class="max-w-3xl mx-auto">
      <div class="text-center mb-10">
        <h2 class="text-3xl font-bold text-zinc-900">Meridian vs Meridian Guard</h2>
        <p class="text-zinc-600 mt-3">Guard includes everything in Core, plus the Guard System and Intel Layer.</p>
      </div>
      <div class="rounded-2xl border border-zinc-200 overflow-hidden shadow-sm">
        <!-- Header row -->
        <div class="grid grid-cols-3 text-sm font-semibold" style="background:#18181b; color:white;">
          <div class="px-5 py-4 text-zinc-400"></div>
          <div class="px-5 py-4 border-l border-zinc-700/60">
            Meridian<br />
            <span class="font-normal text-zinc-400 text-xs">$49.99/mo</span>
          </div>
          <div class="px-5 py-4 border-l border-zinc-700/60" style="color:#34d399;">
            Meridian Guard<br />
            <span class="font-normal text-xs" style="color:#059669;">$69.99/mo</span>
          </div>
        </div>
        <!-- Feature rows -->
        {[
          ['Real-time PSI score',                        true,  true],
          ['7 behavioral signal bars',                   true,  true],
          ['Personal baselines',                         true,  true],
